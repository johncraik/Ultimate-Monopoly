@page "{id}"
@model UltimateMonopoly.Pages.Game.SetupModel
@{
    ViewData["Title"] = "Game Setup";
}

<style>
    .qr-code svg { width: 100%; height: auto; display: block; }

    [data-can-reorder="true"] .player-card { cursor: grab; }
    .player-card-ghost { opacity: 0.4; }
    .player-card-drag {
        cursor: grabbing;
        box-shadow: 0 0.75rem 1.75rem rgba(0, 0, 0, 0.55);
    }
</style>

<div class="mb-3">
    <h1 class="mb-1">@Model.GameName</h1>
    <p class="text-body-secondary mb-0">
        Board: <strong class="text-body">@Model.BoardName</strong>
        <span class="mx-2">·</span>
        Rounding: <strong class="text-body">@Model.RoundingRuleText</strong>
    </p>
</div>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="position-fixed top-0 end-0 p-3" style="z-index: 1090;" data-setup-alert>
        <alert type="@Model.StatusAlertType" message="@Model.StatusMessage" />
    </div>
}

<div class="row g-4">
    @* ---------- Players ---------- *@
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header d-flex align-items-center justify-content-between">
                <span class="fw-semibold">Players</span>
                <span class="badge text-bg-secondary">@Model.Players.Count / 8</span>
            </div>
            <div class="card-body d-flex flex-column gap-2"
                 data-player-list data-can-reorder="@Model.ViewerIsHost.ToString().ToLowerInvariant()">
                @foreach (var p in Model.Players)
                {
                    <div class="card player-card @(p.IsHost ? "border-primary" : "")"
                         data-player-card data-user-id="@p.Profile.UserId">
                        <div class="card-body d-flex align-items-center gap-3 py-2">
                            <profile-circle user="p.Profile" size="Md" />
                            <div class="flex-grow-1 min-w-0">
                                <div class="fw-semibold text-truncate">
                                    @p.Profile.DisplayName
                                    @if (p.IsHost)
                                    {
                                        <span class="badge text-bg-primary ms-1">Host</span>
                                    }
                                </div>
                                <div class="small text-body-secondary">
                                    Dice Numbers:
                                    @if (p.Dice1 is null || p.Dice2 is null)
                                    {
                                        <span class="badge text-bg-warning">Not Set</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-secondary">@p.Dice1 | @p.Dice2</span>
                                    }
                                </div>
                            </div>

                            <button type="button" class="btn btn-sm btn-outline-info"
                                    data-bs-toggle="modal" data-bs-target="#setDiceModal"
                                    data-set-dice
                                    data-user-id="@p.Profile.UserId"
                                    data-name="@p.Profile.DisplayName"
                                    data-dice1="@(p.Dice1?.ToString() ?? string.Empty)"
                                    data-dice2="@(p.Dice2?.ToString() ?? string.Empty)">
                                Set Dice
                            </button>

                            @if (Model.ViewerIsHost && !p.IsHost)
                            {
                                <form method="post" asp-page-handler="Kick" class="m-0">
                                    <input type="hidden" name="targetUserId" value="@p.Profile.UserId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Kick</button>
                                </form>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    @* ---------- Join QR ---------- *@
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">Join Game</div>
            <div class="card-body d-flex flex-column align-items-center justify-content-center text-center pb-5">
                <p class="text-body-secondary small">Scan to join this game.</p>
                <div class="qr-code" style="max-width: 360px; width: 100%;">@Html.Raw(Model.JoinQrSvg)</div>
                <div class="mt-3">
                    <p class="small text-body-secondary mb-1">
                        Or visit <strong class="text-body">/join</strong> to enter code:
                    </p>
                    <span class="fs-3 fw-bold font-monospace text-primary">@Model.JoinCode</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-2 mt-4">
    @* TODO: wire up once TryCancelGame / TryStartGame + the in-game view exist *@
    <div class="col-6">
        <button type="button" class="btn btn-hero-primary w-100">Start Game</button>
    </div>
    <div class="col-6">
        <button type="button" class="btn btn-hero-danger w-100">Cancel Game</button>
    </div>
</div>

@if (Model.ViewerIsHost)
{
    <form method="post" asp-page-handler="Reorder" class="d-none" data-reorder-form></form>
}

@* ---------- Set Dice modal ---------- *@
<div class="modal fade" id="setDiceModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="SetDice">
                <div class="modal-header">
                    <h5 class="modal-title">Set Dice Numbers</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-body-secondary small mb-3" data-dice-player></p>
                    <input type="hidden" name="targetUserId" data-dice-target />
                    <div class="row g-2">
                        <div class="col-6">
                            <label class="form-label">Die 1</label>
                            <input type="number" class="form-control" name="dice1" min="1" max="6" required data-dice1 />
                        </div>
                        <div class="col-6">
                            <label class="form-label">Die 2</label>
                            <input type="number" class="form-control" name="dice2" min="1" max="6" required data-dice2 />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/scripts/Sortable.min.js" asp-append-version="true"></script>
    <script src="~/scripts/game-setup.js" asp-append-version="true"></script>
}