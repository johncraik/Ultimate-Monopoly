@page
@using JC.Core.Extensions
@using UltimateMonopoly.Enums.Games
@model UltimateMonopoly.Pages.Game.IndexModel
@{
    ViewData["Title"] = "New Game";
}

<div class="mb-4">
    <h1 class="mb-1">New Game</h1>
    <p class="text-body-secondary mb-0">Set up a new game of Ultimate Monopoly.</p>
</div>

<div class="row g-4">
    @* ---------- Create dialog ---------- *@
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header fw-semibold">Game Details</div>
            <div class="card-body">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="Name">Game Name</label>
                        <input class="form-control" asp-for="Name"
                               placeholder="Leave blank for an auto-generated name" />
                        <span class="text-danger small" asp-validation-for="Name"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="BoardSkinId">Board</label>
                        <select class="form-select" asp-for="BoardSkinId" asp-items="Model.Boards"></select>
                        <div class="form-text">Pick a custom board skin, or use the default board.</div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label" asp-for="RoundingRule">Rounding Rule</label>
                        <select class="form-select" asp-for="RoundingRule">
                            @foreach (var rule in Enum.GetValues<GameRoundingRule>())
                            {
                                <option value="@rule">@rule.GetDescription()</option>
                            }
                        </select>
                        <div class="form-text">See the panel on the right for what each rule does.</div>
                    </div>

                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary">Create Game</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @* ---------- Rounding rules explainer ---------- *@
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header fw-semibold">Rounding Rules</div>
            <div class="card-body">
                <p class="text-body-secondary small">
                    The rounding rule controls how money amounts are rounded during play —
                    rent, loan repayments, fines and so on.
                </p>
                <ul class="list-group list-group-flush">
                    @foreach (var rule in Enum.GetValues<GameRoundingRule>())
                    {
                        <li class="list-group-item px-0 bg-transparent">
                            <span class="fw-semibold">@rule.GetDescription()</span>
                            <span class="d-block small text-body-secondary">
                                @switch (rule)
                                {
                                    case GameRoundingRule.None:
                                        <span>No rounding applied</span>
                                        break;
                                    case GameRoundingRule.To5:
                                        <span>Fines/payments are rounded to the nearest 5</span>
                                        break;
                                    case GameRoundingRule.To10:
                                        <span>Fines/payments are rounded to the nearest 10 (5 rounds up)</span>
                                        break;
                                    case GameRoundingRule.To20:
                                        <span>Fines/payments are rounded to the nearest 20 (10 rounds up)</span>
                                        break;
                                    case GameRoundingRule.To50:
                                        <span>Fines/payments are rounded to the nearest 50 (25 rounds up)</span>
                                        break;
                                    default:
                                        throw new ArgumentOutOfRangeException();
                                }
                            </span>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}