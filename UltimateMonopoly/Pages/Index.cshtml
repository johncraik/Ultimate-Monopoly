@page
@using MP.GameEngine.Helpers.RuleSet
@model IndexModel
@{
    ViewData["Title"] = "Home";
    var gameName = RuleDictionary.GameName;
}

<link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />

@if (!Model.IsSignedIn)
{
    @* ─────────────────────────────── Public landing (anonymous) ─────────────────────────────── *@
    <div class="py-4 py-lg-5">

        @* Hero *@
        <section class="row align-items-center g-4 g-lg-5 mb-5 text-center text-lg-start">
            <div class="col-lg-7">
                <span class="badge home-hero-badge rounded-pill mb-3 px-3 py-2">
                    <i class="bi bi-dice-5 me-1"></i>A companion app for the board game
                </span>
                <h1 class="fw-bold mb-3 home-hero-title">@gameName</h1>
                <p class="lead text-body-secondary mb-4">
                    A wilder take on Monopoly — <strong>three dice</strong> that keep the whole table moving,
                    a deep <strong>card system</strong> with table-wide global events, and a
                    <strong>social &amp; stats</strong> layer on top. You play on a real board; the app runs
                    the fiddly bits — money, cards, loans, and the bookkeeping.
                </p>
                <div class="d-flex flex-wrap gap-2 justify-content-center justify-content-lg-start">
                    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-hero-primary btn-lg">
                        Get started — it's free
                    </a>
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-nav-info btn-lg">Sign in</a>
                    <a asp-area="" asp-page="/Rules" class="btn btn-nav btn-lg">Read the rules</a>
                </div>
            </div>
            <div class="col-lg-5">
                @* A mock of a player's phone profile — header, roll button, stats, and the
                   icon-only tab bar — to show what each player sees in-game. *@
                <div class="home-glimpse d-flex justify-content-center">
                    <div class="home-phone">
                        <div class="home-phone-screen">
                            <div class="home-phone-notch"></div>

                            @* Header — avatar · name · dice · money (mirrors the profile header) *@
                            <div class="card mb-2">
                                <div class="card-body d-flex align-items-center gap-2 py-2">
                                    <span class="home-avatar">AS</span>
                                    <div class="flex-grow-1 min-w-0">
                                        <div class="fw-semibold text-truncate">Alice Smith</div>
                                        <div class="small text-body-secondary d-flex flex-wrap align-items-center gap-2">
                                            <span>Dice <span class="badge text-bg-secondary">3 | 5</span></span>
                                            <span class="fw-semibold text-body">£2,450</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            @* Roll button (full-width hero, like the real profile) *@
                            <div class="d-grid mb-2">
                                <span class="btn btn-hero-success"><i class="bi bi-dice-5 me-1"></i> Roll Dice</span>
                            </div>

                            @* Block 1 — money / jail cost / triple bonus / %cap (the real Profile-tab list) *@
                            <div class="card mb-2">
                                <div class="card-body py-2">
                                    <dl class="row mb-0 small">
                                        <dt class="col-7 text-body-secondary fw-normal"><i class="bi bi-wallet2 me-1"></i>Money</dt>
                                        <dd class="col-5 text-end fw-semibold mb-1">£2,450</dd>
                                        <dt class="col-7 text-body-secondary fw-normal"><i class="bi bi-building-lock me-1"></i>Jail cost</dt>
                                        <dd class="col-5 text-end mb-1">£50</dd>
                                        <dt class="col-7 text-body-secondary fw-normal"><i class="bi bi-dice-3 me-1"></i>Triple bonus</dt>
                                        <dd class="col-5 text-end mb-1">£1,500</dd>
                                        <dt class="col-7 text-body-secondary fw-normal"><i class="bi bi-percent me-1"></i>Card %cap</dt>
                                        <dd class="col-5 text-end mb-0"><span class="badge text-bg-secondary">50%</span></dd>
                                    </dl>
                                </div>
                            </div>

                            @* Block 2 — current board space (colour banner · name · board index) *@
                            <div class="mb-2">
                                <div class="home-now-space">
                                    <div class="home-now-banner bg-prop-green"></div>
                                    <div class="home-now-name">Bond Street</div>
                                </div>
                                <div class="home-now-index">34</div>
                            </div>

                            @* Bottom icon tab bar — Profile · Properties · Cards · Loans · Deal *@
                            <div class="home-phone-tabs">
                                <span class="home-phone-tab active"><i class="bi bi-person-fill"></i></span>
                                <span class="home-phone-tab"><i class="bi bi-houses-fill"></i></span>
                                <span class="home-phone-tab"><i class="bi bi-card-text"></i></span>
                                <span class="home-phone-tab"><i class="bi bi-cash-coin"></i></span>
                                <span class="home-phone-tab"><i class="bi bi-arrow-left-right"></i></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        @* What makes it different *@
        <section class="mb-5">
            <h2 class="h3 text-center mb-4">What makes it different</h2>
            <div class="row g-3 g-md-4">
                <div class="col-md-4">
                    <div class="home-feature-card">
                        <span class="home-ico is-primary mb-3"><i class="bi bi-dice-6"></i></span>
                        <h3 class="h5">Three-dice movement</h3>
                        <p class="text-body-secondary mb-0">
                            Every roll uses three dice — two main plus a third that moves <em>every</em> other
                            player around the board too. The table is never standing still.
                        </p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="home-feature-card">
                        <span class="home-ico is-info mb-3"><i class="bi bi-collection"></i></span>
                        <h3 class="h5">A deep card system</h3>
                        <p class="text-body-secondary mb-0">
                            Percentage cards scaled by your buildings, held cards you play at the right moment,
                            immunities, and table-wide <strong>global events</strong> that rewrite the rules.
                        </p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="home-feature-card">
                        <span class="home-ico is-success mb-3"><i class="bi bi-graph-up-arrow"></i></span>
                        <h3 class="h5">Social &amp; stats</h3>
                        <p class="text-body-secondary mb-0">
                            Friends, a leaderboard, and rich per-game and lifetime statistics — money over time,
                            most-profitable sets, jail time, and dozens more.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        @* How it works *@
        <section class="mb-5">
            <h2 class="h3 text-center mb-4">How it works</h2>
            <div class="row g-4 text-center">
                <div class="col-md-4">
                    <span class="home-step-num mb-3">1</span>
                    <h3 class="h6"><i class="bi bi-tablet-landscape me-1"></i>One tablet hosts</h3>
                    <p class="text-body-secondary small mb-0">A shared tablet runs the game view — the board, the pot, whose turn it is.</p>
                </div>
                <div class="col-md-4">
                    <span class="home-step-num mb-3">2</span>
                    <h3 class="h6"><i class="bi bi-phone me-1"></i>Players join on phones</h3>
                    <p class="text-body-secondary small mb-0">Scan a code to manage your own money, cards and actions — or let the host drive.</p>
                </div>
                <div class="col-md-4">
                    <span class="home-step-num mb-3">3</span>
                    <h3 class="h6"><i class="bi bi-dice-5 me-1"></i>Play on the real board</h3>
                    <p class="text-body-secondary small mb-0">Roll real dice, move real tokens — the app keeps the ledger straight.</p>
                </div>
            </div>
        </section>

        @* Final CTA *@
        <section class="home-cta text-center py-5 px-3">
            <h2 class="h3 mb-2">Ready to play?</h2>
            <p class="text-body-secondary mb-4">Create a free account and start a game in minutes.</p>
            <div class="d-flex flex-wrap gap-2 justify-content-center">
                <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-hero-primary btn-lg">Create your account</a>
                <a asp-area="" asp-page="/Rules" class="btn btn-nav btn-lg">Browse the rules first</a>
            </div>
        </section>
    </div>
}
else
{
    @* ─────────────────────────────── Personalised hub (signed in) ─────────────────────────────── *@
    var played = Model.CurrentUser?.NumberOfGamesPlayed ?? 0;
    var winRate = played > 0 ? Model.CurrentUser!.NumberOfWins * 100.0 / played : 0;

    <div class="py-4">

        @* First-run welcome — onboarding nudge to the guide. Auto-retires once the player has
           any game; "Don't show again" flips HasDismissedWelcome (OnPostDismissWelcome). *@
        @if (Model.ShowWelcome)
        {
            <div class="home-cta p-3 p-md-4 mb-4">
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                    <div class="d-flex align-items-start gap-3 min-w-0">
                        <span class="home-ico is-primary flex-shrink-0"><i class="bi bi-emoji-smile"></i></span>
                        <div class="min-w-0">
                            <h2 class="h4 mb-1">Welcome to @gameName!</h2>
                            <p class="text-body-secondary mb-0">
                                New here? The quick-start walkthrough takes you from creating an account to playing
                                your first game in a few short steps.
                            </p>
                        </div>
                    </div>
                    <div class="d-flex flex-wrap gap-2 flex-shrink-0">
                        <a class="btn btn-hero-primary" asp-area="" asp-page="/Guides/Index">
                            <i class="bi bi-mortarboard me-1"></i> How to play
                        </a>
                        <form method="post" asp-page-handler="DismissWelcome" class="m-0">
                            <button type="submit" class="btn btn-nav">Don't show again</button>
                        </form>
                    </div>
                </div>
            </div>
        }

        @* Welcome + primary actions *@
        <div class="home-welcome p-3 p-md-4 mb-4">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                <div class="d-flex align-items-center gap-3 min-w-0">
                    @if (Model.CurrentUser is not null)
                    {
                        <profile-circle user="Model.CurrentUser" size="Lg" />
                    }
                    <div class="min-w-0">
                        <div class="text-body-secondary small">Welcome back</div>
                        <h1 class="h3 mb-0 text-truncate">@(Model.CurrentUser?.DisplayName ?? "Player")</h1>
                    </div>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-hero-primary" asp-area="" asp-page="/Games/Index"><i class="bi bi-plus-circle me-1"></i>New game</a>
                    <a class="btn btn-nav-info" asp-area="" asp-page="/Games/Join"><i class="bi bi-box-arrow-in-right me-1"></i>Join</a>
                    <a class="btn btn-nav" asp-area="" asp-page="/Games/MyGames">My games</a>
                    <a class="btn btn-nav" asp-area="" asp-page="/Leaderboard/Index">Leaderboard</a>
                </div>
            </div>
        </div>

        @* Snapshot stat cards *@
        <div class="row g-3 mb-4">
            <div class="col-6 col-lg-3">
                <div class="home-stat">
                    <span class="home-ico home-ico-sm is-primary"><i class="bi bi-controller"></i></span>
                    <div class="min-w-0">
                        <div class="home-stat-num">@Model.ActiveGames.Count</div>
                        <div class="home-stat-label">Active games</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="home-stat">
                    <span class="home-ico home-ico-sm is-info"><i class="bi bi-hourglass-split"></i></span>
                    <div class="min-w-0">
                        <div class="home-stat-num">@Model.SetupGames.Count</div>
                        <div class="home-stat-label">In setup</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="home-stat">
                    <span class="home-ico home-ico-sm is-success"><i class="bi bi-trophy"></i></span>
                    <div class="min-w-0">
                        <div class="home-stat-num">
                            @(Model.CurrentUser?.NumberOfWins ?? 0)<span class="text-body-secondary fs-6">–@(Model.CurrentUser?.NumberOfDraws ?? 0)–@(Model.CurrentUser?.NumberOfLosses ?? 0)</span>
                        </div>
                        <div class="home-stat-label">@winRate.ToString("0")% wins · @played played</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <a class="home-stat" asp-area="Social" asp-page="/Friends/Index" asp-route-tab="requests">
                    <span class="home-ico home-ico-sm is-muted"><i class="bi bi-person-plus"></i></span>
                    <div class="min-w-0">
                        <div class="home-stat-num">
                            @Model.PendingRequests
                            @if (Model.PendingRequests > 0)
                            {
                                <span class="badge text-bg-danger align-middle fs-6">new</span>
                            }
                        </div>
                        <div class="home-stat-label">Friend requests</div>
                    </div>
                </a>
            </div>
        </div>

        @* Continue playing *@
        @if (Model.ActiveGames.Count > 0)
        {
            <h2 class="h5 mb-2"><i class="bi bi-controller me-2"></i>Continue playing</h2>
            <div class="mb-4">
                <partial name="/Pages/Games/_GameList.cshtml" model="Model.ActiveGames" />
            </div>
        }

        @* Waiting to start *@
        @if (Model.SetupGames.Count > 0)
        {
            <h2 class="h5 mb-2"><i class="bi bi-hourglass-split me-2"></i>Waiting to start</h2>
            <div class="mb-4">
                <partial name="/Pages/Games/_GameList.cshtml" model="Model.SetupGames" />
            </div>
        }

        @if (Model.ActiveGames.Count == 0 && Model.SetupGames.Count == 0)
        {
            <div class="home-feature-card text-center py-5 mb-4">
                <i class="bi bi-dice-5 display-5 text-body-tertiary d-block mb-3"></i>
                <h2 class="h5">No games on the go</h2>
                <p class="text-body-secondary mb-3">Start a new game or join one with a code to get playing.</p>
                <div class="d-flex flex-wrap gap-2 justify-content-center">
                    <a class="btn btn-hero-primary" asp-area="" asp-page="/Games/Index">New game</a>
                    <a class="btn btn-nav-info" asp-area="" asp-page="/Games/Join">Join a game</a>
                </div>
            </div>
        }

        @* Quick links *@
        <h2 class="h6 text-body-secondary mb-2">Explore</h2>
        <div class="d-flex flex-wrap gap-2">
            <a class="home-link" asp-area="Social" asp-page="/Friends/Index" asp-route-tab="friends"><i class="bi bi-people"></i>Friends</a>
            <a class="home-link" asp-area="Social" asp-page="/Messages/Index"><i class="bi bi-chat-left-text"></i>Messages</a>
            <a class="home-link" asp-area="" asp-page="/Boards/Index"><i class="bi bi-grid-3x3"></i>My boards</a>
            <a class="home-link" asp-area="" asp-page="/Rules"><i class="bi bi-journal-text"></i>Rules</a>
            <a class="home-link" asp-area="Identity" asp-page="/Profile/Index"><i class="bi bi-person"></i>Profile</a>
        </div>
    </div>
}