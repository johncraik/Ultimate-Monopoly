@page
@model IndexModel
@{
    ViewData["Title"] = "Theme Preview";
}

<h1 class="mb-4">Bootstrap Theme Preview</h1>

<!-- Buttons -->
<section class="mb-5">
    <h2 class="mb-3">Buttons</h2>
    <div class="d-flex flex-wrap gap-2 mb-3">
        <button class="btn btn-primary">Primary</button>
        <button class="btn btn-secondary">Secondary</button>
        <button class="btn btn-success">Success</button>
        <button class="btn btn-danger">Danger</button>
        <button class="btn btn-warning">Warning</button>
        <button class="btn btn-info">Info</button>
        <button class="btn btn-light">Light</button>
        <button class="btn btn-dark">Dark</button>
    </div>
    <div class="d-flex flex-wrap gap-2 mb-3">
        <button class="btn btn-outline-primary">Primary</button>
        <button class="btn btn-outline-secondary">Secondary</button>
        <button class="btn btn-outline-success">Success</button>
        <button class="btn btn-outline-danger">Danger</button>
        <button class="btn btn-outline-warning">Warning</button>
        <button class="btn btn-outline-info">Info</button>
        <button class="btn btn-outline-light">Light</button>
        <button class="btn btn-outline-dark">Dark</button>
    </div>
    <div class="d-flex flex-wrap gap-2 mb-4">
        <button class="btn btn-primary btn-sm">Small</button>
        <button class="btn btn-primary">Default</button>
        <button class="btn btn-primary btn-lg">Large</button>
        <button class="btn btn-primary" disabled>Disabled</button>
    </div>

    <h5 class="mb-2">Nav buttons <small class="text-body-secondary">(transparent, animated underline)</small></h5>
    <div class="d-flex flex-wrap gap-2 mb-4 p-2 rounded bg-body-tertiary">
        <button class="btn btn-nav">Default</button>
        <button class="btn btn-nav-primary">Primary</button>
        <button class="btn btn-nav-secondary">Secondary</button>
        <button class="btn btn-nav-success">Success</button>
        <button class="btn btn-nav-danger">Danger</button>
        <button class="btn btn-nav-warning">Warning</button>
        <button class="btn btn-nav-info">Info</button>
        <button class="btn btn-nav-light">Light</button>
        <button class="btn btn-nav-dark">Dark</button>
    </div>

    <h5 class="mb-2">Hero buttons <small class="text-body-secondary">(gradient + shine sweep on hover)</small></h5>
    <div class="d-flex flex-wrap gap-3">
        <button class="btn btn-hero-primary">Primary</button>
        <button class="btn btn-hero-secondary">Secondary</button>
        <button class="btn btn-hero-success">Success</button>
        <button class="btn btn-hero-danger">Danger</button>
        <button class="btn btn-hero-warning">Warning</button>
        <button class="btn btn-hero-info">Info</button>
        <button class="btn btn-hero-light">Light</button>
        <button class="btn btn-hero-primary" disabled>Disabled</button>
    </div>
</section>

<!-- Alerts -->
<section class="mb-5">
    <h2 class="mb-3">Alerts</h2>
    <div class="alert alert-primary">This is a <strong>primary</strong> alert.</div>
    <div class="alert alert-secondary">This is a <strong>secondary</strong> alert.</div>
    <div class="alert alert-success">This is a <strong>success</strong> alert.</div>
    <div class="alert alert-danger">This is a <strong>danger</strong> alert.</div>
    <div class="alert alert-warning">This is a <strong>warning</strong> alert.</div>
    <div class="alert alert-info">This is an <strong>info</strong> alert.</div>
    <div class="alert alert-light">This is a <strong>light</strong> alert.</div>
    <div class="alert alert-dark">This is a <strong>dark</strong> alert.</div>
</section>

<!-- Badges -->
<section class="mb-5">
    <h2 class="mb-3">Badges</h2>
    <div class="d-flex flex-wrap gap-2">
        <span class="badge bg-primary">Primary</span>
        <span class="badge bg-secondary">Secondary</span>
        <span class="badge bg-success">Success</span>
        <span class="badge bg-danger">Danger</span>
        <span class="badge bg-warning text-dark">Warning</span>
        <span class="badge bg-info text-dark">Info</span>
        <span class="badge bg-light text-dark">Light</span>
        <span class="badge bg-dark">Dark</span>
        <span class="badge rounded-pill bg-primary">Pill Primary</span>
        <span class="badge rounded-pill bg-success">Pill Success</span>
    </div>
</section>

<!-- Cards -->
<section class="mb-5">
    <h2 class="mb-3">Cards</h2>
    <div class="row g-3">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Default Card</h5>
                    <p class="card-text">Some quick example text to build on the card title and make up the bulk of the card's content.</p>
                    <a href="#" class="btn btn-primary">Go somewhere</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-primary">
                <div class="card-header bg-primary text-white">Primary Header</div>
                <div class="card-body">
                    <h5 class="card-title">Primary Card</h5>
                    <p class="card-text">Card with primary border and header styling.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-success">
                <div class="card-header bg-success text-white">Success Header</div>
                <div class="card-body">
                    <h5 class="card-title">Success Card</h5>
                    <p class="card-text">Card with success border and header styling.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">Danger Header</div>
                <div class="card-body">
                    <h5 class="card-title">Danger Card</h5>
                    <p class="card-text">Card with danger border and header styling.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-warning">
                <div class="card-header bg-warning text-dark">Warning Header</div>
                <div class="card-body">
                    <h5 class="card-title">Warning Card</h5>
                    <p class="card-text">Card with warning border and header styling.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-info">
                <div class="card-header bg-info text-dark">Info Header</div>
                <div class="card-body">
                    <h5 class="card-title">Info Card</h5>
                    <p class="card-text">Card with info border and header styling.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Table -->
<section class="mb-5">
    <h2 class="mb-3">Tables</h2>
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>#</th>
                <th>Name</th>
                <th>Status</th>
                <th>Amount</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>1</td>
                <td>Mediterranean Avenue</td>
                <td><span class="badge bg-success">Available</span></td>
                <td>$60</td>
            </tr>
            <tr>
                <td>2</td>
                <td>Boardwalk</td>
                <td><span class="badge bg-danger">Owned</span></td>
                <td>$400</td>
            </tr>
            <tr>
                <td>3</td>
                <td>Park Place</td>
                <td><span class="badge bg-warning text-dark">Mortgaged</span></td>
                <td>$350</td>
            </tr>
            <tr class="table-primary">
                <td>4</td>
                <td>Reading Railroad</td>
                <td><span class="badge bg-info text-dark">Railroad</span></td>
                <td>$200</td>
            </tr>
            <tr class="table-success">
                <td>5</td>
                <td>Electric Company</td>
                <td><span class="badge bg-secondary">Utility</span></td>
                <td>$150</td>
            </tr>
        </tbody>
    </table>

    <h5 class="mt-4">Coloured Table Rows</h5>
    <table class="table">
        <tbody>
            <tr class="table-primary"><td>table-primary</td><td>Row styled with primary</td></tr>
            <tr class="table-secondary"><td>table-secondary</td><td>Row styled with secondary</td></tr>
            <tr class="table-success"><td>table-success</td><td>Row styled with success</td></tr>
            <tr class="table-danger"><td>table-danger</td><td>Row styled with danger</td></tr>
            <tr class="table-warning"><td>table-warning</td><td>Row styled with warning</td></tr>
            <tr class="table-info"><td>table-info</td><td>Row styled with info</td></tr>
            <tr class="table-light"><td>table-light</td><td>Row styled with light</td></tr>
            <tr class="table-dark"><td>table-dark</td><td>Row styled with dark</td></tr>
        </tbody>
    </table>
</section>

<!-- Links & Typography -->
<section class="mb-5">
    <h2 class="mb-3">Links &amp; Typography</h2>
    <p><a href="#" class="link-primary">Primary link</a></p>
    <p><a href="#" class="link-secondary">Secondary link</a></p>
    <p><a href="#" class="link-success">Success link</a></p>
    <p><a href="#" class="link-danger">Danger link</a></p>
    <p><a href="#" class="link-warning">Warning link</a></p>
    <p><a href="#" class="link-info">Info link</a></p>
    <p><a href="#" class="link-light">Light link</a></p>
    <p><a href="#" class="link-dark">Dark link</a></p>

    <hr class="my-4" />

    <h1>Heading 1</h1>
    <h2>Heading 2</h2>
    <h3>Heading 3</h3>
    <h4>Heading 4</h4>
    <h5>Heading 5</h5>
    <h6>Heading 6</h6>
    <p class="lead">This is a lead paragraph for emphasis.</p>
    <p>This is a regular paragraph with <strong>bold text</strong>, <em>italics</em>, and <code>inline code</code>.</p>
    <blockquote class="blockquote">
        <p>This is a blockquote for highlighting important text.</p>
    </blockquote>
</section>

<!-- Forms -->
<section class="mb-5">
    <h2 class="mb-3">Forms</h2>
    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label">Email address</label>
                <input type="email" class="form-control" placeholder="name@example.com" />
            </div>
            <div class="mb-3">
                <label class="form-label">Password</label>
                <input type="password" class="form-control" placeholder="Password" />
            </div>
            <div class="mb-3">
                <label class="form-label">Select</label>
                <select class="form-select">
                    <option selected>Choose an option</option>
                    <option>Option 1</option>
                    <option>Option 2</option>
                    <option>Option 3</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Textarea</label>
                <textarea class="form-control" rows="3" placeholder="Enter text..."></textarea>
            </div>
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="check1" checked />
                <label class="form-check-label" for="check1">Checked checkbox</label>
            </div>
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="check2" />
                <label class="form-check-label" for="check2">Unchecked checkbox</label>
            </div>
            <div class="form-check mb-2">
                <input class="form-check-input" type="radio" name="radios" id="radio1" checked />
                <label class="form-check-label" for="radio1">Radio option 1</label>
            </div>
            <div class="form-check mb-3">
                <input class="form-check-input" type="radio" name="radios" id="radio2" />
                <label class="form-check-label" for="radio2">Radio option 2</label>
            </div>
            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" id="switch1" checked />
                <label class="form-check-label" for="switch1">Toggle switch</label>
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label">Valid input</label>
                <input type="text" class="form-control is-valid" value="Correct" />
                <div class="valid-feedback">Looks good!</div>
            </div>
            <div class="mb-3">
                <label class="form-label">Invalid input</label>
                <input type="text" class="form-control is-invalid" value="Wrong" />
                <div class="invalid-feedback">Please fix this field.</div>
            </div>
            <div class="mb-3">
                <label class="form-label">Disabled input</label>
                <input type="text" class="form-control" disabled placeholder="Disabled" />
            </div>
            <div class="mb-3">
                <label class="form-label">Range</label>
                <input type="range" class="form-range" />
            </div>
            <div class="input-group mb-3">
                <span class="input-group-text">@@</span>
                <input type="text" class="form-control" placeholder="Username" />
            </div>
            <div class="input-group mb-3">
                <input type="text" class="form-control" placeholder="Search..." />
                <button class="btn btn-primary" type="button">Search</button>
            </div>
        </div>
    </div>
</section>

<!-- List Group -->
<section class="mb-5">
    <h2 class="mb-3">List Groups</h2>
    <div class="row">
        <div class="col-md-6">
            <ul class="list-group">
                <li class="list-group-item active">Active item</li>
                <li class="list-group-item">Standard item</li>
                <li class="list-group-item list-group-item-primary">Primary item</li>
                <li class="list-group-item list-group-item-success">Success item</li>
                <li class="list-group-item list-group-item-danger">Danger item</li>
                <li class="list-group-item list-group-item-warning">Warning item</li>
                <li class="list-group-item list-group-item-info">Info item</li>
                <li class="list-group-item disabled">Disabled item</li>
            </ul>
        </div>
    </div>
</section>

<!-- Progress Bars -->
<section class="mb-5">
    <h2 class="mb-3">Progress Bars</h2>
    <div class="progress mb-2"><div class="progress-bar bg-primary" style="width: 25%">25%</div></div>
    <div class="progress mb-2"><div class="progress-bar bg-success" style="width: 50%">50%</div></div>
    <div class="progress mb-2"><div class="progress-bar bg-warning" style="width: 75%">75%</div></div>
    <div class="progress mb-2"><div class="progress-bar bg-danger" style="width: 100%">100%</div></div>
    <div class="progress mb-2"><div class="progress-bar progress-bar-striped progress-bar-animated bg-info" style="width: 60%">Animated</div></div>
</section>

<!-- Spinners -->
<section class="mb-5">
    <h2 class="mb-3">Spinners</h2>
    <div class="d-flex flex-wrap gap-3">
        <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>
        <div class="spinner-border text-secondary" role="status"></div>
        <div class="spinner-border text-success" role="status"></div>
        <div class="spinner-border text-danger" role="status"></div>
        <div class="spinner-border text-warning" role="status"></div>
        <div class="spinner-border text-info" role="status"></div>
        <div class="spinner-grow text-primary" role="status"></div>
        <div class="spinner-grow text-success" role="status"></div>
        <div class="spinner-grow text-danger" role="status"></div>
    </div>
</section>

<!-- Pagination & Breadcrumbs -->
<section class="mb-5">
    <h2 class="mb-3">Pagination &amp; Breadcrumbs</h2>
    <nav>
        <ul class="pagination">
            <li class="page-item disabled"><a class="page-link" href="#">Previous</a></li>
            <li class="page-item active"><a class="page-link" href="#">1</a></li>
            <li class="page-item"><a class="page-link" href="#">2</a></li>
            <li class="page-item"><a class="page-link" href="#">3</a></li>
            <li class="page-item"><a class="page-link" href="#">Next</a></li>
        </ul>
    </nav>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="#">Home</a></li>
            <li class="breadcrumb-item"><a href="#">Game</a></li>
            <li class="breadcrumb-item active">Board</li>
        </ol>
    </nav>
</section>

<!-- Accordion -->
<section class="mb-5">
    <h2 class="mb-3">Accordion</h2>
    <div class="accordion" id="demoAccordion">
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne">Accordion Item #1</button>
            </h2>
            <div id="collapseOne" class="accordion-collapse collapse show" data-bs-parent="#demoAccordion">
                <div class="accordion-body">This is the body of the first accordion item. It is shown by default.</div>
            </div>
        </div>
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo">Accordion Item #2</button>
            </h2>
            <div id="collapseTwo" class="accordion-collapse collapse" data-bs-parent="#demoAccordion">
                <div class="accordion-body">This is the body of the second accordion item. It is hidden by default.</div>
            </div>
        </div>
    </div>
</section>

<!-- Tooltips & Popovers -->
<section class="mb-5">
    <h2 class="mb-3">Tooltips &amp; Popovers</h2>
    <div class="d-flex flex-wrap gap-2">
        <button class="btn btn-primary" data-bs-toggle="tooltip" data-bs-placement="top" title="Tooltip on top">Tooltip Top</button>
        <button class="btn btn-secondary" data-bs-toggle="tooltip" data-bs-placement="bottom" title="Tooltip on bottom">Tooltip Bottom</button>
        <button class="btn btn-success" data-bs-toggle="popover" data-bs-title="Popover Title" data-bs-content="This is some popover content.">Popover</button>
    </div>
</section>

<!-- Modal trigger -->
<section class="mb-5">
    <h2 class="mb-3">Modal</h2>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#demoModal">Open Modal</button>
    <div class="modal fade" id="demoModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Demo Modal</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>This is a modal dialog styled with the dark theme.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button class="btn btn-primary">Save changes</button>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Background colours -->
<section class="mb-5">
    <h2 class="mb-3">Background Colours</h2>
    <div class="row g-2">
        <div class="col-md-3"><div class="p-3 rounded bg-primary text-white">bg-primary</div></div>
        <div class="col-md-3"><div class="p-3 rounded bg-secondary text-white">bg-secondary</div></div>
        <div class="col-md-3"><div class="p-3 rounded bg-success text-white">bg-success</div></div>
        <div class="col-md-3"><div class="p-3 rounded bg-danger text-white">bg-danger</div></div>
        <div class="col-md-3"><div class="p-3 rounded bg-warning text-dark">bg-warning</div></div>
        <div class="col-md-3"><div class="p-3 rounded bg-info text-dark">bg-info</div></div>
        <div class="col-md-3"><div class="p-3 rounded bg-light text-dark">bg-light</div></div>
        <div class="col-md-3"><div class="p-3 rounded bg-dark text-white">bg-dark</div></div>
        <div class="col-md-3"><div class="p-3 rounded bg-body-secondary">bg-body-secondary</div></div>
        <div class="col-md-3"><div class="p-3 rounded bg-body-tertiary">bg-body-tertiary</div></div>
    </div>
</section>

<!-- Text colours -->
<section class="mb-5">
    <h2 class="mb-3">Text Colours</h2>
    <p class="text-primary">text-primary</p>
    <p class="text-secondary">text-secondary</p>
    <p class="text-success">text-success</p>
    <p class="text-danger">text-danger</p>
    <p class="text-warning">text-warning</p>
    <p class="text-info">text-info</p>
    <p class="text-body">text-body</p>
    <p class="text-body-secondary">text-body-secondary</p>
    <p class="text-body-tertiary">text-body-tertiary</p>
    <p class="text-body-emphasis">text-body-emphasis</p>
    <p class="text-muted">text-muted</p>
</section>

@section Scripts {
<script>
    // Initialize tooltips and popovers
    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => new bootstrap.Tooltip(el));
    document.querySelectorAll('[data-bs-toggle="popover"]').forEach(el => new bootstrap.Popover(el));
</script>
}
