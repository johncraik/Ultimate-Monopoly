@page
@using UltimateMonopoly.Models.ViewModels.Leaderboard
@using UltimateMonopoly.Services.Statistics
@using UltimateMonopoly.TagHelpers
@model UltimateMonopoly.Pages.Leaderboard.IndexModel
@{
    ViewData["Title"] = "Leaderboard";

    var records = Model.Records;

    int Pct(LeaderboardRecord r) => (int)Math.Round(LeaderboardService.PlayerWinRate(r.UserProfile) * 100, MidpointRounding.AwayFromZero);
    string Rate(LeaderboardRecord r) => r.UserProfile.NumberOfGamesPlayed == 0 ? "—" : $"{Pct(r)}%";
    bool IsSelf(LeaderboardRecord r) =>
        !string.IsNullOrEmpty(Model.CurrentUserId) && r.UserProfile.UserId == Model.CurrentUserId;
}

<style>
    /* Medal row tints — translucent over the (dark) table so the medal hue shows while the
       theme's normal light text stays readable. Set the Bootstrap table-bg var so striping/
       hover still behave. */
    .lb-gold   { --bs-table-bg:rgba(255,200,0,.16); }
    .lb-silver { --bs-table-bg:rgba(190,195,205,.16); }
    .lb-bronze { --bs-table-bg:rgba(205,127,50,.18); }
    .lb-self   { --bs-table-bg:var(--bs-primary-bg-subtle); }

    /* Row heights: #1 tall, #2/#3 medium, the rest Bootstrap's normal. */
    .lb-row-big td { padding-top:1.6rem; padding-bottom:1.6rem; }
    .lb-row-mid td { padding-top:1rem;   padding-bottom:1rem; }

    /* A coloured accent down the left edge of the medal rows. */
    .lb-gold   td:first-child { box-shadow: inset .35rem 0 0 #e6b800; }
    .lb-silver td:first-child { box-shadow: inset .35rem 0 0 #a9adb1; }
    .lb-bronze td:first-child { box-shadow: inset .35rem 0 0 #c17b3e; }

    .lb-rank { font-variant-numeric:tabular-nums; }
    .leaderboard-table td, .leaderboard-table th { vertical-align:middle; }
    .lb-stat { font-variant-numeric:tabular-nums; }

    /* "How is the score calculated?" disclosure — strip the default marker, keep it tidy. */
    .lb-score-help > summary { cursor:pointer; list-style:none; display:inline-flex; align-items:center; }
    .lb-score-help > summary::-webkit-details-marker { display:none; }
</style>

<div class="py-4">

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-@(Model.StatusKind ?? "info") alert-dismissible fade show" role="alert">
        @Model.StatusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!Model.ShowLeaderboard)
{
    @* ── Locked state — must complete the minimum games first ───────────── *@
    <div class="row justify-content-center">
        <div class="col-12 col-lg-7">
            <div class="card border-0 shadow text-center">
                <div class="card-body p-5">
                    <div class="display-1 text-warning mb-3"><i class="bi bi-lock-fill"></i></div>
                    <h1 class="h3 fw-bold mb-2">The leaderboard is locked</h1>
                    <p class="lead text-body-secondary mb-1">
                        Earn your place first — play and complete at least
                        <strong class="text-body">@IndexModel.MinimumGames games</strong>
                        before the leaderboard unlocks.
                    </p>
                    <p class="text-body-secondary mb-4">
                        Once you've finished @IndexModel.MinimumGames games you'll join the
                        rankings and can see how you stack up against everyone else.
                    </p>
                    <div class="d-flex flex-column flex-sm-row justify-content-center gap-2">
                        <a asp-area="" asp-page="/Games/Index" class="btn btn-primary btn-lg">
                            <i class="bi bi-dice-5-fill me-2"></i>Start a game
                        </a>
                        <a asp-area="" asp-page="/Games/Join" class="btn btn-outline-secondary btn-lg">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Join a game
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow">
        @* ── Header ─────────────────────────────────────────────── *@
        <div class="card-header bg-transparent border-0 pt-4 px-4">
            <h1 class="h2 fw-bold mb-1">
                <i class="bi bi-trophy-fill text-warning me-2"></i>Leaderboard
            </h1>
            <p class="text-body-secondary mb-3">
                Every player ranked by overall score. Win/draw/loss records, games played and win
                rate are public.
            </p>

            <details class="lb-score-help">
                <summary class="text-body-secondary small fw-semibold">
                    <i class="bi bi-info-circle me-1"></i>How is the score calculated?
                </summary>
                <div class="mt-2 p-3 rounded border bg-body-tertiary small">
                    <p class="mb-2">
                        Your score rewards <strong>winning often</strong> and
                        <strong>winning consistently</strong>:
                    </p>
                    <ul class="mb-2">
                        <li>Everyone starts at <strong>1000</strong> points.</li>
                        <li>
                            <span class="text-success fw-semibold">Win +30</span>,
                            <span class="text-secondary fw-semibold">draw +10</span>,
                            <span class="text-danger fw-semibold">loss −15</span>.
                        </li>
                        <li>A <strong>win-rate bonus</strong> of up to <strong>+200</strong> rewards a high win percentage.</li>
                        <li>
                            New players get a small <strong>−20 per game</strong> until they've played
                            <strong>10 games</strong>, so the top spots are earned over time.
                        </li>
                    </ul>
                    <p class="mb-0 text-body-secondary">
                        Ties are broken by most wins, then win rate, then fewest losses.
                    </p>
                </div>
            </details>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 leaderboard-table">
                    <thead>
                        <tr class="text-body-secondary small text-uppercase">
                            <th class="ps-4" style="width:5.5rem;">Rank</th>
                            <th>Player</th>
                            <th class="text-center"><i class="bi bi-award-fill text-primary"></i> Score</th>
                            <th class="text-center"><i class="bi bi-trophy-fill text-success"></i> Wins</th>
                            <th class="text-center"><i class="bi bi-x-circle-fill text-danger"></i> Losses</th>
                            <th class="text-center"><i class="bi bi-dash-circle-fill text-secondary"></i> Draws</th>
                            <th class="text-center"><i class="bi bi-controller text-info"></i> Games</th>
                            <th style="min-width:9rem;"><i class="bi bi-graph-up-arrow text-primary"></i> Win rate</th>
                            <th class="text-end pe-4">Compare</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < records.Count; i++)
                        {
                            var r = records[i];
                            var up = r.UserProfile;
                            var rank = i + 1;
                            var self = IsSelf(r);

                            // Row styling by rank: gold/big, silver/mid, bronze/mid, else normal.
                            var rowClass = rank switch
                            {
                                1 => "lb-gold lb-row-big",
                                2 => "lb-silver lb-row-mid",
                                3 => "lb-bronze lb-row-mid",
                                _ => self ? "lb-self" : ""
                            };
                            var avatarSize = rank == 1 ? ProfileCircleSize.Lg : ProfileCircleSize.Md;
                            var nameClass = rank == 1 ? "fs-4 fw-bold" : rank <= 3 ? "fw-bold" : "fw-semibold";

                            <tr class="@rowClass">
                                @* Rank — medal icon for the top three, plain number otherwise. *@
                                <td class="ps-4 lb-rank">
                                    @if (rank == 1)
                                    {
                                        <span class="fs-3"><i class="bi bi-trophy-fill" style="color:#e6b800;"></i></span>
                                        <span class="fs-4 fw-bold ms-1">1</span>
                                    }
                                    else if (rank == 2)
                                    {
                                        <i class="bi bi-award-fill fs-4" style="color:#a9adb1;"></i>
                                        <span class="fw-bold ms-1">2</span>
                                    }
                                    else if (rank == 3)
                                    {
                                        <i class="bi bi-award-fill fs-4" style="color:#c17b3e;"></i>
                                        <span class="fw-bold ms-1">3</span>
                                    }
                                    else
                                    {
                                        <span class="fw-semibold text-body-secondary">@rank</span>
                                    }
                                </td>

                                @* Player — avatar + name + badges. *@
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <profile-circle user="up" size="@avatarSize" />
                                        <div class="min-w-0">
                                            <div class="@nameClass text-truncate">
                                                @up.DisplayName
                                                @if (self)
                                                {
                                                    <span class="badge text-bg-primary ms-1">You</span>
                                                }
                                                @if (r.AreFriends && !self)
                                                {
                                                    <span class="badge text-bg-info ms-1"><i class="bi bi-person-fill"></i> Friend</span>
                                                }
                                            </div>
                                            <div class="small text-body-secondary text-truncate">@("@")@up.Username</div>
                                        </div>
                                    </div>
                                </td>

                                <td class="text-center fw-bold text-primary lb-stat">@((int)(Math.Round(LeaderboardService.PlayerScore(up), MidpointRounding.AwayFromZero)))</td>
                                <td class="text-center fw-bold text-success lb-stat">@up.NumberOfWins</td>
                                <td class="text-center fw-bold text-danger lb-stat">@up.NumberOfLosses</td>
                                <td class="text-center fw-bold text-secondary lb-stat">@up.NumberOfDraws</td>
                                <td class="text-center fw-semibold text-info lb-stat">@up.NumberOfGamesPlayed</td>

                                @* Win rate — bar + percentage. *@
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress flex-grow-1" style="height:.5rem; min-width:3.5rem;">
                                            <div class="progress-bar bg-success" role="progressbar" style="width:@Pct(r)%;"></div>
                                        </div>
                                        <span class="fw-bold lb-stat" style="min-width:2.75rem;">@Rate(r)</span>
                                    </div>
                                </td>

                                @* Actions — friends get Compare; your own row gets the privacy toggle (E2). *@
                                <td class="text-end pe-4">
                                    @if (self)
                                    {
                                        <form method="post" asp-page-handler="ToggleVisibility" class="d-inline m-0">
                                            @if (Model.IsHidden)
                                            {
                                                <button type="submit" class="btn btn-sm btn-outline-secondary text-nowrap"
                                                        title="Show your name on the leaderboard to everyone.">
                                                    <i class="bi bi-eye me-1"></i>Make Profile Public
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn btn-sm btn-outline-secondary text-nowrap"
                                                        title="Hide your name on the leaderboard from players who aren't your friends.">
                                                    <i class="bi bi-eye-slash me-1"></i>Make Profile Private
                                                </button>
                                            }
                                        </form>
                                    }
                                    else if (r.AreFriends)
                                    {
                                        <a asp-area="" asp-page="/Leaderboard/Compare" asp-route-userId="@up.UserId"
                                           class="btn btn-sm btn-outline-primary text-nowrap" title="Compare stats with @up.DisplayName">
                                            <i class="bi bi-bar-chart-line-fill me-1"></i>Compare
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
</div>