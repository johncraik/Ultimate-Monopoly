@page "{code?}"
@model UltimateMonopoly.Pages.ErrorModel
@{
    ViewData["Title"] = $"{Model.StatusCode} — {Model.Title}";
}

<div class="py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card shadow-sm border-0 text-center">
                <div class="card-body p-4 p-md-5">
                    <div class="display-1 fw-bold text-secondary lh-1 mb-2">@Model.StatusCode</div>
                    <i class="bi @Model.Icon display-5 text-secondary d-block mb-3"></i>
                    <h1 class="h3 mb-2">@Model.Title</h1>
                    <p class="text-body-secondary mb-4">@Model.Message</p>
                    <div class="d-flex gap-2 justify-content-center flex-wrap">
                        <a href="/" class="btn btn-hero-primary">Go home</a>
                        <button type="button" class="btn btn-hero-secondary" onclick="history.back()">Go back</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>