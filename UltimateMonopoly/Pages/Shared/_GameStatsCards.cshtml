@model UltimateMonopoly.Models.ViewModels.Social.UserProfileViewModel
@{
    var played = Model.NumberOfGamesPlayed;
    var winRate = played > 0
        ? $"{Model.NumberOfWins * 100.0 / played:0.#}%"
        : "-";

    var cards = new[]
    {
        new { Label = "Wins",         Value = Model.NumberOfWins.ToString(),     Icon = "bi-trophy-fill",       Tone = "success" },
        new { Label = "Losses",       Value = Model.NumberOfLosses.ToString(),   Icon = "bi-x-circle-fill",     Tone = "danger"  },
        new { Label = "Draws",        Value = Model.NumberOfDraws.ToString(),    Icon = "bi-dash-circle-fill",  Tone = "warning" },
        new { Label = "Games Played", Value = played.ToString(),                 Icon = "bi-dice-5-fill",       Tone = "primary" },
        new { Label = "Win Rate",     Value = winRate,                           Icon = "bi-graph-up-arrow",    Tone = "info"    }
    };
}

<div class="row row-cols-2 row-cols-md-3 row-cols-xl-5 g-3">
    @foreach (var card in cards)
    {
        <div class="col">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 bg-@(card.Tone)-subtle text-@(card.Tone)-emphasis"
                         style="width: 3rem; height: 3rem;">
                        <i class="bi @card.Icon fs-4"></i>
                    </div>
                    <div class="min-w-0">
                        <div class="text-body-secondary small text-uppercase">@card.Label</div>
                        <div class="fs-3 fw-semibold lh-1">@card.Value</div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
