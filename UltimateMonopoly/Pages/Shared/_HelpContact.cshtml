@inject IConfiguration Config
@*
    Shared "need help?" strip for the status pages (Error / Access Denied / Disabled). Surfaces the
    support email (always — a mailto works for anyone, signed in or not) and, for signed-in users, a
    button through to the Guides → Contact tab. Mirrors the footer's email pattern (_Layout.cshtml):
    Communication:Email:ContactRecipient, falling back to support@monappoly.com.
*@
@{
    var email = Config["Communication:Email:ContactRecipient"] ?? "support@monappoly.com";
}
<hr class="my-4" />
<p class="small text-body-secondary mb-2">Need help, or think this is a mistake?</p>
<div class="d-flex gap-2 justify-content-center flex-wrap">
    <a href="mailto:@email" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-envelope me-1"></i>@email
    </a>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-area="" asp-page="/Guides/Index" asp-route-tab="contact" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-chat-left-text me-1"></i>Contact us
        </a>
    }
</div>
