@using JC.Communication.Notifications.Helpers
@using JC.Communication.Notifications.Services
@using JC.Core.Extensions
@using JC.Identity.Authentication
@using Microsoft.AspNetCore.Identity
@using UltimateMonopoly.Data
@using UltimateMonopoly.Services
@using Microsoft.Extensions.Hosting
@inject SignInManager<AppUser> SignInManager
@inject NotificationCache NotificationCache
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env

<nav class="navbar navbar-expand-lg navbar-glass mb-4">
    <div class="app-page">
        <partial name="_Branding"/>

        <button class="navbar-toggler nav-toggler-morph collapsed" type="button"
                data-bs-toggle="collapse" data-bs-target="#mainNav"
                aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="burger" aria-hidden="true"><span></span><span></span><span></span></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
            @if (SignInManager.IsSignedIn(User))
            {
                <ul class="navbar-nav mx-lg-auto mb-2 mb-lg-0 gap-lg-1">

                    @* ───────────── Games ───────────── *@
                    <li class="nav-item nav-mega" data-mega>
                        <button class="btn btn-nav nav-mega-toggle" type="button" data-mega-toggle aria-expanded="false">
                            Games <i class="bi bi-chevron-down nav-mega-caret"></i>
                        </button>
                        <div class="nav-mega-card">
                            <button class="nav-mega-close" type="button" data-mega-close aria-label="Close menu"><i class="bi bi-x-lg"></i></button>
                            <div class="nav-mega-grid mega-3 mega-games">
                                <a class="nav-mega-item" asp-area="" asp-page="/Games/Index">
                                    <span class="nav-mega-ico"><i class="bi bi-plus-circle"></i></span>
                                    <span class="nav-mega-text"><span class="nav-mega-title">New Game</span><span class="nav-mega-desc">Create a game to host</span></span>
                                </a>
                                <a class="nav-mega-item" asp-area="" asp-page="/Games/Join">
                                    <span class="nav-mega-ico"><i class="bi bi-box-arrow-in-right"></i></span>
                                    <span class="nav-mega-text"><span class="nav-mega-title">Join Game</span><span class="nav-mega-desc">Enter a join code</span></span>
                                </a>
                                <a class="nav-mega-item" asp-area="" asp-page="/Guides/Index">
                                    <span class="nav-mega-ico"><i class="bi bi-mortarboard"></i></span>
                                    <span class="nav-mega-text"><span class="nav-mega-title">How To Play</span><span class="nav-mega-desc">New here? Start here</span></span>
                                </a>
                                <a class="nav-mega-item" asp-area="" asp-page="/Games/MyGames">
                                    <span class="nav-mega-ico"><i class="bi bi-controller"></i></span>
                                    <span class="nav-mega-text"><span class="nav-mega-title">My Games</span><span class="nav-mega-desc">Games you're hosting</span></span>
                                </a>
                                <a class="nav-mega-item" asp-area="" asp-page="/Games/Joined">
                                    <span class="nav-mega-ico"><i class="bi bi-people"></i></span>
                                    <span class="nav-mega-text"><span class="nav-mega-title">Joined Games</span><span class="nav-mega-desc">Games you've joined</span></span>
                                </a>
                                <a class="nav-mega-item" asp-area="" asp-page="/Rules">
                                    <span class="nav-mega-ico"><i class="bi bi-journal-text"></i></span>
                                    <span class="nav-mega-text"><span class="nav-mega-title">Rules</span><span class="nav-mega-desc">The full rulebook</span></span>
                                </a>
                            </div>
                        </div>
                    </li>

                    @* ───────────── Social ───────────── *@
                    <li class="nav-item nav-mega" data-mega>
                        <button class="btn btn-nav nav-mega-toggle" type="button" data-mega-toggle aria-expanded="false">
                            Social <i class="bi bi-chevron-down nav-mega-caret"></i>
                        </button>
                        <div class="nav-mega-card">
                            <button class="nav-mega-close" type="button" data-mega-close aria-label="Close menu"><i class="bi bi-x-lg"></i></button>
                            <div class="nav-mega-grid mega-3 mega-social">
                                <a class="nav-mega-item" asp-area="Social" asp-page="/Friends/Index" asp-route-tab="friends">
                                    <span class="nav-mega-ico"><i class="bi bi-people"></i></span>
                                    <span class="nav-mega-text"><span class="nav-mega-title">My Friends</span><span class="nav-mega-desc">Your friends list</span></span>
                                </a>
                                <a class="nav-mega-item" asp-area="Social" asp-page="/Messages/Index">
                                    <span class="nav-mega-ico"><i class="bi bi-chat-left-text"></i></span>
                                    <span class="nav-mega-text"><span class="nav-mega-title">My Messages</span><span class="nav-mega-desc">Direct messages</span></span>
                                </a>
                                <a class="nav-mega-item" asp-area="Identity" asp-page="/Profile/Index">
                                    <span class="nav-mega-ico"><i class="bi bi-person"></i></span>
                                    <span class="nav-mega-text"><span class="nav-mega-title">My Profile</span><span class="nav-mega-desc">Avatar, stats, privacy</span></span>
                                </a>
                                <a class="nav-mega-item" asp-area="Social" asp-page="/Friends/Index" asp-route-tab="add">
                                    <span class="nav-mega-ico"><i class="bi bi-person-plus"></i></span>
                                    <span class="nav-mega-text"><span class="nav-mega-title">Add Friend</span><span class="nav-mega-desc">Find someone by name</span></span>
                                </a>
                                <a class="nav-mega-item" asp-area="Social" asp-page="/Friends/Index" asp-route-tab="requests">
                                    <span class="nav-mega-ico"><i class="bi bi-person-lines-fill"></i></span>
                                    <span class="nav-mega-text"><span class="nav-mega-title">Friend Requests</span><span class="nav-mega-desc">Pending invitations</span></span>
                                </a>
                                <a class="nav-mega-item" asp-area="Identity" asp-page="/Profile/Index" asp-route-tab="blocked">
                                    <span class="nav-mega-ico"><i class="bi bi-slash-circle"></i></span>
                                    <span class="nav-mega-text"><span class="nav-mega-title">Blocked Users</span><span class="nav-mega-desc">Manage who's blocked</span></span>
                                </a>
                            </div>
                        </div>
                    </li>

                    @* ───────────── Boards ───────────── *@
                    <li class="nav-item nav-mega" data-mega>
                        <button class="btn btn-nav nav-mega-toggle" type="button" data-mega-toggle aria-expanded="false">
                            Boards <i class="bi bi-chevron-down nav-mega-caret"></i>
                        </button>
                        <div class="nav-mega-card">
                            <button class="nav-mega-close" type="button" data-mega-close aria-label="Close menu"><i class="bi bi-x-lg"></i></button>
                            <div class="nav-mega-grid mega-2">
                                <a class="nav-mega-item" asp-area="" asp-page="/Boards/Edit">
                                    <span class="nav-mega-ico"><i class="bi bi-plus-square"></i></span>
                                    <span class="nav-mega-text"><span class="nav-mega-title">New Board</span><span class="nav-mega-desc">Design a custom board</span></span>
                                </a>
                                <a class="nav-mega-item" asp-area="" asp-page="/Boards/Index">
                                    <span class="nav-mega-ico"><i class="bi bi-grid-3x3"></i></span>
                                    <span class="nav-mega-text"><span class="nav-mega-title">My Boards</span><span class="nav-mega-desc">Your saved boards</span></span>
                                </a>
                            </div>
                        </div>
                    </li>

                    @* ───────────── Leaderboard (plain link) ───────────── *@
                    <li class="nav-item">
                        <a class="btn btn-nav" asp-area="" asp-page="/Leaderboard/Index">Leaderboard</a>
                    </li>

                    @* ───────────── Help ───────────── *@
                    <li class="nav-item nav-mega" data-mega>
                        <button class="btn btn-nav nav-mega-toggle" type="button" data-mega-toggle aria-expanded="false">
                            Help <i class="bi bi-chevron-down nav-mega-caret"></i>
                        </button>
                        <div class="nav-mega-card">
                            <button class="nav-mega-close" type="button" data-mega-close aria-label="Close menu"><i class="bi bi-x-lg"></i></button>
                            <div class="nav-mega-grid mega-2">
                                <a class="nav-mega-item" asp-area="" asp-page="/Guides/Index">
                                    <span class="nav-mega-ico"><i class="bi bi-mortarboard"></i></span>
                                    <span class="nav-mega-text"><span class="nav-mega-title">How To Play</span><span class="nav-mega-desc">A walkthrough for new players</span></span>
                                </a>
                                <a class="nav-mega-item" asp-area="" asp-page="/Rules">
                                    <span class="nav-mega-ico"><i class="bi bi-journal-text"></i></span>
                                    <span class="nav-mega-text"><span class="nav-mega-title">Rules</span><span class="nav-mega-desc">The full rulebook</span></span>
                                </a>
                            </div>
                        </div>
                    </li>
                </ul>

                <div class="d-flex align-items-center gap-2 ms-auto justify-content-end">
                    <partial name="_NotificationBell" />
                    <partial name="~/Pages/Shared/_ProfileDropdown.cshtml" />
                </div>
            }
            else
            {
                @* Signed out — public How To Play and Rules links, plus the auth actions. *@
                <ul class="navbar-nav mx-lg-auto mb-2 mb-lg-0 gap-lg-1">
                    <li class="nav-item"><a class="btn btn-nav" asp-area="" asp-page="/Guides/Index">How To Play</a></li>
                    <li class="nav-item"><a class="btn btn-nav" asp-area="" asp-page="/Rules">Rules</a></li>
                </ul>

                <div class="d-flex flex-column flex-lg-row gap-2">
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-nav-info">Login</a>
                    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-hero-primary">Register</a>
                </div>
            }
        </div>
    </div>
</nav>
