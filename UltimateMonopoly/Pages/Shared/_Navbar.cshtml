@using Microsoft.AspNetCore.Identity
@using UltimateMonopoly.Data
@inject SignInManager<AppUser> SignInManager

<nav class="navbar navbar-expand-lg navbar-glass mb-4">
    <div class="container-lg">
        <a class="navbar-brand" asp-area="" asp-page="/Index">
            <span class="text-primary">Ultimate</span> Monopoly
        </a>

        <button class="navbar-toggler nav-toggler-morph collapsed" type="button"
                data-bs-toggle="collapse" data-bs-target="#mainNav"
                aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="burger" aria-hidden="true"><span></span><span></span><span></span></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
            @* TODO: replace href="#" once these pages exist *@
            <ul class="navbar-nav mx-lg-auto mb-2 mb-lg-0 gap-lg-1">
                <li class="nav-item"><a class="btn btn-nav" href="#">New Game</a></li>
                <li class="nav-item"><a class="btn btn-nav" href="#">Load Game</a></li>
                <li class="nav-item"><a class="btn btn-nav" asp-area="Social" asp-page="/Friends/Index">Friends</a></li>
                <li class="nav-item"><a class="btn btn-nav" href="#">My Boards</a></li>
            </ul>

            @if (SignInManager.IsSignedIn(User))
            {
                <div class="dropdown">
                    <button class="btn btn-nav-info dropdown-toggle" type="button"
                            data-bs-toggle="dropdown" aria-expanded="false">
                        My Account
                    </button>
                    <ul class="dropdown-menu dropdown-menu-lg-end">
                        <li><a class="dropdown-item" href="/account">Settings</a></li>
                        <li><hr class="dropdown-divider" /></li>
                        <li>
                            <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="m-0">
                                <button type="submit" class="dropdown-item dropdown-item-danger">Logout</button>
                            </form>
                        </li>
                    </ul>
                </div>
            }
            else
            {
                <div class="d-flex flex-column flex-lg-row gap-2">
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-nav-info">Login</a>
                    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-hero-primary">Register</a>
                </div>
            }
        </div>
    </div>
</nav>

@* Measures the navbar's actual rendered height and exposes it as a CSS var
   so .sticky-tabs (and any other below-the-bar pinning) can sit flush. *@
<script>
    (() => {
        const root = document.documentElement;
        const nav  = document.querySelector('.navbar-glass');
        if (!nav) return;
        const update = () => root.style.setProperty('--app-navbar-height', nav.offsetHeight + 'px');
        update();
        window.addEventListener('resize', update);
        document.fonts?.ready?.then(update);
        new ResizeObserver(update).observe(nav);
    })();
</script>
