@using JC.Communication.Notifications.Helpers
@using JC.Communication.Notifications.Services
@using JC.Core.Extensions
@using Microsoft.AspNetCore.Identity
@using UltimateMonopoly.Areas.Identity.Services
@using UltimateMonopoly.Data
@inject SignInManager<AppUser> SignInManager
@inject NotificationCache NotificationCache
@inject ProfileService ProfileService

<nav class="navbar navbar-expand-lg navbar-glass mb-4">
    <div class="container-lg">
        <a class="navbar-brand" asp-area="" asp-page="/Index">
            <span class="text-primary">Ultimate</span> Monopoly
        </a>

        <button class="navbar-toggler nav-toggler-morph collapsed" type="button"
                data-bs-toggle="collapse" data-bs-target="#mainNav"
                aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="burger" aria-hidden="true"><span></span><span></span><span></span></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
            @* TODO: replace href="#" once these pages exist *@
            <ul class="navbar-nav mx-lg-auto mb-2 mb-lg-0 gap-lg-1">
                <li class="nav-item"><a class="btn btn-nav" href="#">New Game</a></li>
                <li class="nav-item"><a class="btn btn-nav" href="#">Load Game</a></li>
                <li class="nav-item"><a class="btn btn-nav" asp-area="Social" asp-page="/Friends/Index">Friends</a></li>
                <li class="nav-item"><a class="btn btn-nav" href="#">My Boards</a></li>
            </ul>

            @if (SignInManager.IsSignedIn(User))
            {
                var notifications = (await NotificationCache.GetNotificationsAsync())
                    .Where(n => !n.IsRead)
                    .ToList();
                var unreadCount = notifications.Count;
                var badgeText = unreadCount > 99 ? "99+" : unreadCount.ToString();

                <div class="d-flex align-items-center gap-2">
                    <div class="dropdown" id="notification-dropdown">
                        <button class="btn p-0 border-0 rounded-circle bg-info text-white d-flex align-items-center justify-content-center position-relative" type="button"
                                data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false" aria-label="Notifications"
                                style="width: 2.5rem; height: 2.5rem;">
                            <i class="bi bi-bell fs-5"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger @(unreadCount == 0 ? "d-none" : "")"
                                  data-notification-badge>
                                @badgeText
                                <span class="visually-hidden">unread notifications</span>
                            </span>
                        </button>
                        <div class="dropdown-menu dropdown-menu-end p-0 shadow-lg" style="width: 22rem;">
                            <div class="px-3 py-2 border-bottom d-flex align-items-center justify-content-between">
                                <strong>Notifications</strong>
                                <span class="badge text-bg-secondary @(unreadCount == 0 ? "d-none" : "")" data-notification-count>@unreadCount</span>
                            </div>

                            <div class="overflow-auto" style="max-height: 25rem;" data-notification-list>
                                @if (unreadCount == 0)
                                {
                                    <div class="px-3 py-4 text-center text-body-secondary" data-notification-empty>
                                        <i class="bi bi-bell-slash fs-2 d-block mb-2"></i>
                                        You're all caught up!
                                    </div>
                                }
                                else
                                {
                                    foreach (var n in notifications)
                                    {
                                        var icon = n.Style?.CustomIconClass ?? NotificationUIHelper.GetIconClass(n.Type);
                                        var colour = n.Style?.CustomColourClass ?? NotificationUIHelper.GetColourClass(n.Type);
                                        var hasLink = !string.IsNullOrEmpty(n.UrlLink);

                                        <div class="d-flex align-items-start gap-2 px-3 py-2 border-bottom" data-notification-id="@n.Id">
                                            <i class="bi @icon text-@colour fs-5 flex-shrink-0 mt-1"></i>
                                            <div class="flex-grow-1 min-w-0">
                                                @if (hasLink)
                                                {
                                                    <a href="@n.UrlLink" class="text-decoration-none text-body d-block">
                                                        <div class="fw-semibold text-truncate">@n.Title</div>
                                                        <div class="small text-body-secondary">@n.Body</div>
                                                        <div class="small text-body-tertiary">@n.CreatedUtc.ToRelativeTime()</div>
                                                    </a>
                                                }
                                                else
                                                {
                                                    <div class="fw-semibold text-truncate">@n.Title</div>
                                                    <div class="small text-body-secondary">@n.Body</div>
                                                    <div class="small text-body-tertiary">@n.CreatedUtc.ToRelativeTime()</div>
                                                }
                                            </div>
                                            <button type="button" class="btn btn-sm btn-link p-0 text-body-secondary flex-shrink-0"
                                                    data-notification-dismiss="@n.Id" aria-label="Dismiss notification" title="Dismiss">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>

                    @{
                        var currentUser = await ProfileService.GetCurrentUserProfileViewModelAsync();
                    }
                    <div class="dropdown">
                        <button class="btn p-0 border-0 rounded-circle" type="button"
                                data-bs-toggle="dropdown" aria-expanded="false" aria-label="My Account">
                            <profile-circle user="currentUser" size="Md" />
                        </button>
                        <ul class="dropdown-menu dropdown-menu-lg-end">
                            <li><a class="dropdown-item" href="/profile">Profile</a></li>
                            <li><a class="dropdown-item" href="/account">Settings</a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="m-0">
                                    <button type="submit" class="dropdown-item dropdown-item-danger">Logout</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>

            }
            else
            {
                <div class="d-flex flex-column flex-lg-row gap-2">
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-nav-info">Login</a>
                    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-hero-primary">Register</a>
                </div>
            }
        </div>
    </div>
</nav>
