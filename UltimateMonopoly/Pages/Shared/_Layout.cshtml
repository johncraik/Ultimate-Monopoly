@using MP.GameEngine.Helpers.RuleSet
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@inject IConfiguration Config
@{
    // Canonical always points at the production domain (never localhost/staging). Pages override the path
    // via ViewData["Canonical"]; unset falls back to the site root.
    var webUrl = Config["Routes:WebUrl"] ?? "https://www.monappoly.com/";
    var canonicalUrl = ViewData["Canonical"] as string ?? webUrl;
    var publisherUrl = Config["Routes:PublisherUrl"] ?? "https://www.jcfoundry.co.uk";
    var metaDescription = ViewData["Description"] as string;
    var ogTitle = ViewData["Title"] is string pageTitle && !string.IsNullOrWhiteSpace(pageTitle)
        ? $"{pageTitle} - {RuleDictionary.GameName}"
        : RuleDictionary.GameName;
}

<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @RuleDictionary.GameName</title>
    <link rel="canonical" href="@canonicalUrl" />
    @* Public pages set ViewData["Description"] for the search snippet + share preview; omitted elsewhere. *@
    @if (!string.IsNullOrWhiteSpace(metaDescription))
    {
        <meta name="description" content="@metaDescription" />
    }
    @* Open Graph — link-share preview card (no og:image / Twitter card by design). *@
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="@RuleDictionary.GameName" />
    <meta property="og:title" content="@ogTitle" />
    <meta property="og:url" content="@canonicalUrl" />
    @if (!string.IsNullOrWhiteSpace(metaDescription))
    {
        <meta property="og:description" content="@metaDescription" />
    }
    @* Structured data — declares the site as a free web game app by JC Foundry for rich results.
       @@ is escaped to a literal @ (Razor); the schema.org keys must render as @context / @type. *@
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "WebApplication",
        "name": "@RuleDictionary.GameName",
        "url": "@webUrl",
        "applicationCategory": "GameApplication",
        "operatingSystem": "Web",
        "description": "A free companion app for a wilder, heavily-extended take on the Monopoly board game.",
        "offers": {
            "@@type": "Offer",
            "price": "0",
            "priceCurrency": "GBP"
        },
        "publisher": {
            "@@type": "Organization",
            "name": "JC Foundry",
            "url": "@publisherUrl"
        }
    }
    </script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdn.syncfusion.com/ej2/33.2.6/bootstrap5-dark.css" />
    @{
        var afTokens = Antiforgery.GetAndStoreTokens(Context);
    }
    <meta name="csrf-header" content="@afTokens.HeaderName" />
    <meta name="csrf-token" content="@afTokens.RequestToken" />
</head>
<body class="app-shell">
    <partial name="_Navbar" />

    <main class="app-page pb-5">
        @RenderBody()
    </main>

    <footer class="app-footer">
        <div class="app-page py-3">
            <div class="app-footer-grid small">
                @{
                    var email = Config["Communication:Email:ContactRecipient"] ?? "support@monappoly.com";
                }
                
                <div class="d-none d-lg-block"></div>
                <div class="text-center text-body-secondary">
                    &copy; @(DateTime.UtcNow.ToLocalTime().Date.Year) - <a href="@publisherUrl" class="app-footer-link">JC Foundry</a>
                </div>
                <div class="text-center text-lg-end mt-2 mt-lg-0">
                    <a href="mailto:@email" class="app-footer-link">
                        <i class="bi bi-envelope me-1"></i>@email
                    </a>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-area="" asp-page="/Guides/Index" asp-route-tab="contact" class="app-footer-link ms-3">
                            <i class="bi bi-chat-left-text me-1"></i>Contact
                        </a>
                    }
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/scripts/navbar.js" asp-append-version="true"></script>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <script src="~/scripts/SignalR/signalr.min.js" asp-append-version="true"></script>
        <script src="~/scripts/SignalR/presence.js" asp-append-version="true"></script>
        <script src="~/scripts/notifications.js" asp-append-version="true"></script>
    }
    <script src="https://cdn.syncfusion.com/ej2/33.2.6/dist/ej2.min.js"></script>

    <partial name="~/Pages/Shared/_BugReporter.cshtml" />
    <partial name="~/Pages/Shared/_FeedbackModal.cshtml" />

    @await RenderSectionAsync("Scripts", required: false)
    <ejs-scripts></ejs-scripts>
</body>
</html>
