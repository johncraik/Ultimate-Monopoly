@using System.Net
@using System.Text.Json
@using JC.Core.Extensions
@using MP.GameEngine.Enums
@using MP.GameEngine.Enums.Cards
@using MP.GameEngine.Enums.Properties
@using MP.GameEngine.Helpers
@using MP.GameEngine.Models.Boards
@using MP.GameEngine.Models.Statistics
@using Microsoft.AspNetCore.Html
@using UltimateMonopoly.Models.Statistics
@using UltimateMonopoly.Services.Cache
@model (PlayerStatRecord Stats, PlayerStatRecord? Comparison)
@inject BoardCacheService BoardCache
@{
    // Glorified statistics panel. Model = (Stats, Comparison): Stats is the aggregate the
    // page chose (avg / min / max / total view); Comparison is the "before" aggregate
    // (null when there's nothing to compare against). Under each value we surface the
    // movement vs Comparison — a coloured +/- for numbers (green/red by whether up is
    // good in that context, grey for no change), and a grey "was X" badge for
    // categoricals (enums / board indexes — no +/- makes sense there).
    //
    // Catalogue-driven: every section / tile is rendered from StatCatalogue (the same source
    // the comparison table uses), so the two views can never drift. Section layout (full-width
    // vs the 50/50 pairs, tile column count) rides StatSection.Half / LgCols.
    var s = Model.Stats;
    var cmp = Model.Comparison;
    var hasCmp = cmp is not null;

    // Default board — the projection values every game against it (StatisticsJob), so
    // board-index stats resolve their space names here too.
    var board = await BoardCache.GetDefaultBoard();

    // ── formatting ──
    string Money(long v) => v < 0 ? $"-£{Math.Abs(v):N0}" : $"£{v:N0}";
    string Num(long v) => v.ToString("N0");

    // ── numeric comparison: +/- coloured by context (higher == true → up is good;
    //    false → down is good; null → neutral/grey). Grey "no change" on a tie; null
    //    (no comparison row) when there's no comparison. ──
    (string Cls, string Icon, string Text)? Delta(long? cur, long? old, bool? higher, bool money)
    {
        if (!hasCmp || cur is null || old is null) return null;
        var diff = cur.Value - old.Value;
        if (diff == 0) return ("text-body-secondary", "bi-dash", "no change");

        var up = diff > 0;
        var cls = higher is null ? "text-body-secondary"
            : higher.Value == up ? "text-success" : "text-danger";
        var mag = Math.Abs(diff);
        return (cls, up ? "bi-arrow-up-short" : "bi-arrow-down-short", money ? Money(mag) : Num(mag));
    }

    // ── board-index → space name ──
    string? NameOf(ushort? index)
    {
        if (index is null) return null;
        try { return board.GetBoardSpace(index.Value).Name; }
        catch { return $"Space {index}"; }
    }

    // ── reusable tiles (all values here are app-controlled; board names are encoded) ──
    IHtmlContent Tile(string label, string icon, string tone, bool? higher, bool money, long? cur, long? old, string? sub = null)
    {
        var val = cur is null ? "—" : money ? Money(cur.Value) : Num(cur.Value);
        var d = Delta(cur, old, higher, money);
        var deltaHtml = d is null ? "" : $"<div class=\"stat-delta {d.Value.Cls}\"><i class=\"bi {d.Value.Icon}\"></i> {d.Value.Text}</div>";
        var subHtml = string.IsNullOrEmpty(sub) ? "" : $"<div class=\"stat-sub\">{WebUtility.HtmlEncode(sub)}</div>";
        return new HtmlString(
            $"<div class=\"stat-tile\"><div class=\"stat-tile-top\"><span class=\"stat-ico text-{tone} bg-{tone}-subtle\"><i class=\"bi {icon}\"></i></span>" +
            $"<span class=\"stat-label\">{label}</span></div><div class=\"stat-value\">{val}</div>{subHtml}{deltaHtml}</div>");
    }

    // Categorical tile (enum / board index / bool): the rendered current value, plus a grey
    // "was X" badge of the old value (or "no change") when there's a comparison.
    IHtmlContent CatTile(string label, string icon, string tone, string currentHtml, string? curKey, string? oldKey, string? oldText)
    {
        var cmpHtml = "";
        if (hasCmp && oldKey is not null)
            cmpHtml = string.Equals(curKey, oldKey)
                ? "<span class=\"stat-delta text-body-secondary\"><i class=\"bi bi-dash\"></i> no change</span>"
                : $"<span class=\"badge text-bg-secondary stat-was\">was {WebUtility.HtmlEncode(oldText ?? "")}</span>";
        return new HtmlString(
            $"<div class=\"stat-tile\"><div class=\"stat-tile-top\"><span class=\"stat-ico text-{tone} bg-{tone}-subtle\"><i class=\"bi {icon}\"></i></span>" +
            $"<span class=\"stat-label\">{label}</span></div><div class=\"mt-1\">{currentHtml}</div>{cmpHtml}</div>");
    }

    // Two related numbers in one tile, split down the middle ("you | someone", "taken | repaid"),
    // each with its own sub-label and (when comparing) its own delta.
    IHtmlContent SplitTile(string label, string icon, string tone, bool money,
        string leftLabel, long? lCur, long? lOld, bool? lHigher,
        string rightLabel, long? rCur, long? rOld, bool? rHigher)
    {
        string Half(string subLabel, long? cur, long? old, bool? higher)
        {
            var val = cur is null ? "—" : money ? Money(cur.Value) : Num(cur.Value);
            var d = Delta(cur, old, higher, money);
            var delta = d is null ? "" : $"<div class=\"stat-delta justify-content-center {d.Value.Cls}\"><i class=\"bi {d.Value.Icon}\"></i> {d.Value.Text}</div>";
            return $"<div class=\"flex-fill text-center\"><div class=\"stat-value\">{val}</div>{delta}<div class=\"stat-sub\">{WebUtility.HtmlEncode(subLabel)}</div></div>";
        }
        return new HtmlString(
            $"<div class=\"stat-tile\"><div class=\"stat-tile-top\"><span class=\"stat-ico text-{tone} bg-{tone}-subtle\"><i class=\"bi {icon}\"></i></span>" +
            $"<span class=\"stat-label\">{label}</span></div>" +
            $"<div class=\"d-flex align-items-start gap-2 mt-1 stat-split\">{Half(leftLabel, lCur, lOld, lHigher)}" +
            $"<div class=\"stat-split-divider\"></div>{Half(rightLabel, rCur, rOld, rHigher)}</div></div>");
    }

    // ── catalogue-driven rendering: one descriptor → the right tile, reusing the chrome above ──
    bool? Higher(StatSentiment sent) => sent switch
    {
        StatSentiment.HigherBetter => true,
        StatSentiment.LowerBetter => false,
        _ => (bool?)null
    };

    long? AsLong(StatPart part, PlayerStatRecord? rec)
        => rec is null ? null : part.Value(rec) is { } v ? Convert.ToInt64(v) : (long?)null;

    // A categorical part's comparison key (equality) and "was X" display text, by kind.
    (string? Key, string? Text) Cat(StatPart part, PlayerStatRecord? rec)
    {
        if (rec is null) return (null, null);
        var v = part.Value(rec);
        return part.Kind switch
        {
            StatKind.BoardIndex => (((ushort?)v)?.ToString(), NameOf((ushort?)v)),
            StatKind.PropertySet => ((v as PropertySet?)?.ToString(), (v as PropertySet?)?.ToDisplayName()),
            StatKind.FinancialReason => ((v as FinancialReason?)?.ToString(), (v as FinancialReason?)?.ToDisplayName()),
            StatKind.CardTrigger => ((v as CardTrigger?)?.ToString(), (v as CardTrigger?)?.ToDisplayName()),
            StatKind.CardEngagement => ((v as CardEngagement?)?.ToString(),
                (v as CardEngagement?) is { } e ? (e == CardEngagement.Forced ? "Forced" : e == CardEngagement.Choice ? "Choice" : "Instant") : null),
            StatKind.TriBool => (((bool?)v)?.ToString() ?? "null", (bool?)v is { } tb ? (tb ? "Yes" : "No") : "N/A"),
            StatKind.Bool => (((bool?)v)?.ToString(), (v as bool?) is { } b ? (b ? "Yes" : "No") : null),
            _ => (v?.ToString(), v?.ToString())
        };
    }

    IHtmlContent RenderDescriptor(StatDescriptor d)
    {
        var p = d.Primary;
        var money = p.Kind == StatKind.Money;

        // Two-number split (dice number, loans, per-type card boxes, immunity).
        if (d.Secondary is { } q)
            return SplitTile(d.Label, d.Icon, d.Tone, money,
                p.Label ?? "", AsLong(p, s), AsLong(p, cmp), Higher(p.Sentiment),
                q.Label ?? "", AsLong(q, s), AsLong(q, cmp), Higher(q.Sentiment));

        // Categorical kinds — the rendered fragment (StatRender produces HTML identical to the old
        // hand-coded helpers), in the categorical chrome with a "was X" note.
        if (p.Kind is not (StatKind.Money or StatKind.Number))
        {
            var curHtml = StatRender.Value(p, s, board).ToString() ?? "";
            var (curKey, _) = Cat(p, s);
            var (oldKey, oldText) = Cat(p, cmp);
            return CatTile(d.Label, d.Icon, d.Tone, curHtml, curKey, oldKey, oldText);
        }

        var cur = AsLong(p, s);

        // Money / number with inline detail badges (largest payment → reason + property; largest rent → property).
        if (d.Details is { } details)
        {
            var valStr = cur is null ? "—" : money ? Money(cur.Value) : Num(cur.Value);
            var dlt = Delta(cur, AsLong(p, cmp), Higher(p.Sentiment), money);
            var deltaHtml = dlt is null ? "" : $"<div class=\"stat-delta {dlt.Value.Cls}\"><i class=\"bi {dlt.Value.Icon}\"></i> {dlt.Value.Text}</div>";
            var badges = string.Concat(details.Select(dp => StatRender.Value(dp, s, board).ToString()));
            return new HtmlString(
                $"<div class=\"stat-tile\"><div class=\"stat-tile-top\"><span class=\"stat-ico text-{d.Tone} bg-{d.Tone}-subtle\"><i class=\"bi {d.Icon}\"></i></span>" +
                $"<span class=\"stat-label\">{d.Label}</span></div><div class=\"stat-value\">{valStr}</div>{deltaHtml}" +
                $"<div class=\"d-flex flex-wrap align-items-center gap-2 mt-1\">{badges}</div></div>");
        }

        // Plain money / number tile (with optional sub-note).
        return Tile(d.Label, d.Icon, d.Tone, Higher(p.Sentiment), money, cur, AsLong(p, cmp), d.Sub?.Invoke(s));
    }

    // One section card's inner (title + tile grid). lgCols only matters for full-width cards;
    // half cards are always 2-up at sm and above.
    IHtmlContent SectionCard(StatSection sec, bool half)
    {
        var cols = half ? "row-cols-1 row-cols-sm-2" : $"row-cols-1 row-cols-sm-2 row-cols-lg-{sec.LgCols}";
        var tiles = string.Concat(sec.Stats
            .Where(stat => stat.Visible is null || stat.Visible(s))
            .Select(stat => $"<div class=\"col\">{RenderDescriptor(stat)}</div>"));
        return new HtmlString(
            $"<div class=\"card shadow-sm border-0 {(half ? "h-100" : "mb-4")}\"><div class=\"card-body\">" +
            $"<h2 class=\"h5 stats-card-title mb-3\"><span class=\"stats-card-ico text-{sec.Tone} bg-{sec.Tone}-subtle\">" +
            $"<i class=\"bi {sec.Icon}\"></i></span>{WebUtility.HtmlEncode(sec.Title)}</h2>" +
            $"<div class=\"row {cols} g-3\">{tiles}</div></div></div>");
    }

    // ── chart series (per-turn arrays serialised on the stat record) ──
    double[] Series(string? json)
        => string.IsNullOrWhiteSpace(json)
            ? []
            : (JsonSerializer.Deserialize<List<double>>(json) ?? []).ToArray();

    string SeriesJs(string? json) => JsonSerializer.Serialize(Series(json));
    string CmpSeriesJs(Func<PlayerStatRecord, string> pick) => cmp is null ? "null" : JsonSerializer.Serialize(Series(pick(cmp)));

    // Unique per render — this partial can appear several times on one page (the profile's
    // avg/min/max/total tabs), so chart element ids must not collide.
    var uid = Guid.NewGuid().ToString("N")[..8];

    var sections = StatCatalogue.Sections;
}

<link rel="stylesheet" href="~/css/player-stats.css" asp-append-version="true" />

<div class="player-stats">

    @* ── Hero ── *@
    <div class="stats-hero mb-4">
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
            <div>
                <h1 class="h3 mb-1"><i class="bi bi-bar-chart-line-fill me-2"></i>Statistics</h1>
                <p class="mb-0 opacity-75">A full breakdown of the numbers.</p>
            </div>
            @if (hasCmp)
            {
                <div class="d-flex flex-column gap-1">
                    <span class="stats-key"><span class="stats-key-line"></span> All games</span>
                    <span class="stats-key"><span class="stats-key-line dashed"></span> Previous</span>
                </div>
            }
        </div>
    </div>

    @* ── Sections (catalogue-driven). Full-width cards render alone; consecutive Half sections
         pair into a 50/50 row (Spending+Income, Jail+Free Parking). ── *@
    @for (var i = 0; i < sections.Count; i++)
    {
        var sec = sections[i];
        if (!sec.Half)
        {
            @SectionCard(sec, false)
        }
        else
        {
            var right = i + 1 < sections.Count && sections[i + 1].Half ? sections[i + 1] : null;
            <div class="row g-4 mb-4">
                <div class="col-12 col-lg-6">@SectionCard(sec, true)</div>
                @if (right is not null)
                {
                    <div class="col-12 col-lg-6">@SectionCard(right, true)</div>
                }
            </div>
            if (right is not null) { i++; }
        }
    }

    @* ── 13.12 Graphs ── *@
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h2 class="h5 stats-card-title mb-3">
                <span class="stats-card-ico text-info bg-info-subtle"><i class="bi bi-graph-up"></i></span>
                Over time
            </h2>
            <div class="row g-4">
                <div class="col-12 col-xl-6"><div id="chartBalance-@uid" class="stats-chart"></div></div>
                <div class="col-12 col-xl-6"><div id="chartNetWorth-@uid" class="stats-chart"></div></div>
                <div class="col-12 col-xl-6"><div id="chartProps-@uid" class="stats-chart"></div></div>
                <div class="col-12 col-xl-6"><div id="chartRank-@uid" class="stats-chart"></div></div>
            </div>
        </div>
    </div>
</div>

@* Charts build lazily, the first time each canvas becomes visible (IntersectionObserver).
   This handles (a) ej2.min.js loading at end of body, and (b) charts that start inside a
   hidden tab pane on the profile — Syncfusion sizes to 0 in a display:none container, so we
   defer the build until the tab is shown. Element ids are suffixed with @@uid so several
   renders of this partial on one page (the profile's four view tabs) don't collide. *@
<script>
    (function () {
        var data = {
            balance:  { stats: @Html.Raw(SeriesJs(s.BalanceOverTimeJson)),       prev: @Html.Raw(CmpSeriesJs(c => c.BalanceOverTimeJson)) },
            networth: { stats: @Html.Raw(SeriesJs(s.NetWorthOverTimeJson)),       prev: @Html.Raw(CmpSeriesJs(c => c.NetWorthOverTimeJson)) },
            props:    { stats: @Html.Raw(SeriesJs(s.PropertyCountOverTimeJson)),  prev: @Html.Raw(CmpSeriesJs(c => c.PropertyCountOverTimeJson)) },
            rank:     { stats: @Html.Raw(SeriesJs(s.WealthRankOverTimeJson)),     prev: @Html.Raw(CmpSeriesJs(c => c.WealthRankOverTimeJson)) }
        };

        var specs = [
            ['chartBalance-@uid', 'Balance over time', 'Balance (£)', data.balance, false],
            ['chartNetWorth-@uid', 'Net worth over time', 'Net worth (£)', data.networth, false],
            ['chartProps-@uid', 'Properties over time', 'Properties', data.props, false],
            ['chartRank-@uid', 'Wealth rank over time', 'Rank (1 = richest)', data.rank, true]
        ];

        function pts(a) { return (a || []).map(function (v, i) { return { x: i + 1, y: v }; }); }

        function build(id, title, yTitle, d, inversed) {
            var el = document.getElementById(id);
            if (!el) return;
            if (!d.stats || !d.stats.length) {
                el.innerHTML = '<div class="text-body-secondary small text-center py-5">No data yet.</div>';
                return;
            }
            var series = [{
                dataSource: pts(d.stats), xName: 'x', yName: 'y', name: 'All games',
                type: 'Line', width: 3, marker: { visible: true, width: 6, height: 6 }
            }];
            if (d.prev && d.prev.length) {
                series.push({
                    dataSource: pts(d.prev), xName: 'x', yName: 'y', name: 'Previous',
                    type: 'Line', width: 2, dashArray: '6,4', marker: { visible: true, width: 5, height: 5 }
                });
            }
            new ej.charts.Chart({
                theme: 'Bootstrap5Dark',
                title: title,
                primaryXAxis: { title: 'Turn', valueType: 'Double', interval: 1, minimum: 1, edgeLabelPlacement: 'Shift' },
                primaryYAxis: { title: yTitle, isInversed: !!inversed },
                series: series,
                tooltip: { enable: true, shared: true },
                legendSettings: { visible: true },
                chartArea: { border: { width: 0 } }
            }).appendTo('#' + id);
        }

        function start() {
            if (typeof ej === 'undefined' || !ej.charts) return;
            ej.charts.Chart.Inject(ej.charts.LineSeries, ej.charts.Tooltip, ej.charts.Legend);

            specs.forEach(function (spec) {
                var el = document.getElementById(spec[0]);
                if (!el) return;
                var built = false;
                var obs = new IntersectionObserver(function (entries) {
                    entries.forEach(function (entry) {
                        if (!entry.isIntersecting || built) return;   // only when actually visible
                        built = true;
                        obs.disconnect();
                        build(spec[0], spec[1], spec[2], spec[3], spec[4]);
                    });
                });
                obs.observe(el);
            });
        }

        // Defer until ej2.min.js (end of body) has run.
        if (document.readyState !== 'loading') start();
        else document.addEventListener('DOMContentLoaded', start);
    })();
</script>
