@using JC.Identity.Authentication
@using UltimateMonopoly.Data
@using UltimateMonopoly.Services
@inject ProfileService ProfileService
@* Shared profile circle + account dropdown, used by every layout's navbar. The top item adapts to context:
   inside the Admin area it's "Back to App"; elsewhere it's the admin entry point (Admin Centre, or Reported
   Issues for a GithubManager-only user). Assumes a #feedbackModal is present on the page. *@
@{
    var currentUser = await ProfileService.GetCurrentUserProfileViewModelAsync();
    var inAdminArea = string.Equals(ViewContext.RouteData.Values["area"] as string, "Admin", StringComparison.OrdinalIgnoreCase);
    var isAdmin = User.IsInRole(SystemRoles.Admin) || User.IsInRole(SystemRoles.SystemAdmin);
    var isOnlyGithubManager = !isAdmin && User.IsInRole(AppRoles.GithubManager);
}
<div class="dropdown">
    <button class="btn p-0 border-0 rounded-circle" type="button"
            data-bs-toggle="dropdown" aria-expanded="false" aria-label="My Account">
        <profile-circle user="currentUser" size="Md" />
    </button>
    <ul class="dropdown-menu dropdown-menu-end" style="max-width: 95vw;">
        @if (inAdminArea)
        {
            <li><a class="dropdown-item" href="/"><i class="bi bi-box-arrow-left me-1"></i>Back to App</a></li>
            <li><hr class="dropdown-divider" /></li>
        }
        else if (isAdmin)
        {
            <li><a class="dropdown-item" asp-area="Admin" asp-page="/Index"><i class="bi bi-shield-lock me-1"></i>Admin Centre</a></li>
            <li><hr class="dropdown-divider" /></li>
        }
        else if (isOnlyGithubManager)
        {
            <li><a class="dropdown-item" asp-area="Admin" asp-page="/Logs/Issues/Index"><i class="bi bi-card-list me-1"></i>Reported Issues</a></li>
            <li><hr class="dropdown-divider" /></li>
        }
        <li><a class="dropdown-item" href="/profile"><i class="bi bi-person me-1"></i>Profile</a></li>
        <li><a class="dropdown-item" href="/account"><i class="bi bi-gear me-1"></i>Account</a></li>
        <li><hr class="dropdown-divider" /></li>
        <li>
            <button type="button" class="dropdown-item" data-bs-toggle="modal" data-bs-target="#feedbackModal">
                <i class="bi bi-chat-square-text me-1"></i>Give Feedback
            </button>
        </li>
        <li><hr class="dropdown-divider" /></li>
        <li>
            <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="m-0">
                <button type="submit" class="dropdown-item dropdown-item-danger"><i class="bi bi-box-arrow-right me-1"></i>Logout</button>
            </form>
        </li>
    </ul>
</div>
