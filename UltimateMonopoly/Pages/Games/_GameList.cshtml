@model List<UltimateMonopoly.Models.ViewModels.Games.GameViewModel>
@inject JC.Core.Models.IUserInfo UserInfo

@*
    Game-list row. Layout + responsive behaviour live in `.game-tile` (site.css / custom-bootstrap.scss):
    while the tile is wide enough the name sits beside the badge + buttons; once they no longer fit, the
    action group drops to a full-width strip beneath the meta line and the name wraps instead of truncating.
    Container-query driven, so it adapts to the tile's own width (wide games pages and narrow hub columns alike).
*@

@if (Model.Count == 0)
{
    <p class="text-body-secondary text-center py-4 mb-0">No games here yet.</p>
}
else
{
    <div class="d-flex flex-column gap-2">
        @foreach (var game in Model)
        {
            <div class="game-tile card">
                <div class="game-tile__body card-body py-2">
                    <div class="game-tile__main">
                        <div class="game-tile__name">@game.Name</div>
                        <div class="game-tile__meta small text-body-secondary">
                            @game.Players.Count player@(game.Players.Count == 1 ? "" : "s")
                            <span class="mx-1">·</span>
                            @game.CreatedDate
                        </div>
                    </div>
                    <div class="game-tile__actions">
                        <span class="badge text-bg-secondary align-self-center">@game.State</span>

                        @switch (game.State.ToLower())
                        {
                            case "setup":
                            {
                                if (game.IsHost)
                                {
                                    <a class="btn btn-sm btn-primary"
                                       asp-area="Game" asp-page="/Setup" asp-route-id="@game.Id">Open Host</a>
                                }
                                <a class="btn btn-sm btn-outline-primary"
                                   asp-area="Game" asp-page="/Player/Lobby"
                                   asp-route-gameId="@game.Id" asp-route-userId="@UserInfo.UserId">Player Lobby</a>
                                break;
                            }
                            case "in play":
                            {
                                if (game.IsHost)
                                {
                                    <a class="btn btn-sm btn-primary"
                                       asp-area="Game" asp-page="/Play" asp-route-gameId="@game.Id">Host</a>
                                }
                                <a class="btn btn-sm btn-outline-primary"
                                   asp-area="Game" asp-page="/Player/Index"
                                   asp-route-gameId="@game.Id" asp-route-userId="@UserInfo.UserId">Open</a>
                                break;
                            }
                            case "finished":
                                <a class="btn btn-sm btn-outline-secondary"
                                   asp-page="/Games/Finished" asp-route-gameId="@game.Id">View</a>
                                break;
                            case "cancelled" when game.IsHost:
                                <form method="post" asp-page-handler="Delete" class="m-0">
                                    <input type="hidden" name="gameId" value="@game.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                                break;
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}