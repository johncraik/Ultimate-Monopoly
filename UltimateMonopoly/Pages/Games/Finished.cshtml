@page "{gameId}"
@model UltimateMonopoly.Pages.Games.FinishedModel
@{
    ViewData["Title"] = "Game Completed";
    // _PlayerCard lives in the Game area; reference it by full path from this root page.
    const string playerCard = "~/Areas/Game/Pages/Shared/_PlayerCard.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-7 col-xl-6">

        @* ───────────── Game Completed header ───────────── *@
        <div class="card text-center border-0 shadow-sm mb-4">
            <div class="card-body py-4">
                <div class="display-5 lh-1 mb-2"><i class="bi bi-flag-checkered"></i></div>
                <h1 class="h3 mb-2">Game Completed</h1>
                <div class="fs-5 fw-semibold mb-3">@Model.GameName</div>
                <div class="d-flex justify-content-center flex-wrap gap-2">
                    <span class="badge text-bg-secondary"><i class="bi bi-calculator me-1"></i>@Model.RoundingRule</span>
                    <span class="badge text-bg-secondary"><i class="bi bi-grid-3x3-gap-fill me-1"></i>@Model.BoardName</span>
                </div>
            </div>
        </div>

        @* ───────────── Winner (or Drawn players) ───────────── *@
        @if (!Model.IsDraw && Model.Winner is not null)
        {
            <div class="card text-center border-warning shadow-sm mb-4">
                <div class="card-body">
                    <div class="text-warning lh-1 mb-2" style="font-size: 3rem;">
                        <i class="bi bi-trophy-fill"></i>
                    </div>
                    <div class="text-uppercase fw-bold text-warning small mb-3" style="letter-spacing: .08em;">Winner</div>
                    <partial name="@playerCard" model="Model.Winner" />
                </div>
            </div>
        }
        else if (Model.IsDraw && Model.DrawnPlayers.Count > 0)
        {
            <div class="card border-info shadow-sm mb-4">
                <div class="card-header text-center fw-semibold text-info-emphasis bg-info-subtle">
                    <i class="bi bi-people-fill me-2"></i>Drawn Game
                </div>
                <div class="card-body d-flex flex-column gap-2">
                    @foreach (var card in Model.DrawnPlayers)
                    {
                        <partial name="@playerCard" model="card" />
                    }
                </div>
            </div>
        }

        @* ───────────── Losers (bankrupt) ───────────── *@
        @if (Model.Losers.Count > 0)
        {
            <div class="card border-danger shadow-sm mb-4">
                <div class="card-header text-center fw-semibold text-danger-emphasis bg-danger-subtle">
                    <i class="bi bi-emoji-frown-fill me-2"></i>Bankrupt
                </div>
                <div class="card-body d-flex flex-column gap-2">
                    @foreach (var card in Model.Losers)
                    {
                        <partial name="@playerCard" model="card" />
                    }
                </div>
            </div>
        }

        @* ───────────── Stats CTAs ───────────── *@
        <div class="d-grid gap-2">
            <a class="btn btn-hero-primary" asp-page="/Games/GameStats"
               asp-route-gameId="@Model.GameId" asp-route-userId="@Model.CurrentUserId">
                <i class="bi bi-bar-chart-line-fill me-2"></i> View My Game Stats
            </a>
            <a class="btn btn-outline-primary" asp-page="/Games/Compare" asp-route-gameId="@Model.GameId">
                <i class="bi bi-bar-chart-steps me-2"></i> Compare All Players
            </a>
        </div>

    </div>
</div>