@page
@model UltimateMonopoly.Pages.Games.MyGamesModel
@{
    ViewData["Title"] = "My Games";
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
    <div>
        <h1 class="mb-1">My Games</h1>
        <p class="text-body-secondary mb-0">Games you've created.</p>
    </div>
    <a asp-page="/Games/Joined" class="btn btn-outline-primary">View Games Joined</a>
</div>

<partial name="_GameTabs" model="Model.Games" />