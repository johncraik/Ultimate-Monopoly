@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="mx-auto text-center" style="max-width: 640px;">
    <div class="card border-danger">
        <div class="card-body">
            <h2 class="text-danger mb-3">Something went wrong</h2>
            @if (Model.ShowRequestId)
            {
                <p class="text-body-secondary"><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
            }
            <a href="/" class="btn btn-primary w-100">Return to home</a>
        </div>
    </div>
</div>
