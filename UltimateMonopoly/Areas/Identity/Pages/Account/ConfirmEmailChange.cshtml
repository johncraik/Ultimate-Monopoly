@page
@model ConfirmEmailChangeModel
@{
    ViewData["Title"] = "Confirm Email Change";
}

<div class="mx-auto" style="max-width: 560px;">
    <div class="card text-center">
        <div class="card-body p-4 p-md-5">
            @if (Model.Succeeded)
            {
                <div class="display-4 text-success mb-3"><i class="bi bi-check-circle-fill"></i></div>
                <h1 class="h3 mb-2">Email change confirmed</h1>
                <p class="text-body-secondary mb-4">
                    Your new email address is now verified and active on your account.
                </p>
                <a asp-area="Identity" asp-page="/Account/Manage/Index" class="btn btn-hero-primary btn-lg w-100">
                    <i class="bi bi-person-gear me-1"></i> Account settings
                </a>
            }
            else
            {
                <div class="display-4 text-danger mb-3"><i class="bi bi-x-circle-fill"></i></div>
                <h1 class="h3 mb-2">We couldn't change your email</h1>
                <p class="text-body-secondary mb-4">
                    This link is invalid or has expired. You can request the change again from your account settings.
                </p>
                <a asp-area="Identity" asp-page="/Account/Manage/Index" class="btn btn-hero-primary btn-lg w-100">
                    <i class="bi bi-person-gear me-1"></i> Account settings
                </a>
            }
        </div>
    </div>
</div>
