@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Password Reset";
}

<div class="mx-auto text-center" style="max-width: 640px;">
    <div class="card">
        <div class="card-body">
            <h2 class="mb-3">Password Reset</h2>
            <p>Your password has been reset successfully.</p>
            <a asp-page="./Login" class="btn btn-primary w-100">Log in</a>
        </div>
    </div>
</div>
