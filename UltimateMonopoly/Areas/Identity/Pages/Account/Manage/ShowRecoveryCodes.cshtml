@page
@model ShowRecoveryCodesModel
@{
    ViewData["Title"] = "Recovery Codes";
    ViewData["ActivePage"] = "TwoFactorAuthentication";
    var allCodes = string.Join("\n", Model.RecoveryCodes);
}

<h3>@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />

<style>
    .recovery-code.copied, .copy-all.copied { outline: 2px solid var(--bs-success); outline-offset: 2px; }
</style>

<div class="card border-warning">
    <div class="card-body">
        <div class="alert alert-warning mb-3">
            <strong>Store these codes in a safe place.</strong> If you lose your authenticator device and don't have these codes, you'll lose access to your account.
        </div>
        <div class="d-flex flex-wrap gap-2 mb-3">
            @foreach (var code in Model.RecoveryCodes)
            {
                <code class="recovery-code bg-body-secondary p-2 rounded user-select-all" role="button" title="Click to copy" data-copy="@(code)">@(code)</code>
            }
        </div>
        <button type="button" class="copy-all btn btn-outline-primary btn-sm" data-copy="@allCodes">
            <i class="bi bi-clipboard me-1"></i>Copy all codes
        </button>
    </div>
</div>

@section Scripts {
    @* Generic delegated click-to-copy (any [data-copy] element) — reused for per-code and copy-all. *@
    <script src="~/scripts/admin/copy.js" asp-append-version="true"></script>
}
