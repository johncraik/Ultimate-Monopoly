@{
    Layout = ViewData.TryGetValue("ParentLayout", out var parentLayout) && parentLayout != null
        ? parentLayout.ToString()
        : "/Pages/Shared/_Layout.cshtml";

    var active = ViewData["ActivePage"] as string ?? "Account";

    bool InTab(params string[] pages) => pages.Contains(active, StringComparer.OrdinalIgnoreCase);

    // Sub-pages (e.g. EnableAuthenticator) keep their original ActivePage, so each tab owns its group.
    var accountActive = InTab("Account", "Index", "Email") ? "active" : "";
    var securityActive = InTab("Security", "ChangePassword", "SetPassword", "TwoFactorAuthentication",
        "EnableAuthenticator", "ResetAuthenticator", "Disable2fa", "GenerateRecoveryCodes", "ShowRecoveryCodes") ? "active" : "";
    var dataActive = InTab("PersonalData", "DownloadPersonalData", "DeletePersonalData") ? "active" : "";
}

<h2 class="mb-4">Account Settings</h2>

<ul class="nav nav-tabs mb-4">
    <li class="nav-item">
        <a class="nav-link @accountActive" asp-page="./Index">Account</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @securityActive" asp-page="./Security">Security</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @dataActive" asp-page="./PersonalData">Personal Data</a>
    </li>
</ul>

@RenderBody()

@section Scripts {
    @RenderSection("Scripts", required: false)
}