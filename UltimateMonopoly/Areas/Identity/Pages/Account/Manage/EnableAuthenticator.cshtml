@page
@model EnableAuthenticatorModel
@{
    ViewData["Title"] = "Enable Authenticator";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<h3>@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />

<div class="card">
    <div class="card-body">
        <ol class="list-group list-group-numbered mb-4">
            <li class="list-group-item bg-transparent border-secondary">
                Download an authenticator app (e.g. Google Authenticator, Microsoft Authenticator).
            </li>
            <li class="list-group-item bg-transparent border-secondary">
                Scan the QR code with your authenticator app, or enter the setup key manually.

                <div class="text-center my-3">
                    <div class="d-inline-block bg-white p-3 rounded">
                        @Html.Raw(Model.QrCodeSvg)
                    </div>
                </div>

                <small class="text-body-secondary d-block mb-1">Setup key (click to copy):</small>
                <pre id="shared-key"
                     class="bg-body-secondary text-body p-3 rounded mb-0 user-select-all"
                     style="cursor: pointer;"
                     role="button"
                     tabindex="0"
                     title="Click to copy"><code>@Model.SharedKey</code></pre>
            </li>
            <li class="list-group-item bg-transparent border-secondary">
                Enter the 6-digit code from your app below.
            </li>
        </ol>

        <form id="send-code" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Code" class="form-control" autocomplete="off" placeholder="000000" />
                <label asp-for="Input.Code">Verification Code</label>
                <span asp-validation-for="Input.Code" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Verify</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const el = document.getElementById('shared-key');
            if (!el) return;
            const codeEl = el.querySelector('code') ?? el;
            const original = codeEl.textContent;

            const copy = async () => {
                try {
                    await navigator.clipboard.writeText(original.trim());
                    codeEl.textContent = 'Copied!';
                    setTimeout(() => { codeEl.textContent = original; }, 1200);
                } catch {
                    // Clipboard API unavailable (e.g. non-secure context) — silently no-op.
                }
            };

            el.addEventListener('click', copy);
            el.addEventListener('keydown', (e) => {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    copy();
                }
            });
        })();
    </script>
}
