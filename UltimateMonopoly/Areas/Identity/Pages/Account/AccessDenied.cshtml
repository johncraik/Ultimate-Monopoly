@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Access denied";
}

<div class="py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card shadow-sm border-0 text-center">
                <div class="card-body p-4 p-md-5">
                    <i class="bi bi-shield-lock display-4 text-secondary d-block mb-3"></i>
                    <h1 class="h3 mb-2">Access denied</h1>
                    <p class="text-body-secondary mb-4">
                        You don't have permission to view this page. If you think you should, let us know.
                    </p>

                    <div class="d-flex gap-2 justify-content-center flex-wrap">
                        <a href="/" class="btn btn-hero-primary">Go home</a>
                        <button type="button" class="btn btn-hero-secondary" onclick="history.back()">Go back</button>
                    </div>

                    <partial name="~/Pages/Shared/_HelpContact.cshtml" />
                </div>
            </div>
        </div>
    </div>
</div>
