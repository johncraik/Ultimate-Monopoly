@page
@model LoginWithRecoveryCodeModel
@{
    ViewData["Title"] = "Recovery Code";
}

<div class="container" style="max-width: 640px;">
    <div class="card">
        <div class="card-body">
            <h2 class="card-title text-center mb-4">Recovery Code</h2>
            <p class="text-center text-body-secondary mb-3">Enter one of your recovery codes to log in.</p>
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.RecoveryCode" class="form-control" autocomplete="off" placeholder="Recovery code" />
                    <label asp-for="Input.RecoveryCode">Recovery code</label>
                    <span asp-validation-for="Input.RecoveryCode" class="text-danger"></span>
                </div>
                <button type="submit" class="w-100 btn btn-lg btn-primary">Log in</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
