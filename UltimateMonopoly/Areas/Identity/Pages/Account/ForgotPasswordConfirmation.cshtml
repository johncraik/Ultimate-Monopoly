@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Password Reset Sent";
}

<div class="mx-auto text-center" style="max-width: 640px;">
    <div class="card">
        <div class="card-body">
            <h2 class="mb-3">Check Your Email</h2>
            <p>If an account exists with that email, a password reset link has been sent.</p>
            <a asp-page="./Login" class="btn btn-primary w-100">Back to login</a>
        </div>
    </div>
</div>
