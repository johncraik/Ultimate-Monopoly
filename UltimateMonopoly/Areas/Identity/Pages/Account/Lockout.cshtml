@page
@model LockoutModel
@{
    ViewData["Title"] = "Account Locked";
}

<div class="container text-center" style="max-width: 640px;">
    <div class="card border-danger">
        <div class="card-body">
            <h2 class="text-danger mb-3">Account Locked</h2>
            <p>This account has been locked due to too many failed attempts. Please try again later.</p>
        </div>
    </div>
</div>
