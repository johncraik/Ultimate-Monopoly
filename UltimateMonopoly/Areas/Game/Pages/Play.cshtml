@page "{gameId}"
@model UltimateMonopoly.Areas.Game.Pages.PlayModel
@{
    ViewData["Title"] = Model.Engine.Cache.GameName;
    var cache = Model.Engine.Cache;
}

@*
    HOST / TABLET PLAY PAGE  (/Game/Play/{gameId}) — see design-docs/Game-UI.md.
    The play body lives in the _PlayView partial and renders from the engine
    cache. play-state.js re-fetches that partial (PlayModel handler=State) on
    every SignalR StateChanged frame (web-orchestration.md §6) and swaps it into
    .play-page, so live and first-load render paths are identical — no
    client-side state duplication. The board JSON itself is static.

    Player-facing prompts (DiceRoll, etc.) surface on the player profile / its
    host drawer, never here — only the interruptible (NOPE) window targets the
    game view, and that isn't wired yet.
*@

<div class="play-page row g-3" data-play data-game-id="@cache.GameId">
    <partial name="Play/_PlayView" model="Model.Engine" />
</div>

@* ───────── Player profile drawer (left pull-out) ─────────
   Body is loaded by player-drawer.js — it fetches the real /player-profile
   partial (Index handler=State) for the selected player. Opens manually (the
   "View" buttons) and automatically on that player when a prompt fires; the
   prompt modals below render over it. See Game-UI.md / player-drawer.js. *@
<div class="player-drawer-backdrop" data-drawer-backdrop></div>
<aside class="player-drawer" data-player-drawer aria-hidden="true">
    <div class="player-drawer-header d-flex align-items-center justify-content-between gap-2 p-2 border-bottom">
        <button type="button" class="btn btn-sm btn-outline-secondary" data-drawer-prev aria-label="Previous player">
            <i class="bi bi-chevron-left"></i>
        </button>
        <span class="fw-semibold text-truncate" data-drawer-title>Player</span>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-sm btn-outline-secondary" data-drawer-next aria-label="Next player">
                <i class="bi bi-chevron-right"></i>
            </button>
            <button type="button" class="btn btn-sm btn-outline-danger" data-drawer-close aria-label="Close">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    </div>
    <div class="player-drawer-body p-3">
        <p data-drawer-content class="text-body-secondary">No player selected.</p>
    </div>
</aside>

@* Player-facing prompts now render inside the player-profile partial (server-side),
   so they surface only within the host's player-profile drawer — see the .pp-prompt
   overlay in _PlayerProfileView. No page-level prompt modals here. *@

@section Styles {
    <link rel="stylesheet" href="~/css/play.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/player-profile.css" asp-append-version="true" />
}

@section Scripts {
    @* Coordinator first (owns the connection); the rest register against it. *@
    <script src="~/scripts/InGame/game-play-hub.js" asp-append-version="true"></script>
    <script src="~/scripts/InGame/play-state.js" asp-append-version="true"></script>
    <script src="~/scripts/InGame/play-page.js" asp-append-version="true"></script>
    <script src="~/scripts/InGame/player-drawer.js" asp-append-version="true"></script>
    @* Submits the server-rendered prompts (the .pp-prompt overlay inside the drawer's profile). *@
    <script src="~/scripts/InGame/ingame-prompts.js" asp-append-version="true"></script>
    @* Live "give / receive" summary for the deal builder (_MakeDealPartial). *@
    <script src="~/scripts/InGame/make-deal.js" asp-append-version="true"></script>
    @* Deal tab: pick-a-player ↔ deal-builder block toggling. *@
    <script src="~/scripts/InGame/deal-tab.js" asp-append-version="true"></script>
}