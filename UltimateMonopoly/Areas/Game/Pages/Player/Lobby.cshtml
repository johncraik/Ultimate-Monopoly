@page "{gameId}/{userId}"
@model UltimateMonopoly.Areas.Game.Pages.Player.Lobby
@{
    ViewData["Title"] = "Game Lobby";
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-5" data-lobby data-game-id="@Model.GameId" data-user-id="@Model.UserId">

        <div class="text-center mb-4">
            <h1 class="h3 mb-1">@Model.GameName</h1>
            <p class="text-body-secondary mb-0">Game Lobby</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.StatusMessage))
        {
            <div class="position-fixed top-0 end-0 p-3" style="z-index: 1090;" data-floating-alert>
                <alert type="@Model.StatusAlertType" message="@Model.StatusMessage" />
            </div>
        }

        @* ---- Player profile ---- *@
        <div class="card mb-3">
            <div class="card-body d-flex align-items-center gap-3">
                <profile-circle user="Model.Profile" size="Lg" />
                <div class="flex-grow-1 min-w-0">
                    <div class="fw-semibold text-truncate fs-5">@Model.Profile?.DisplayName</div>
                    <div class="small text-body-secondary">
                        Dice Numbers:
                        <span data-dice-display>
                            @if (Model.Dice1 is null || Model.Dice2 is null)
                            {
                                <span class="badge text-bg-warning">Not Set</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">@Model.Dice1 | @Model.Dice2</span>
                            }
                        </span>
                    </div>
                </div>
            </div>
        </div>

        @* ---- Set dice numbers ---- *@
        <div class="card mb-3">
            <div class="card-header fw-semibold">Your Dice Numbers</div>
            <div class="card-body">
                <p class="small text-body-secondary">Roll two dice and select the values.</p>
                <form method="post" asp-page-handler="SetDice">
                    <div class="mb-3">
                        <label class="form-label">Die 1</label>
                        <div class="btn-group d-flex" role="group" aria-label="Die 1">
                            @for (ushort i = 1; i <= 6; i++)
                            {
                                <input type="radio" class="btn-check" name="dice1" id="lobby-d1-@i" value="@i"
                                       autocomplete="off" required checked="@(Model.Dice1 == i)" />
                                <label class="btn btn-outline-primary" for="lobby-d1-@i">@i</label>
                            }
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Die 2</label>
                        <div class="btn-group d-flex" role="group" aria-label="Die 2">
                            @for (ushort i = 1; i <= 6; i++)
                            {
                                <input type="radio" class="btn-check" name="dice2" id="lobby-d2-@i" value="@i"
                                       autocomplete="off" required checked="@(Model.Dice2 == i)" />
                                <label class="btn btn-outline-primary" for="lobby-d2-@i">@i</label>
                            }
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Save Dice Numbers</button>
                </form>
            </div>
        </div>

        @* ---- Waiting for host ---- *@
        <div class="card text-center">
            <div class="card-body">
                <div class="spinner-border text-primary mb-2" role="status">
                    <span class="visually-hidden">Waiting...</span>
                </div>
                <p class="mb-0">Waiting for the host to start the game...</p>
            </div>
        </div>

        <form method="post" asp-page-handler="Leave" class="mt-3">
            <button type="submit" class="btn btn-outline-danger w-100">Leave Game</button>
        </form>

    </div>
</div>

@section Scripts {
    <script src="~/scripts/SignalR/game-lobby-hub.js" asp-append-version="true"></script>
}