@page "/player-profile/{gameId}/{userId}"
@model UltimateMonopoly.Areas.Game.Pages.Player.Index
@{
    ViewData["Title"] = Model.Profile?.DisplayName ?? "Player";
}

@*
    MOBILE PLAYER PROFILE
    The only functioning element on this page is the dice-roll prompt (the modal
    at the bottom), driven by SignalR via /scripts/InGame/Prompts/dice-roll-prompt.js.
    It appears only when a
    DiceRollPrompt fires for this player. Everything else below is static mock — no
    money/property/card data is wired yet.
*@

<div class="row justify-content-center"
     data-player data-game-id="@Model.GameId" data-user-id="@Model.UserId">
    <div class="col-md-7 col-lg-5">

        @* ---- Identity ---- *@
        <div class="card mb-3">
            <div class="card-body d-flex align-items-center gap-3">
                <profile-circle user="Model.Profile" size="Lg" />
                <div class="flex-grow-1 min-w-0">
                    <div class="d-flex align-items-center gap-2">
                        <span class="fw-semibold text-truncate fs-5">@Model.Profile?.DisplayName</span>
                        @if (Model.IsOwnProfile)
                        {
                            <span class="badge text-bg-primary">You</span>
                        }
                    </div>
                    <div class="small text-body-secondary">
                        @Model.GameName · Seat @(Model.OrderId + 1)
                        @if (Model.Dice1 is not null && Model.Dice2 is not null)
                        {
                            <span class="ms-1">· Dice <span class="badge text-bg-secondary">@Model.Dice1 | @Model.Dice2</span></span>
                        }
                    </div>
                </div>
                @* mock turn indicator *@
                <span class="badge rounded-pill text-bg-success align-self-start">Your turn</span>
            </div>
        </div>

        @* ---- Cash (mock) ---- *@
        <div class="card mb-3 text-center">
            <div class="card-body py-4">
                <div class="text-body-secondary text-uppercase small mb-1">Balance</div>
                <div class="display-5 fw-bold">£1,500</div>
                <div class="small text-body-secondary mt-1">Net worth £1,500</div>
            </div>
        </div>

        @* ---- Quick stats (mock) ---- *@
        <div class="row g-2 mb-3 text-center">
            <div class="col-4">
                <div class="card h-100"><div class="card-body p-2">
                    <div class="fs-4 fw-semibold">0</div>
                    <div class="small text-body-secondary">Properties</div>
                </div></div>
            </div>
            <div class="col-4">
                <div class="card h-100"><div class="card-body p-2">
                    <div class="fs-4 fw-semibold">0</div>
                    <div class="small text-body-secondary">Cards</div>
                </div></div>
            </div>
            <div class="col-4">
                <div class="card h-100"><div class="card-body p-2">
                    <div class="fs-4 fw-semibold">0</div>
                    <div class="small text-body-secondary">Loans</div>
                </div></div>
            </div>
        </div>

        @* ---- Properties (mock) ---- *@
        <div class="card mb-3">
            <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                <span>Properties</span>
                <span class="small text-body-secondary">by set</span>
            </div>
            <div class="card-body">
                <div class="text-center text-body-secondary py-3">
                    <i class="bi bi-houses fs-3 d-block mb-2"></i>
                    You don't own any properties yet.
                </div>
            </div>
        </div>

        @* ---- Cards in hand (mock) ---- *@
        <div class="card mb-3">
            <div class="card-header fw-semibold">Cards in hand</div>
            <div class="card-body">
                <div class="text-center text-body-secondary py-3">
                    <i class="bi bi-card-text fs-3 d-block mb-2"></i>
                    No cards held.
                </div>
            </div>
        </div>

        @* ---- Actions (mock — disabled) ---- *@
        <div class="d-grid gap-2 mb-2">
            <button type="button" class="btn btn-outline-primary" disabled>Manage Properties</button>
            <button type="button" class="btn btn-outline-primary" disabled>Propose Deal</button>
            <button type="button" class="btn btn-success" disabled>End Turn</button>
        </div>
        <p class="text-center small text-body-secondary">These actions aren't wired up yet.</p>

    </div>
</div>

@* ---- Engine prompts ---- *@
<partial name="Play/_DiceRollPrompt" />
<partial name="Play/_AcknowledgePrompt" />

@section Scripts {
    @* Coordinator first — prompt handlers register against it, then it connects. *@
    <script src="~/scripts/InGame/game-play-hub.js" asp-append-version="true"></script>
    <script src="~/scripts/InGame/Prompts/dice-roll-prompt.js" asp-append-version="true"></script>
    <script src="~/scripts/InGame/Prompts/acknowledge-prompt.js" asp-append-version="true"></script>
}