@page "/player-profile/{gameId}/{userId}"
@model UltimateMonopoly.Areas.Game.Pages.Player.Index
@{
    ViewData["Title"] = Model.Profile?.DisplayName ?? "Player";
}

@*
    MOBILE PLAYER PROFILE  (/player-profile/{gameId}/{userId}) — see design-docs/Game-UI.md
    "Player Profile Partial". The body lives in _PlayerProfileView and renders from
    the engine cache. player-state.js re-fetches that partial (handler=State) on every
    SignalR StateChanged frame and swaps it into [data-player], so live and first-load
    render paths are identical (mirrors the host play page). Engine prompts (dice,
    acquire, …) surface as the separate modals below, driven by the hub coordinator.
*@

<div class="player-profile" data-player data-game-id="@Model.GameId" data-user-id="@Model.UserId">
    <partial name="Play/_PlayerProfileView" model="Model.ProfileView" />
</div>

@* ---- Engine prompts (outside [data-player] so the live swap never disturbs them) ---- *@
<partial name="Play/_DiceRollPrompt" />
<partial name="Play/_AcknowledgePrompt" />
<partial name="Play/_AcquirePropertyPrompt" />

@section Styles {
    <link rel="stylesheet" href="~/css/player-profile.css" asp-append-version="true" />
}

@section Scripts {
    @* Coordinator first — prompt handlers + the state/command modules register against it, then it connects. *@
    <script src="~/scripts/InGame/game-play-hub.js" asp-append-version="true"></script>
    <script src="~/scripts/InGame/player-state.js" asp-append-version="true"></script>
    <script src="~/scripts/InGame/player-page.js" asp-append-version="true"></script>
    <script src="~/scripts/InGame/Prompts/dice-roll-prompt.js" asp-append-version="true"></script>
    <script src="~/scripts/InGame/Prompts/acknowledge-prompt.js" asp-append-version="true"></script>
    <script src="~/scripts/InGame/Prompts/acquire-property-prompt.js" asp-append-version="true"></script>
}