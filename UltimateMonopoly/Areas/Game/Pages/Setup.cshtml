@page "{id}"
@model UltimateMonopoly.Areas.Game.Pages.SetupModel
@using MP.GameEngine.Helpers.RuleSet
@{
    ViewData["Title"] = "Game Setup";

    var playerCount = Model.Players.Count;
    var enoughPlayers = playerCount >= RuleDictionary.MinimumPlayers;
    var allDiceSet = Model.Players.All(p => p.Dice1 is not null && p.Dice2 is not null);
    var ready = enoughPlayers && allDiceSet;

    var readinessMessage = !enoughPlayers
        ? $"Not enough players — at least {RuleDictionary.MinimumPlayers} are needed to start."
        : !allDiceSet
            ? "All players must set their dice numbers before the game can start."
            : "Ready to Start";
}

<style>
    .qr-code svg { width: 100%; height: auto; display: block; }

    .player-card { cursor: grab; }
    .player-card-ghost { opacity: 0.4; }
    .player-card-drag {
        cursor: grabbing;
        box-shadow: 0 0.75rem 1.75rem rgba(0, 0, 0, 0.55);
    }
</style>

<div class="mb-3">
    <h1 class="mb-1">@Model.GameName</h1>
    <p class="text-body-secondary mb-0">
        Board: <strong class="text-body">@Model.BoardName</strong>
        <span class="mx-2">·</span>
        Rounding: <strong class="text-body">@Model.RoundingRuleText</strong>
    </p>
</div>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="position-fixed top-0 end-0 p-3" style="z-index: 1090;" data-floating-alert>
        <alert type="@Model.StatusAlertType" message="@Model.StatusMessage" />
    </div>
}

<div class="row g-4">
    @* ---------- Players ---------- *@
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header d-flex align-items-center justify-content-between">
                <span class="fw-semibold">Players</span>
                <span class="badge @(enoughPlayers ? "text-bg-success" : "text-bg-danger")"><span data-player-count>@playerCount</span> / @RuleDictionary.MaximumPlayers</span>
            </div>

            <div data-readiness-banner
                 class="alert @(ready ? "alert-success" : "alert-danger") rounded-0 border-0 mb-0 py-2 px-3 text-center fw-semibold">
                @readinessMessage
            </div>

            <div class="card-body d-flex flex-column gap-2" data-player-list data-game-id="@Model.GameId" data-min-players="@RuleDictionary.MinimumPlayers">
                @foreach (var p in Model.Players)
                {
                    <partial name="_PlayerCard" model="p" />
                }
            </div>
        </div>
    </div>

    @* ---------- Join QR ---------- *@
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">Join Game</div>
            <div class="card-body d-flex flex-column align-items-center justify-content-center text-center pb-5">
                <p class="text-body-secondary small">Scan to join this game.</p>
                <div class="qr-code" style="max-width: 360px; width: 100%;">@Html.Raw(Model.JoinQrSvg)</div>
                <div class="mt-3">
                    <p class="small text-body-secondary mb-1">
                        Or visit <strong class="text-body">/join</strong> to enter code:
                    </p>
                    <span class="fs-3 fw-bold font-monospace text-primary">@Model.JoinCode</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-2 mt-4">
    <div class="col-6">
        <form method="post" asp-page-handler="Start">
            <button type="submit" class="btn btn-hero-primary w-100" disabled="@(!ready)">Start Game</button>
        </form>
    </div>
    <div class="col-6">
        <form method="post" asp-page-handler="Cancel">
            <button type="submit" class="btn btn-hero-danger w-100">Cancel Game</button>
        </form>
    </div>
</div>

<form method="post" asp-page-handler="Reorder" class="d-none" data-reorder-form></form>

@* ---------- Set Dice modal ---------- *@
<div class="modal fade" id="setDiceModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="SetDice">
                <div class="modal-header">
                    <h5 class="modal-title">Set Dice Numbers</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-body-secondary small mb-3" data-dice-player></p>
                    <input type="hidden" name="targetUserId" data-dice-target />
                    <div class="mb-3">
                        <label class="form-label">Die 1</label>
                        <div class="btn-group d-flex" role="group" aria-label="Die 1">
                            @for (ushort i = 1; i <= 6; i++)
                            {
                                <input type="radio" class="btn-check" name="dice1" id="modal-d1-@i" value="@i"
                                       autocomplete="off" required />
                                <label class="btn btn-outline-primary" for="modal-d1-@i">@i</label>
                            }
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Die 2</label>
                        <div class="btn-group d-flex" role="group" aria-label="Die 2">
                            @for (ushort i = 1; i <= 6; i++)
                            {
                                <input type="radio" class="btn-check" name="dice2" id="modal-d2-@i" value="@i"
                                       autocomplete="off" required />
                                <label class="btn btn-outline-primary" for="modal-d2-@i">@i</label>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/scripts/Sortable.min.js" asp-append-version="true"></script>
    <script src="~/scripts/game-setup.js" asp-append-version="true"></script>
    <script src="~/scripts/SignalR/game-setup-hub.js" asp-append-version="true"></script>
}