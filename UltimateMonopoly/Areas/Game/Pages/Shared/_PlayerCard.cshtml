@model UltimateMonopoly.Models.ViewModels.PlayerCard

<div class="card player-card @(Model.IsHost ? "border-primary" : "")"
     data-player-card data-user-id="@Model.Profile.UserId"
     data-dice-set="@((Model.Dice1 is not null && Model.Dice2 is not null).ToString().ToLowerInvariant())">
    <div class="card-body d-flex align-items-center gap-3 py-2">
        <profile-circle user="Model.Profile" size="Md" />
        <div class="flex-grow-1 min-w-0">
            <div class="fw-semibold text-truncate">
                @Model.Profile.DisplayName
                @if (Model.IsHost)
                {
                    <span class="badge text-bg-primary ms-1">Host</span>
                }
            </div>
            <div class="small text-body-secondary">
                Dice Numbers:
                <span data-dice-display>
                    @if (Model.Dice1 is null || Model.Dice2 is null)
                    {
                        <span class="badge text-bg-warning">Not Set</span>
                    }
                    else
                    {
                        <span class="badge text-bg-secondary">@Model.Dice1 | @Model.Dice2</span>
                    }
                </span>
            </div>
        </div>

        @if (Model.IsSetup)
        {
            <button type="button" class="btn btn-sm btn-outline-info"
                    data-bs-toggle="modal" data-bs-target="#setDiceModal"
                    data-set-dice
                    data-user-id="@Model.Profile.UserId"
                    data-name="@Model.Profile.DisplayName"
                    data-dice1="@(Model.Dice1?.ToString() ?? string.Empty)"
                    data-dice2="@(Model.Dice2?.ToString() ?? string.Empty)">
                Set Dice
            </button>

            @if (!Model.IsHost)
            {
                <form method="post" asp-page-handler="Kick" class="m-0">
                    <input type="hidden" name="targetUserId" value="@Model.Profile.UserId" />
                    <button type="submit" class="btn btn-sm btn-outline-danger">Kick</button>
                </form>
            }
        }
        else if (!string.IsNullOrEmpty(Model.Profile.UserId))
        {
            @* No UserId ⇒ a masked (blocked) player — render no action at all. *@
            @if (Model.GameId is not null)
            {
                @* Finished-game context → open this player's stats for the game. *@
                <a class="btn btn-sm btn-primary"
                   asp-area="" asp-page="/Games/GameStats"
                   asp-route-gameId="@Model.GameId" asp-route-userId="@Model.Profile.UserId">
                    <i class="bi bi-bar-chart-line-fill me-1"></i> View Stats
                </a>
            }
            else
            {
                <a class="btn btn-sm btn-primary"
                   asp-area="Social" asp-page="/Friends/Profile" asp-route-userId="@Model.Profile.UserId">
                    <i class="bi bi-person-lines-fill me-1"></i> View
                </a>
            }
        }
    </div>
</div>