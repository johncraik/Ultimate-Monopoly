@using MP.GameEngine.Helpers.Cards
@model MP.GameEngine.Models.Prompts.PromptTypes.AcknowledgePrompt
@*
    ACKNOWLEDGE PROMPT — server-rendered fragment, shown inside _PlayerProfileView's
    .pp-prompt overlay when this prompt is pending for the player. Single "Okay" that
    submits an empty AcknowledgeResponse via ingame-prompts.js (delegated off
    [data-prompt-submit]). Card-draw acknowledges carry a CardType and are coloured by
    deck; every other acknowledge has a null CardType and falls back to secondary styling.
*@
@{
    // CardColourDisplay returns the colour token (e.g. "card-chance"); compose the Bootstrap
    // utility prefixes off it. Null CardType → secondary, as before.
    var colour = Model.CardType is { } type ? CardDisplayHelper.CardColourDisplay(type, Model.PlayingCard) : "secondary";
}
<div class="pp-prompt-card border border-2 border-@colour">
    <div class="pp-prompt-head text-bg-@colour">@Model.Title</div>
    <div class="pp-prompt-body">
        <p class="mb-0">@Model.Body</p>
    </div>
    <div class="pp-prompt-foot">
        <button type="button" class="btn text-bg-@colour w-100" data-prompt-submit>Okay</button>
    </div>
</div>
