@using JC.Core.Extensions
@using MP.GameEngine.Enums
@using MP.GameEngine.Enums.Cards
@using MP.GameEngine.Enums.Properties
@using MP.GameEngine.Helpers
@using MP.GameEngine.Helpers.Cards
@using MP.GameEngine.Helpers.RuleSet
@using MP.GameEngine.Models.Prompts.PromptTypes
@using MP.GameEngine.Models.Snapshot
@using MP.GameEngine.Models.Snapshot.Cards
@using UltimateMonopoly.Models.ViewModels.Games
@using UltimateMonopoly.Services.Cache
@model PlayerProfilePlayViewModel
@inject PlayerCacheService PlayerCache
@inject MP.GameEngine.Abstractions.ITurnTaxService TurnTaxService
@{
    // The live player-profile body. Rendered on first load (Player/Index) and
    // re-rendered on every SignalR StateChanged frame (Index.OnGetStateAsync →
    // swapped in by player-state.js). All state reads straight off the engine
    // cache, so the live and first-load render paths are identical — mirrors the
    // host _PlayView. See design-docs/Game-UI.md "Player Profile Partial".
    var engine = Model.Engine;
    var cache = engine.Cache;
    var tsp = engine.TurnStateProvider;
    var game = cache.Game;
    var board = cache.Board;
    var rule = cache.RoundingRule;

    var playerId = Model.PlayerId;
    var viewerId = Model.ViewerUserId;

    // Admin read-only render: the game-details page constructs this view model with IsAdminView = true.
    // We force every command gate off (belt-and-braces with that page not loading the game-play hub) and
    // hide the pending prompt. The live game uses the default (false), so behaviour there is unchanged.
    var readOnly = Model.IsAdminView;

    var player = game.GetPlayer(playerId) ?? game.GetPlayer(playerId, true)
        ?? throw new InvalidOperationException($"Player {playerId} not found in game state.");

    // CurrentPlayer() returns null if the current player is bankrupt; tolerate it.
    PlayerModel? current;
    try { current = game.CurrentPlayer(); } catch { current = null; }
    var isCurrent = current is not null && current.PlayerId == playerId;

    var profile = await PlayerCache.GetPlayerProfile(playerId);
    const string cur = RuleDictionary.Currency;

    // Every *computed* money figure shown goes through MoneyHelper so it matches
    // the game's rounding rule (NormaliseAmountToPositive Math.Abs-es, so a
    // cost-context value always reads positive). Exact ledger amounts (a player's
    // Money, a loan's Amount/PaidBack) are shown raw.
    string Cost(long raw, FinancialReason reason) => $"{cur}{MoneyHelper.NormaliseAmountToPositive(raw, rule, reason):N0}";

    // Bootstrap-icon class for a card type — drives the held-card list on the Cards tab.
    string CardIcon(CardType t) => t switch
    {
        CardType.Chance => "bi-question-circle",
        CardType.ComChest => "bi-box2-heart",
        CardType.PercentageChance => "bi-patch-question",
        CardType.PercentageComChest => "bi-patch-question",
        CardType.Third => "bi-dice-3",
        CardType.Double => "bi-dice-2",
        CardType.Triple => "bi-dice-6",
        CardType.Tax => "bi-cash-stack",
        CardType.Go => "bi-flag",
        CardType.JustVisiting => "bi-eye",
        CardType.FreeParking => "bi-p-circle",
        CardType.GoToJail => "bi-lock",
        _ => "bi-card-text"
    };

    // Ownership-state tint for the current-space tile (Block 2), mirroring the board
    // view's .space-body tint (softened via --bs-bg-opacity in the CSS).
    string? StateTint(PropertyState s) => s switch
    {
        PropertyState.NotOwned => "bg-success",
        PropertyState.Owned => "bg-danger",
        PropertyState.Mortgaged => "bg-warning",
        PropertyState.Reserved => "bg-primary",
        PropertyState.FreeParking => "bg-info",
        _ => null
    };

    // Capability gates — host-bypass aware, evaluated for the *viewer* (self or
    // the host). Mock/stub actions still wear their real guards: hidden where the
    // state forbids them, disabled where the doc wants a persistent button.
    var canStart = !readOnly && tsp.CanStartTurn(playerId, viewerId);
    var canEnd = !readOnly && tsp.CanEndTurn(playerId, viewerId);
    var canPortfolio = !readOnly && tsp.CanPortfolioCommand(playerId, viewerId);
    var canLeaveJail = !readOnly && tsp.CanLeaveJail(playerId, viewerId);
    var canBankrupt = !readOnly && tsp.CanDeclareBankruptcy(playerId, viewerId);

    var owned = game.GetOwnedProperties(playerId);
    var mortgaged = owned.Where(p => p.State == PropertyState.Mortgaged).ToList();
    // Sum the shared per-property MoneyHelper.MortgageFee — identical rounding to the engine charge, so display == charge.
    var mortgageFeeRaw = mortgaged.Sum(p => (long)MoneyHelper.MortgageFee(p.BoardIndex, board, rule));

    // Houses/hotels: this player's built count (pass the id) vs the table-wide
    // remaining pool (no id → global). Two distinct figures, per Game-UI.md.
    var (housesBuilt, hotelsBuilt) = game.GetHousesAndHotelsTaken(playerId);
    var (housesLeft, hotelsLeft) = game.GetHousesAndHotelsLeft();
    // Real bulk build/sell guards for the "on all" buttons (still AND-ed with the portfolio gate).
    var canBuildAll = canPortfolio && game.CanIncreaseRentLevelForAll(playerId);
    var canSellAll = canPortfolio && game.CanDecreaseRentLevelForAll(playerId);
    // Cost to build one level on every complete buildable set held — aggregate the
    // per-set build cost over the owned sets (the figure BuildOnAllProperties confirms).
    // 0 when no complete set is held.
    var buildAllSets = PropertySetHelper.GetOwnedSets(playerId,
        game.GetOwnedProperties(playerId, includeMortgaged: false, includeReserved: false));
    var buildAllCostRaw = buildAllSets.Sum(s => PropertySetHelper.GetBuildCost(s, board, engine.Cache.Game.HasStreetEffect(playerId, s)));

    var loans = player.Loans;
    var outstandingLoans = loans.Where(l => l.IsOutstanding).ToList();
    var loanRemaining = outstandingLoans.Sum(l => (long)l.Amount - l.PaidBack);
    // The real GO instalment (10% of outstanding originals) — same value ForcedRepayLoans
    // charges, routed through Cost()/MoneyHelper so the display matches the charge.
    var loanCostRaw = (long)player.MinimumLoanRepayment();

    var fpSets = player.FPHandedInSets.Distinct().ToList();

    // Pending prompt for THIS player, if any — rendered inline below as a server-side
    // overlay. It's part of the swapped state, so it appears/disappears atomically with
    // each StateChanged frame (no client open/close race), and only ever shows for the
    // player this partial renders — so on the host it surfaces only in that player's drawer.
    var pending = cache.PendingPrompt;
    var prompt = pending is not null && pending.Prompt.PlayerId == playerId ? pending.Prompt : null;
    var promptType = prompt switch
    {
        DiceRollPrompt => "DiceRoll",
        AcknowledgePrompt => "Acknowledge",
        AcquirePropertyPrompt => "AcquireProperty",
        AuctionBidPrompt => "AuctionBid",
        ShortfallPrompt => "Shortfall",
        TargetPropertyPrompt => "TargetProperty",
        TargetPlayerPrompt => "TargetPlayer",
        LeaveJailPrompt => "LeaveJail",
        CardOptionPrompt => "CardOption",
        DealPrompt => "Deal",
        BuildDealPrompt => "BuildDeal",
        _ => null
    };
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="pp-view">
            @* ─────────── Engine prompt (server-rendered overlay) ───────────
               The pending prompt for this player renders here as part of the swapped
               state — it appears/disappears atomically with each StateChanged frame
               (no client open/close race). ingame-prompts.js reads data-prompt-* + the
               controls and calls SubmitPrompt. Scoped to the drawer/profile, never the
               whole page. *@
            @if (prompt is not null && promptType is not null && !readOnly)
            {
                <div class="pp-prompt" data-prompt-id="@prompt.PromptId" data-prompt-type="@promptType" data-stamp="@cache.ConcurrencyStamp">
                    @* Hide (don't cancel) — the prompt stays open server-side; this only hides the
                       overlay so the viewer can browse the tabs. Reopen via the floating button
                       below. Backdrop carries the same data hook so tapping the dim area hides too.
                       Wired on both hosts that run this partial — the phone profile and the play
                       page's drawer (prompt-hide.js / player-profile.css scope to each). *@
                    <div class="pp-prompt-backdrop" data-prompt-hide></div>
                    <button type="button" class="btn btn-light pp-prompt-hide" data-prompt-hide
                            aria-label="Hide prompt" title="Hide — reopen from the button above the menu">
                        <i class="bi bi-x-lg"></i>
                    </button>
                    <div class="pp-prompt-dialog">
                        @switch (prompt)
                        {
                            case DiceRollPrompt p:
                                <partial name="~/Areas/Game/Pages/Shared/Play/_DiceRollPrompt.cshtml" model="p" />
                                break;
                            case AcknowledgePrompt p:
                                <partial name="~/Areas/Game/Pages/Shared/Play/_AcknowledgePrompt.cshtml" model="p" />
                                break;
                            case AcquirePropertyPrompt p:
                                <partial name="~/Areas/Game/Pages/Shared/Play/_AcquirePropertyPrompt.cshtml" model="p" />
                                break;
                            case AuctionBidPrompt p:
                                <partial name="~/Areas/Game/Pages/Shared/Play/_AuctionBidPrompt.cshtml" model="p" />
                                break;
                            case ShortfallPrompt p:
                                <partial name="~/Areas/Game/Pages/Shared/Play/_ShortfallPrompt.cshtml" model="p" />
                                break;
                            case TargetPropertyPrompt p:
                                <partial name="~/Areas/Game/Pages/Shared/Play/_TargetPropertyPrompt.cshtml" model="p" />
                                break;
                            case TargetPlayerPrompt p:
                                <partial name="~/Areas/Game/Pages/Shared/Play/_TargetPlayerPrompt.cshtml" model="p" />
                                break;
                            case LeaveJailPrompt p:
                                <partial name="~/Areas/Game/Pages/Shared/Play/_LeaveJailPrompt.cshtml" model="p" />
                                break;
                            case CardOptionPrompt p:
                                <partial name="~/Areas/Game/Pages/Shared/Play/_CardOptionPrompt.cshtml" model="p" />
                                break;
                            case DealPrompt p:
                                <partial name="~/Areas/Game/Pages/Shared/Play/_DealPrompt.cshtml" model="p" />
                                break;
                            case BuildDealPrompt p:
                                <partial name="~/Areas/Game/Pages/Shared/Play/_BuildDealPrompt.cshtml" model="p" />
                                break;
                        }
                    </div>
                </div>

                @* Floating "Open Prompt" bar — pinned full-width above the phone's tab bar or to
                   the drawer's bottom (positioned per host in player-profile.css).
                   Hidden until the viewer dismisses the overlay (prompt-hide.js toggles d-none). *@
                <button type="button" class="btn btn-primary pp-prompt-reopen d-none" data-prompt-open>
                    <i class="bi bi-chat-left-dots-fill me-2"></i>Open Prompt
                </button>
            }

            @* ───────────────── Header (shared across tabs) ───────────────── *@
            <div class="card mb-2">
                <div class="card-body d-flex align-items-center gap-3 py-2">
                    <profile-circle user="profile" size="Lg" />
                    <div class="flex-grow-1 min-w-0">
                        <div class="fw-semibold text-truncate fs-5">
                            @profile.DisplayName
                            @if (player.IsBankrupt)
                            {
                                <span class="badge text-bg-danger ms-1">Bankrupt</span>
                            }
                        </div>
                        <div class="small text-body-secondary d-flex flex-wrap align-items-center gap-2">
                            <span>Dice <span class="badge text-bg-secondary">@player.Dice1 | @player.Dice2</span></span>
                            <span class="fw-semibold text-body">@cur@player.Money.ToString("N0")</span>
                        </div>
                    </div>
                </div>
            </div>

            @* Roll / End turn — only for this player on their own turn (mirrors the
               host turn button), otherwise show whose turn it is. *@
            @if (isCurrent)
            {
                <div class="d-grid mb-2">
                    @if (cache.TurnState == TurnState.StartOfTurn)
                    {
                        <button type="button" class="btn btn-hero-success" data-start-turn disabled="@(!canStart)">
                            <i class="bi bi-dice-5 me-1"></i> Roll Dice
                        </button>
                    }
                    else if (cache.TurnState == TurnState.EndOfTurn)
                    {
                        <button type="button" class="btn btn-hero-danger" data-end-turn disabled="@(!canEnd)">
                            <i class="bi bi-flag-fill me-1"></i> End Turn
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-hero-light" data-end-turn disabled>
                            <i class="bi bi-flag-fill me-1"></i> End Turn
                        </button>
                    }
                </div>
            }
            else
            {
                <div class="card mb-2">
                    <div class="card-body d-flex align-items-center gap-2 py-2">
                        @if (current is not null)
                        {
                            var currentProfile = await PlayerCache.GetPlayerProfile(current.PlayerId);
                            <profile-circle user="currentProfile" size="Md" />
                            <span class="small text-body-secondary">
                                It's <span class="fw-semibold text-body">@currentProfile.DisplayName</span>'s turn
                            </span>
                        }
                        else
                        {
                            <span class="small text-body-secondary">Waiting for the next turn…</span>
                        }
                    </div>
                </div>
            }
            
            @if (player.MissNextTurn)
            {
                <div class="d-grid mb-2">
                    <div class="btn btn-hero-warning">
                        <i class="bi bi-x-octagon-fill me-1"></i>
                        @(player.TurnsToMiss == 1 ? "You are missing your next turn!" : $"You are missing {player.TurnsToMiss} turns!")
                    </div>
                </div>
            }
            else if (player.HasExtraTurns)
            {
                <div class="d-grid mb-2">
                    <div class="btn btn-hero-info">
                        <i class="bi bi-plus-circle-fill me-1"></i>
                        @(player.ExtraTurns == 1 ? "You have an extra turn!" : $"You have an extra {player.ExtraTurns} turns!")
                    </div>
                </div>
            }

            @* ───────────────────────── Tab content ───────────────────────── *@
            <div class="tab-content pp-content">

                @* ===================== Profile ===================== *@
                <div class="tab-pane fade show active" id="pp-profile" role="tabpanel">

                    @switch (player.IsInJail)
                    {
                        case true when canLeaveJail:
                        {
                            <div class="card mb-3">
                                <div class="card-body">
                                    <div class="d-grid gap-2">
                                        @* Leave jail by paying the fee (LeaveJailPay → JailService.LeaveJailByPaying).
                               Guarded by CanLeaveJail; the figure is the grid-rounded charge. *@
                                        <button type="button" class="btn btn-outline-warning py-2" data-leave-jail-pay>
                                            <i class="bi bi-cash-coin me-1"></i> Leave jail — pay @Cost(player.JailCost, FinancialReason.JailFee)
                                        </button>
                                        @* Only when the player holds a Get Out of Jail Free card
                               (LeaveJailCard → CardService.PlayCard). Same CanLeaveJail gate;
                               holding the card is the extra condition. *@
                                        @if (player.GetOutOfJailCard() is { } jailCard)
                                        {
                                            <button type="button" class="btn btn-outline-secondary py-2" data-leave-jail-card data-card-id="@jailCard.CardId">
                                                <i class="bi bi-ticket-perforated me-1"></i> Leave jail — use card
                                            </button>
                                        }
                                    </div>  
                                </div>
                            </div>
                            break;
                        }
                        case true when !canLeaveJail:
                        {
                            // Only when a card lock is the reason they can't leave (MinJailTurns not yet
                            // served) — not merely "it isn't your turn". Remaining = MinJailTurns − counter.
                            if (player is { CanLeaveJail: false, MinJailTurns: { } minTurns })
                            {
                                var lockedTurns = minTurns - player.JailTurnCounter;
                                <div class="card mb-3">
                                    <div class="card-body">
                                        <div class="d-grid">
                                            <div class="btn btn-hero-warning">
                                                <i class="bi bi-lock-fill me-1"></i>
                                                @(lockedTurns <= 1 ? "You cannot leave jail until your next turn" : $"You cannot leave jail for {lockedTurns} turns")
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                            break;
                        }
                    }

                    @* Block 1 — money / jail cost / triple bonus / %cap *@
                    <div class="card mb-3">
                        <div class="card-body">
                            <dl class="row mb-0">
                                <dt class="col-7 text-body-secondary fw-normal"><i class="bi bi-wallet2 me-1"></i> Money</dt>
                                <dd class="col-5 text-end fw-semibold mb-2">@cur@player.Money.ToString("N0")</dd>

                                <dt class="col-7 text-body-secondary fw-normal"><i class="bi bi-building-lock me-1"></i> Jail cost</dt>
                                <dd class="col-5 text-end mb-2">@cur@(MoneyHelper.NormaliseAmountToPositive(player.JailCost, cache.RoundingRule, FinancialReason.JailFee).ToString("N0"))</dd>

                                <dt class="col-7 text-body-secondary fw-normal"><i class="bi bi-dice-3 me-1"></i> Triple bonus</dt>
                                <dd class="col-5 text-end mb-2">@cur@player.TripleBonus.ToString("N0")</dd>

                                <dt class="col-7 text-body-secondary fw-normal"><i class="bi bi-percent me-1"></i> Card %cap</dt>
                                <dd class="col-5 text-end mb-@(TurnTaxService.Enabled ? "2" : "0")">
                                    <span class="badge text-bg-secondary">@(game.PlayerPercentCap(playerId))%</span>
                                </dd>

                                @* Turn tax (D2) — only when enabled. The tax the player would pay on their
                                   current cash at the start of their next roll; routed through Cost() so the
                                   figure matches the (rounded) charge. *@
                                @if (TurnTaxService.Enabled)
                                {
                                    <dt class="col-7 text-body-secondary fw-normal"><i class="bi bi-bank me-1"></i> Wealth tax on roll</dt>
                                    <dd class="col-5 text-end mb-0">@Cost(TurnTaxService.TotalTax(player.Money), FinancialReason.TurnTax)</dd>
                                }
                            </dl>
                        </div>
                    </div>

                    @* Block 2 — current board space: a compact board-style tile for the
                       player's position (colour banner if a property, icon for card/tax,
                       corner/space name otherwise), with the board index in a box beneath. *@
                    @{
                        var nowSpace = board.GetBoardSpace(player.BoardIndex);
                        var nowProp = game.GetPropertySpace(player.BoardIndex);
                        // Current rent on this space (when owned): 0 if mortgaged/reserved,
                        // multiplier for utilities, the rounded rent for the level otherwise.
                        var nowRentText = nowProp is null ? null
                            : nowProp.State is PropertyState.Mortgaged or PropertyState.Reserved
                                ? $"{cur}0"
                                : nowSpace.PropertySet == PropertySet.Utility
                                    ? $"{nowSpace.GetRent(nowProp.RentLevel) ?? 0}× dice"
                                    : $"{cur}{MoneyHelper.NormaliseAmountToPositive(nowSpace.GetRent(nowProp.RentLevel) ?? 0, rule, FinancialReason.Rent):N0}";
                    }
                    <div class="pp-now mb-3">
                        <div class="pp-now-space">
                            @if (nowSpace.PropertySet is { } nowSet)
                            {
                                <div class="pp-now-banner bg-prop-@(nowSet.ToDisplayName().ToSlug())"></div>
                                <div class="pp-now-body @(nowProp is not null ? StateTint(nowProp.State) : null)">
                                    <span class="p-2"><b>@(nowProp?.Name)</b></span>
                                    @if (!string.IsNullOrWhiteSpace(nowProp?.OwnerPlayerId))
                                    {
                                        <span class="p-2"><b>Owner: </b>@(await PlayerCache.GetPlayerName(nowProp.OwnerPlayerId))</span>
                                        <span class="p-2 d-inline-flex align-items-center gap-1">
                                            <b>Rent level:</b> <partial name="~/Areas/Game/Pages/Shared/Play/_RentLevel.cshtml" model="nowProp!.RentLevel" />
                                        </span>
                                        <span class="p-2"><b>Rent:</b> @nowRentText</span>
                                    }
                                </div>
                            }
                            else if (player.BoardIndex.IsChance())
                            {
                                <div class="pp-now-body pp-now-icon">
                                    <i class="bi bi-question-lg"></i>
                                    <span class="p-2">@nowSpace.Name</span>
                                </div>
                            }
                            else if (player.BoardIndex.IsComChest())
                            {
                                <div class="pp-now-body pp-now-icon">
                                    <i class="bi bi-archive-fill"></i>
                                    <span class="p-2">@nowSpace.Name</span>
                                </div>
                            }
                            else if (player.BoardIndex.IsTax())
                            {
                                <div class="pp-now-body pp-now-icon">
                                    <i class="bi bi-bank2"></i>
                                    <span class="p-2">@nowSpace.Name</span>
                                </div>
                            }
                            else
                            {
                                @* Corners (GO / Just Visiting / Free Parking / Go To Jail / Jail). *@
                                <div class="pp-now-body pp-now-corner">@nowSpace.Name</div>
                            }
                        </div>
                        <div class="pp-now-index border text-center">@player.BoardIndex</div>
                    </div>

                    @* Block 3 — Free Parking hand-ins (accordion, count in header) *@
                    <div class="accordion mb-3" id="ppFpAccordion">
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#pp-fp-sets">
                                    Free Parking hand-ins · @fpSets.Count
                                </button>
                            </h2>
                            <div id="pp-fp-sets" class="accordion-collapse collapse" data-bs-parent="#ppFpAccordion">
                                <div class="accordion-body">
                                    @if (fpSets.Count == 0)
                                    {
                                        <div class="text-body-secondary small text-center py-2">No sets handed into Free Parking.</div>
                                    }
                                    else
                                    {
                                        <div class="d-grid gap-2">
                                            @foreach (var s in fpSets)
                                            {
                                                <span class="badge text-bg-prop-@(s.ToDisplayName().ToSlug()) w-100 py-2">@s.ToDisplayName()</span>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    @* Block 3 — declare bankruptcy (disabled unless allowed). Opens the
                       confirmation modal (stable page DOM, outside this live-swapped body) via
                       Bootstrap's delegated toggle, carrying this player's id; bankruptcy.js reads
                       it off relatedTarget and fires GamePlayHub.DeclareBankruptcy on confirm. *@
                    <div class="d-grid">
                        <button type="button" class="btn btn-outline-danger"
                                data-bs-toggle="modal" data-bs-target="#bankruptcyConfirmModal"
                                data-bankrupt-target="@playerId" disabled="@(!canBankrupt)">
                            <i class="bi bi-flag me-1"></i> Declare bankruptcy
                        </button>
                    </div>
                </div>

                @* ===================== Properties ===================== *@
                <div class="tab-pane fade" id="pp-properties" role="tabpanel">

                    @* Block 1 — bank/building summary (all figures real). *@
                    <div class="card mb-3">
                        <div class="card-body">
                            <dl class="row mb-0 small">
                                @if (mortgaged.Count > 0)
                                {
                                    <dt class="col-7 text-body-secondary fw-normal">Mortgage fee at GO</dt>
                                    <dd class="col-5 text-end mb-2">@Cost(mortgageFeeRaw, FinancialReason.MortgageFee)</dd>
                                }
                                <dt class="col-7 text-body-secondary fw-normal">Houses built</dt>
                                <dd class="col-5 text-end mb-2">@housesBuilt</dd>
                                <dt class="col-7 text-body-secondary fw-normal">Houses left</dt>
                                <dd class="col-5 text-end mb-2">@housesLeft</dd>
                                <dt class="col-7 text-body-secondary fw-normal">Hotels built</dt>
                                <dd class="col-5 text-end mb-2">@hotelsBuilt</dd>
                                <dt class="col-7 text-body-secondary fw-normal">Hotels left</dt>
                                <dd class="col-5 text-end mb-2">@hotelsLeft</dd>
                                @* Free-hotel credits (R-06) — each waives the cost of one future hotel build. Shown only when held. *@
                                @if (player.FreeHotels > 0)
                                {
                                    <dt class="col-7 text-body-secondary fw-normal">Free hotels</dt>
                                    <dd class="col-5 text-end mb-2"><span class="badge text-bg-success">@player.FreeHotels</span></dd>
                                }
                                <dt class="col-7 text-body-secondary fw-normal">Cost to build all</dt>
                                @* >0 guard: Cost() bumps a rounded-to-zero figure up to one grid unit, so show £0 directly when no set is held rather than a misleading minimum. *@
                                <dd class="col-5 text-end mb-0">@(buildAllCostRaw > 0 ? Cost(buildAllCostRaw, FinancialReason.Build) : $"{cur}0")</dd>
                            </dl>
                            @* Build/sell-on-all commands (data-cmd → GamePlayHub.BuildAll/SellAll); guarded by CanIncrease/DecreaseRentLevelForAll + the portfolio gate. *@
                            <div class="d-flex gap-2 mt-2">
                                <button type="button" class="btn btn-success btn-sm flex-fill" data-cmd="buildall" disabled="@(!canBuildAll)">
                                    <i class="bi bi-house-add me-1"></i> Build on all
                                </button>
                                <button type="button" class="btn btn-warning btn-sm flex-fill" data-cmd="sellall" disabled="@(!canSellAll)">
                                    <i class="bi bi-house-dash me-1"></i> Sell on all
                                </button>
                            </div>
                        </div>
                    </div>

                    @* Block 2 — owned properties grouped by set *@
                    @if (owned.Count == 0)
                    {
                        <div class="card">
                            <div class="card-body text-center text-body-secondary py-4">
                                <i class="bi bi-houses fs-3 d-block mb-2"></i> You don't own any properties yet.
                            </div>
                        </div>
                    }
                    else
                    {
                        var grouped = owned
                            .Select(p => (Prop: p, Set: PropertySetHelper.ResolveSet(p.BoardIndex)))
                            .Where(x => x.Set is not null)
                            .GroupBy(x => x.Set!.Value)
                            .OrderBy(g => (int)g.Key)
                            .ToList();

                        <div class="accordion" id="ppPropAccordion">
                            @foreach (var grp in grouped)
                            {
                                var set = grp.Key;
                                var slug = set.ToDisplayName().ToSlug();
                                var setIndexes = PropertySetHelper.GetIndexes(set);
                                var ownsAll = grp.Count() == setIndexes.Count;
                                var buildable = set is not (PropertySet.Station or PropertySet.Utility);
                                var buildCost = buildable ? board.GetBoardSpace(grp.First().Prop.BoardIndex).BuildCost : null;
                                var paneId = $"pp-set-{slug}";

                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#@paneId">
                                            <span class="pp-set-dot me-2 bg-prop-@slug"></span>
                                            <span class="flex-grow-1">@set.ToDisplayName()</span>
                                            <span class="badge text-bg-secondary me-2">@grp.Count()/@setIndexes.Count</span>
                                            @if (ownsAll)
                                            {
                                                <span class="badge text-bg-prop-@slug me-2">SET</span>
                                            }
                                        </button>
                                    </h2>
                                    @* Expanded by default (show); no data-bs-parent so every set stays open independently and can be toggled without collapsing the others. *@
                                    <div id="@paneId" class="accordion-collapse collapse show">
                                        <div class="accordion-body">

                                            @if (buildable && ownsAll && buildCost is not null)
                                            {
                                                var bc = (long)buildCost.Value;
                                                var canBuildSet = canPortfolio && game.CanIncreaseRentLevelForAllInSet(playerId, set);
                                                var canSellSet = canPortfolio && game.CanDecreaseRentLevelForAllInSet(playerId, set);
                                                <div class="d-flex justify-content-between align-items-center small mb-2 gap-2">
                                                    <span class="text-body-secondary">
                                                        Build @Cost(bc, FinancialReason.Build) · Double hotel @Cost(bc * 5, FinancialReason.Build)
                                                    </span>
                                                    @* Build/sell-set commands (data-cmd → GamePlayHub.BuildSet/SellSet, carrying a set index); guarded by CanIncrease/DecreaseRentLevelForAllInSet + the portfolio gate. *@
                                                    <div class="d-flex gap-1 flex-shrink-0">
                                                        <button type="button" class="btn btn-success btn-sm" data-cmd="buildset" data-board-index="@setIndexes[0]" disabled="@(!canBuildSet)">Build set</button>
                                                        <button type="button" class="btn btn-warning btn-sm" data-cmd="sellset" data-board-index="@setIndexes[0]" disabled="@(!canSellSet)">Sell set</button>
                                                    </div>
                                                </div>
                                            }

                                            <div class="d-grid gap-2">
                                                @foreach (var x in grp.OrderBy(x => x.Prop.BoardIndex))
                                                {
                                                    var prop = x.Prop;
                                                    var space = board.GetBoardSpace(prop.BoardIndex);
                                                    var purchase = (long)(space.PurchaseCost ?? 0);
                                                    var built = prop.BuiltOn();
                                                    // Rent shown now: 0 when mortgaged/reserved; utilities are dice-multiplied
                                                    // (show the multiplier); otherwise the rounded rent for the current level.
                                                    var rentText = prop.State is PropertyState.Mortgaged or PropertyState.Reserved
                                                        ? $"{cur}0"
                                                        : space.PropertySet == PropertySet.Utility
                                                            ? $"{space.GetRent(prop.RentLevel) ?? 0}× dice"
                                                            : $"{cur}{MoneyHelper.NormaliseAmountToPositive(space.GetRent(prop.RentLevel) ?? 0, rule, FinancialReason.Rent):N0}";

                                                    <div class="pp-space border border-prop-@slug">
                                                        <div class="pp-space-head text-bg-prop-@slug">
                                                            <span class="text-truncate">@space.Name</span>
                                                            @if (prop.State == PropertyState.Mortgaged)
                                                            {
                                                                <span class="badge text-bg-warning">Mortgaged</span>
                                                            }
                                                            else if (prop.State == PropertyState.Reserved)
                                                            {
                                                                <span class="badge text-bg-info">Reserved</span>
                                                            }
                                                            @* Purge state — currently purged (buildings stripped, rent reset to SET). *@
                                                            @if (prop.IsPurged)
                                                            {
                                                                <span class="badge text-bg-danger">Purged</span>
                                                            }
                                                        </div>
                                                        <div class="pp-space-body">
                                                            <div class="d-flex align-items-center justify-content-between small mb-1">
                                                                <span class="text-body-secondary">Rent level:</span>
                                                                <partial name="~/Areas/Game/Pages/Shared/Play/_RentLevel.cshtml" model="prop.RentLevel" />
                                                            </div>
                                                            <div class="small mb-2">
                                                                <span class="text-body-secondary">Rent:</span>
                                                                <span class="fw-semibold">@rentText</span>
                                                            </div>
                                                            <div class="small mb-2">
                                                                @if (prop.State == PropertyState.Reserved)
                                                                {
                                                                    @* Un-reserve = full purchase price (real — Reserved Properties rule 4). *@
                                                                    <span class="text-body-secondary">Un-reserve:</span>
                                                                    <span class="fw-semibold">@Cost(purchase, FinancialReason.UnReserve)</span>
                                                                }
                                                                else if (prop.State == PropertyState.Mortgaged)
                                                                {
                                                                    @* Real un-mortgage cost = mortgage value + 10%, grid-rounded (MoneyHelper). *@
                                                                    <span class="text-body-secondary">Unmortgage:</span>
                                                                    <span class="fw-semibold">@cur@MoneyHelper.UnMortgageCost(prop.BoardIndex, board, rule).ToString("N0")</span>
                                                                }
                                                                else
                                                                {
                                                                    @* Real mortgage payout = half purchase price, grid-rounded (MoneyHelper). *@
                                                                    <span class="text-body-secondary">Mortgage:</span>
                                                                    <span class="fw-semibold">@cur@MoneyHelper.MortgageValue(prop.BoardIndex, board, rule).ToString("N0")</span>
                                                                }
                                                            </div>
                                                            <div class="d-flex flex-wrap gap-1">
                                                                @* Per-property build/sell (data-cmd → GamePlayHub.BuildProperty/SellProperty); enabled only when the real build/sell + portfolio gates allow. *@
                                                                @if (buildable && ownsAll)
                                                                {
                                                                    <button type="button" class="btn btn-success btn-sm" data-cmd="build" data-board-index="@prop.BoardIndex" disabled="@(!(canPortfolio && game.CanIncreaseRentLevel(playerId, prop.BoardIndex)))">Build</button>
                                                                    <button type="button" class="btn btn-warning btn-sm" data-cmd="sell" data-board-index="@prop.BoardIndex" disabled="@(!(canPortfolio && game.CanDecreaseRentLevel(playerId, prop.BoardIndex)))">Sell</button>
                                                                }
                                                                @* Live commands (engine built) — carry data-cmd + board index; the
                                                                   page JS invokes the matching GamePlayHub method, which opens an
                                                                   AcquirePropertyPrompt confirmation. *@
                                                                @if (prop.State == PropertyState.Reserved)
                                                                {
                                                                    <button type="button" class="btn btn-info btn-sm" data-cmd="unreserve" data-board-index="@prop.BoardIndex" disabled="@(!canPortfolio)">Un-reserve</button>
                                                                }
                                                                else if (prop.State == PropertyState.Mortgaged)
                                                                {
                                                                    <button type="button" class="btn btn-outline-secondary btn-sm" data-cmd="unmortgage" data-board-index="@prop.BoardIndex" disabled="@(!canPortfolio)">Unmortgage</button>
                                                                }
                                                                else if (!built)
                                                                {
                                                                    <button type="button" class="btn btn-danger btn-sm" data-cmd="mortgage" data-board-index="@prop.BoardIndex" disabled="@(!canPortfolio)">Mortgage</button>
                                                                }
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                @* ===================== Cards ===================== *@
                <div class="tab-pane fade" id="pp-cards" role="tabpanel">
                    @{
                        // Three lists off PlayerModel, each grouped/ordered by card type:
                        //  1) Get out of jail   2) Playable now (turn-start / on-landing)   3) Triggered.
                        // A get-out-of-jail card is OnInJail-triggered, so it also matches GetOtherCards();
                        // exclude it from the triggered list so it appears once, under its own section.
                        var jailCards = player.GetOutOfJailCards().OrderBy(c => c.CardType).ToList();
                        var jailIds = jailCards.Select(c => c.CardId).ToHashSet();
                        var playableCards = player.GetPlayableCards().OrderBy(c => c.CardType).ToList();
                        var triggeredCards = player.GetOtherCards()
                            .Where(c => !jailIds.Contains(c.CardId))
                            .OrderBy(c => c.CardType).ToList();

                        // Shared card chrome — icon, dynamic text, deck-coloured badge, and (right) the
                        // condition type + trigger(s). A play button (where applicable) is appended per section.
                        Func<CardModel, object> cardChrome =
                            @<div class="d-flex align-items-start gap-3">
                                <i class="bi @CardIcon(item.CardType) fs-3 text-body-secondary"></i>
                                <div class="flex-grow-1">
                                    <p class="mb-2">@item.GetDisplayText(engine.Cache, playerId)</p>
                                    <span class="badge text-bg-@CardDisplayHelper.CardColourDisplay(item.CardType)">@item.CardType.ToDisplayName()</span>
                                </div>
                                <div class="text-end small text-body-secondary flex-shrink-0">
                                    <div class="fw-semibold">@item.ConditionDisplay()</div>
                                    <div>@item.CardTriggerDisplay()</div>
                                </div>
                            </div>;
                    }

                    @if (player.Cards.Count == 0)
                    {
                        <div class="card">
                            <div class="card-body text-center text-body-secondary py-4">
                                <i class="bi bi-card-text fs-3 d-block mb-2"></i> You have no cards.
                            </div>
                        </div>
                    }
                    else
                    {
                        @* 1) Get out of jail — Play routes to LeaveJailCard with this card's id; enabled only
                           when the player can leave jail (in jail, their turn start, can-leave, idle). *@
                        @if (jailCards.Count > 0)
                        {
                            <h6 class="text-body-secondary mb-2"><i class="bi bi-ticket-perforated me-1"></i> Get out of jail</h6>
                            foreach (var card in jailCards)
                            {
                                <div class="card mb-2">
                                    <div class="card-body">
                                        @cardChrome(card)
                                        <div class="d-grid mt-3">
                                            <button type="button" class="btn btn-outline-secondary btn-sm" data-leave-jail-card data-card-id="@card.CardId" disabled="@(!canLeaveJail)">
                                                <i class="bi bi-box-arrow-right me-1"></i> Leave jail — use card
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        }

                        @* 2) Playable now — Play routes to PlayCard with this card's id; enabled only at the
                           player's own turn start (CanPortfolioCommand). The engine also offers these on landing. *@
                        @if (playableCards.Count > 0)
                        {
                            <h6 class="text-body-secondary mb-2 mt-3"><i class="bi bi-play-circle me-1"></i> Playable</h6>
                            foreach (var card in playableCards)
                            {
                                <div class="card mb-2">
                                    <div class="card-body">
                                        @cardChrome(card)
                                        <div class="d-grid mt-3">
                                            <button type="button" class="btn btn-outline-primary btn-sm" data-play-card data-card-id="@card.CardId" disabled="@(!canPortfolio)">
                                                <i class="bi bi-play-circle me-1"></i> Play
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        }

                        @* 3) Triggered — fire only when their trigger is met; no manual play. *@
                        @if (triggeredCards.Count > 0)
                        {
                            <h6 class="text-body-secondary mb-2 mt-3"><i class="bi bi-lightning-charge me-1"></i> Triggered</h6>
                            foreach (var card in triggeredCards)
                            {
                                <div class="card mb-2">
                                    <div class="card-body">
                                        @cardChrome(card)
                                    </div>
                                </div>
                            }
                        }
                    }
                </div>

                @* ===================== Loans ===================== *@
                <div class="tab-pane fade" id="pp-loans" role="tabpanel">
                    <div class="card mb-3">
                        <div class="card-body">
                            <dl class="row mb-2 small">
                                <dt class="col-7 text-body-secondary fw-normal">Outstanding loans</dt>
                                <dd class="col-5 text-end mb-2">@outstandingLoans.Count / 3</dd>
                                @if (outstandingLoans.Count > 0)
                                {
                                    <dt class="col-7 text-body-secondary fw-normal">Total still owed</dt>
                                    <dd class="col-5 text-end mb-2">@cur@loanRemaining.ToString("N0")</dd>
                                    <dt class="col-7 text-body-secondary fw-normal">Repayment at GO</dt>
                                    <dd class="col-5 text-end mb-0">@Cost(loanCostRaw, FinancialReason.LoanRepay)</dd>
                                }
                            </dl>
                            @* Custom repayment (Loans rule 7) — pays the oldest loan first, cascading.
                               Loans are only ever taken to cover a shortfall, so there's no voluntary
                               "take out a loan" action. Gated by the portfolio command window. *@
                            @if (outstandingLoans.Count > 0)
                            {
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text">@cur</span>
                                    <input type="number" class="form-control" data-loan-amount min="0" step="50" placeholder="Amount to repay" />
                                    <button type="button" class="btn btn-outline-secondary" data-loan-repay disabled="@(!canPortfolio)">
                                        <i class="bi bi-coin me-1"></i> Repay
                                    </button>
                                </div>
                            }
                        </div>
                    </div>

                    @if (loans.Count == 0)
                    {
                        <div class="card">
                            <div class="card-body text-center text-body-secondary py-4">
                                <i class="bi bi-bank fs-3 d-block mb-2"></i> No loans taken.
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="card">
                            <div class="table-responsive">
                                <table class="table table-sm mb-0 align-middle">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th class="text-end">Borrowed</th>
                                            <th class="text-end">Paid</th>
                                            <th class="text-end">Outstanding</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{ var li = 0; }
                                        @foreach (var loan in loans)
                                        {
                                            li++;
                                            var rem = (long)loan.Amount - loan.PaidBack;
                                            <tr class="@(loan.IsOutstanding ? null : "text-body-secondary")">
                                                <td>@li</td>
                                                <td class="text-end">@cur@loan.Amount.ToString("N0")</td>
                                                <td class="text-end">@cur@loan.PaidBack.ToString("N0")</td>
                                                <td class="text-end">@(loan.IsOutstanding ? $"{cur}{rem:N0}" : "Paid")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                </div>

                @* ===================== Deal ===================== *@
                <div class="tab-pane fade" id="pp-deal" role="tabpanel">
                    @{
                        // One CanDeal gate covers every candidate — it's about this player being at a
                        // turn boundary / engine idle (host-bypass aware), not about the counter party.
                        var canDeal = tsp.CanDeal(playerId, viewerId);
                        // Other active players, clockwise from this player (bankrupt excluded).
                        var dealCandidates = game.GetPlayers(playerId);
                    }

                    @* Block 1 — pick a player to deal with. deal-tab.js hides this and reveals the
                       chosen player's builder (Block 2) on click; Cancel reverses it. *@
                    <div data-deal-list>
                        @if (dealCandidates.Count == 0)
                        {
                            <div class="card">
                                <div class="card-body text-center text-body-secondary py-4">
                                    <i class="bi bi-people fs-3 d-block mb-2"></i> No one to deal with.
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="small text-body-secondary mb-2">Select a player to deal with:</div>
                            <div class="list-group">
                                @foreach (var cand in dealCandidates)
                                {
                                    var candProfile = await PlayerCache.GetPlayerProfile(cand.PlayerId);
                                    @* In admin read-only we keep the pick clickable so the moderator can inspect each
                                       counterparty's builder — the Offer button below is what's disabled. *@
                                    <button type="button" class="list-group-item list-group-item-action d-flex align-items-center gap-3"
                                            data-deal-target="@cand.PlayerId" disabled="@(!readOnly && !canDeal)">
                                        <profile-circle user="candProfile" size="Md" />
                                        <div class="flex-grow-1 min-w-0 text-start">
                                            <div class="fw-semibold text-truncate">@candProfile.DisplayName</div>
                                            <div class="small text-body-secondary">
                                                Dice <span class="badge text-bg-secondary">@cand.Dice1 | @cand.Dice2</span>
                                            </div>
                                        </div>
                                        <span class="fw-semibold">@cur@cand.Money.ToString("N0")</span>
                                    </button>
                                }
                            </div>
                        }
                    </div>

                    @* Block 2 — one deal builder per candidate, hidden until its player is picked.
                       Pre-rendered (correct per-counter-party pools/balances from the cache); the
                       partial's ids are counter-party-scoped so the instances don't collide. *@
                    @foreach (var cand in dealCandidates)
                    {
                        <div class="d-none" data-deal-block="@cand.PlayerId">
                            <partial name="~/Areas/Game/Pages/Shared/Play/_MakeDealPartial.cshtml" model="new MakeDealViewModel(cache.GameId, playerId, cand.PlayerId)" />
                            <div class="d-grid gap-2 mt-2">
                                @* Offer Deal — stub for now; will call the deal command (run the deal). *@
                                <button type="button" class="btn btn-hero-primary" data-deal-offer data-counterparty-id="@cand.PlayerId" disabled="@readOnly">
                                    <i class="bi bi-arrow-left-right me-1"></i> Offer Deal
                                </button>
                                <button type="button" class="btn btn-hero-danger" data-deal-cancel>
                                    <i class="bi bi-x-lg me-1"></i> Cancel
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>

            @* ───────────────── Bottom tab bar (glassy, sticky, icon-only) ───────────────── *@
            <nav class="pp-tabbar" role="tablist" aria-label="Profile sections">
                <button class="pp-tab active" data-bs-toggle="pill" data-bs-target="#pp-profile" type="button" role="tab" title="Profile" aria-label="Profile"><i class="bi bi-person-fill"></i></button>
                <button class="pp-tab" data-bs-toggle="pill" data-bs-target="#pp-properties" type="button" role="tab" title="Properties" aria-label="Properties"><i class="bi bi-houses-fill"></i></button>
                <button class="pp-tab" data-bs-toggle="pill" data-bs-target="#pp-cards" type="button" role="tab" title="Cards" aria-label="Cards"><i class="bi bi-card-text"></i></button>
                <button class="pp-tab" data-bs-toggle="pill" data-bs-target="#pp-loans" type="button" role="tab" title="Loans" aria-label="Loans"><i class="bi bi-cash-coin"></i></button>
                <button class="pp-tab" data-bs-toggle="pill" data-bs-target="#pp-deal" type="button" role="tab" title="Deal" aria-label="Deal"><i class="bi bi-arrow-left-right"></i></button>
            </nav>

        </div>
    </div>
</div>