@using JC.Core.Extensions
@using MP.GameEngine.Helpers
@using MP.GameEngine.Models.Prompts.PromptTypes
@model AcquirePropertyPrompt
@{
    var set = PropertySetHelper.ResolveSet(Model.BoardIndex);
    var slug = set?.ToDisplayName().ToSlug();
    var headClass = slug is not null ? $"text-bg-prop-{slug}" : "text-bg-primary";
    var borderClass = slug is not null ? $"border-prop-{slug}" : "border-primary";

    // Accept / decline wording per action type (computed server-side now — the
    // old client-side map is gone with the modal handler).
    var (accept, decline) = Model.Type switch
    {
        AcquirePropertyType.Buy => ("Buy", "Auction"),
        AcquirePropertyType.Reserve => ("Reserve", "Ignore"),
        AcquirePropertyType.UnReserve => ("Un-reserve", "Cancel"),
        AcquirePropertyType.Mortgage => ("Mortgage", "Cancel"),
        AcquirePropertyType.UnMortgage => ("Unmortgage", "Cancel"),
        AcquirePropertyType.Build => ("Build", "Cancel"),
        AcquirePropertyType.BuildAllInSet => ("Build set", "Cancel"),
        AcquirePropertyType.BuildAll => ("Build all", "Cancel"),
        AcquirePropertyType.Sell => ("Sell", "Cancel"),
        AcquirePropertyType.SellAllInSet => ("Sell set", "Cancel"),
        AcquirePropertyType.SellAll => ("Sell all", "Cancel"),
        _ => ("Confirm", "Cancel")
    };
}
@*
    ACQUIRE-PROPERTY PROMPT — server-rendered fragment. Binary confirm/decline for any
    property action (Type drives the wording). Coloured by the property's set.
    ingame-prompts.js submits AcquirePropertyResponse { accept }: [data-prompt-submit]
    = accept (true), [data-prompt-decline] = decline (false).
*@
<div class="pp-prompt-card border border-2 @borderClass">
    <div class="pp-prompt-head @headClass">@Model.Title</div>
    <div class="pp-prompt-body">
        <p class="mb-0">@Model.Body</p>
    </div>
    <div class="pp-prompt-foot d-flex gap-2">
        <button type="button" class="btn btn-outline-secondary flex-fill" data-prompt-decline>@decline</button>
        <button type="button" class="btn btn-primary flex-fill" data-prompt-submit>@accept</button>
    </div>
</div>
