@*
    HOST CONTROL PANEL — a "bottom sheet" of host-only game controls, opened by the
    trigger bar at the bottom of the screen or by swiping up from the bottom edge
    (host-panel.js). Lives in stable page DOM (included OUTSIDE the live-swapped
    .play-page), so a StateChanged re-render can't strand the panel or an open modal —
    same reasoning as the bankruptcy modal / the move off Bootstrap modals for prompts.

    Each action confirms via its own modal, then invokes the matching GamePlayHub method
    (host-gated server-side).
*@

@* Trigger bar pinned to the bottom of the screen (swipe up / tap to open). *@
<button type="button" class="host-panel-trigger" data-host-panel-open aria-label="Open host controls">
    <i class="bi bi-chevron-up"></i>
</button>

<div class="host-panel-backdrop" data-host-panel-backdrop></div>
<div class="host-panel" data-host-panel aria-hidden="true">
    <div class="app-page py-3">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h2 class="h6 mb-0"><i class="bi bi-sliders me-2"></i>Host Controls</h2>
            <button type="button" class="btn btn-sm btn-outline-secondary" data-host-panel-close aria-label="Close controls">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div class="row g-3">
            @* Force Refresh *@
            <div class="col-6 col-md-3">
                <div class="host-action">
                    <span class="host-action-ico text-warning"><i class="bi bi-arrow-clockwise"></i></span>
                    <div class="fw-semibold mb-1">Force Refresh</div>
                    <p class="small text-body-secondary host-action-desc">Reload every connected device from the latest saved state.</p>
                    <div class="d-grid">
                        <button type="button" class="btn btn-warning" data-bs-toggle="modal" data-bs-target="#forceRefreshConfirmModal">Force Refresh</button>
                    </div>
                </div>
            </div>

            @* Declare Winner *@
            <div class="col-6 col-md-3">
                <div class="host-action">
                    <span class="host-action-ico text-success"><i class="bi bi-trophy-fill"></i></span>
                    <div class="fw-semibold mb-1">Declare Winner</div>
                    <p class="small text-body-secondary host-action-desc">End now — the player with the highest net worth wins; all others go bankrupt.</p>
                    <div class="d-grid">
                        <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#declareWinnerConfirmModal">Declare Winner</button>
                    </div>
                </div>
            </div>

            @* Draw Game *@
            <div class="col-6 col-md-3">
                <div class="host-action">
                    <span class="host-action-ico text-info"><i class="bi bi-people-fill"></i></span>
                    <div class="fw-semibold mb-1">Draw Game</div>
                    <p class="small text-body-secondary host-action-desc">End now as a draw — every remaining player shares the result.</p>
                    <div class="d-grid">
                        <button type="button" class="btn btn-info" data-bs-toggle="modal" data-bs-target="#drawGameConfirmModal">Draw Game</button>
                    </div>
                </div>
            </div>

            @* Cancel Game *@
            <div class="col-6 col-md-3">
                <div class="host-action">
                    <span class="host-action-ico text-danger"><i class="bi bi-x-octagon-fill"></i></span>
                    <div class="fw-semibold mb-1">Cancel Game</div>
                    <p class="small text-body-secondary host-action-desc">Abandon the game entirely — no winner, nothing recorded.</p>
                    <div class="d-grid">
                        <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#cancelGameConfirmModal">Cancel Game</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* ── Confirmation modals (stable DOM) ── *@

<div class="modal fade" id="forceRefreshConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-warning">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title"><i class="bi bi-arrow-clockwise me-2"></i>Force refresh?</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">
                    This forces <strong>every connected device</strong> — the host and all players' phones —
                    to reload the game from the latest saved state. Use it if the game looks stuck or out of sync.
                    No game progress is lost.
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning" data-host-action="force-refresh">
                    <i class="bi bi-arrow-clockwise me-1"></i> Force refresh
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="declareWinnerConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-success">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="bi bi-trophy-fill me-2"></i>Declare a winner?</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">
                    This ends the game <strong>now</strong>. The remaining player with the
                    <strong>highest net worth</strong> is declared the winner, and <strong>every other player
                    is bankrupted</strong>. The game is recorded as finished and everyone is taken to the
                    results page. This <strong>cannot be undone</strong>.
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                @* host-panel.js wires data-host-action="declare-winner" → GamePlayHub.DeclareWinner
                   (highest net worth wins, the rest bankrupted via BankruptcyService.DeclareWinnerViaNetWorth). *@
                <button type="button" class="btn btn-success" data-host-action="declare-winner">
                    <i class="bi bi-trophy-fill me-1"></i> Declare winner
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="drawGameConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-info">
            <div class="modal-header bg-info text-dark">
                <h5 class="modal-title"><i class="bi bi-people-fill me-2"></i>Draw the game?</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">
                    This ends the game <strong>now as a draw</strong>. Every remaining (non-bankrupt) player
                    shares the result, the game is recorded as finished, and everyone is taken to the results page.
                    This <strong>cannot be undone</strong>.
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-info" data-host-action="draw">
                    <i class="bi bi-people-fill me-1"></i> Draw game
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="cancelGameConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-danger">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-x-octagon-fill me-2"></i>Cancel the game?</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">
                    This <strong>abandons the game entirely</strong> — no winner, no draw, nothing recorded.
                    The game is cancelled and everyone is returned to the home page. This <strong>cannot be undone</strong>.
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Keep playing</button>
                @* Cancel is a plain POST to the Play page (ambient gameId route) — the handler
                   cancels + tears down the runtime and broadcasts GameCancelled so the other
                   clients redirect home; this host follows the POST redirect. *@
                <form method="post" asp-page-handler="Cancel" class="m-0">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-x-octagon-fill me-1"></i> Cancel game
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>