@model MP.GameEngine.Models.Prompts.PromptTypes.DiceRollPrompt
@{
    var count = Model.DiceCount is >= 1 and <= 3 ? Model.DiceCount : (ushort)3;
}
@*
    DICE-ROLL PROMPT — server-rendered fragment. Renders DiceCount dice (1 → Die 1,
    2 → Die 1 + Die 2, 3 → + Third die). ingame-prompts.js reads the checked radio in
    each [data-die] group on [data-prompt-submit] and submits a DiceRollResponse
    (data-die "1"/"2"/"3" → Die1/Die2/ThirdDie). Primary card styling.
*@
<div class="pp-prompt-card border border-primary border-2">
    <div class="pp-prompt-head text-bg-primary">
        <i class="bi bi-dice-5 me-1"></i> @(string.IsNullOrEmpty(Model.Title) ? "Roll the dice" : Model.Title)
    </div>
    <div class="pp-prompt-body">
        @if (!string.IsNullOrEmpty(Model.Body))
        {
            <p class="text-body-secondary">@Model.Body</p>
        }
        @for (ushort d = 1; d <= count; d++)
        {
            <div class="mb-3">
                <label class="form-label">@(d == 3 ? "Third die" : $"Die {d}")</label>
                <div class="btn-group d-flex" role="group" data-die="@d">
                    @for (ushort i = 1; i <= 6; i++)
                    {
                        <input type="radio" class="btn-check" name="pp-die-@d" id="pp-die-@d-@i" value="@i" autocomplete="off" />
                        <label class="btn btn-outline-primary" for="pp-die-@d-@i">@i</label>
                    }
                </div>
            </div>
        }
        <div class="alert alert-warning d-none mb-0" data-prompt-error role="alert"></div>
    </div>
    <div class="pp-prompt-foot">
        <button type="button" class="btn btn-primary w-100" data-prompt-submit>
            <i class="bi bi-dice-5 me-1"></i> Roll
        </button>
    </div>
</div>
