@using JC.Core.Extensions
@using MP.GameEngine.Enums.Properties
@using MP.GameEngine.Helpers
@using MP.GameEngine.Helpers.RuleSet
@using UltimateMonopoly.Helpers
@using UltimateMonopoly.Models.ViewModels.Games
@using UltimateMonopoly.Services.Cache
@model BoardViewModel
@inject PlayerCacheService PlayerCache
@{
    // Live ownership state keyed by board index. A space is "ownable" (banner +
    // state tint, no text label) iff it has a PropertySet; everything else
    // (corners, tax, card spaces) shows its name as text.
    var propsByIndex = Model.Properties.ToDictionary(p => p.BoardIndex);

    // Players grouped by the space they occupy. One counter renders per space
    // (the first occupant); any others are tallied on the space's outer edge.
    var playersByIndex = Model.Players
        .GroupBy(pl => pl.Model.BoardIndex)
        .ToDictionary(g => g.Key, g => g.ToList());

    var c = RuleDictionary.Currency;

    // One property sitting in Free Parking, shown as a card in the centre. Usually
    // there's exactly one; first-or-default covers the none / rare >1 cases.
    var fpProp = Model.Properties.FirstOrDefault(p => p.State == PropertyState.FreeParking);
}

@* ─── Board ───────────────────────────────────────────────────────────────
   Square 13×13 grid sized off the container's height (see Game-UI.md). Each
   cell carries data-board-index so the live layer can re-colour it from the
   StateChanged broadcast. Ownable spaces show a colour banner (inward edge,
   shared .bg-prop-* palette) + an ownership-state tint; corners and
   non-property spaces show a text label.                                       *@
<div class="board-view">
    <div class="board-grid">
        @foreach (var space in Model.Board.Spaces
            .Where(s => s.Index < IndexHelper.PhysicalBoardSize)
            .OrderBy(s => s.Index))
        {
            var cell = BoardLayoutHelper.GetCell(space.Index);
            var isCorner = cell.Side == BoardSide.Corner;
            var ownable = space.IsPurchasable;
            propsByIndex.TryGetValue(space.Index, out var prop);
            playersByIndex.TryGetValue(space.Index, out var spacePlayers);

            // Tooltip on properties + tax only — not corners, not card spaces.
            string? tipTitle = null, tipContent = null;
            if (ownable)
            {
                tipTitle = space.Name;
                var owner = string.IsNullOrEmpty(prop?.OwnerPlayerId) ? "Available" : await PlayerCache.GetPlayerName(prop.OwnerPlayerId);
                tipContent = $"Cost: {RuleDictionary.Currency}{space.PurchaseCost}";
                if (space.IsBuildable)
                    tipContent += $"\nBuild: {RuleDictionary.Currency}{space.BuildCost}";
                tipContent += $"\nOwner: {owner}";

                // Rent level + current rent — only once owned (mortgaged/reserved show level too,
                // but rent is 0). Utilities are dice-multiplied, so show the multiplier.
                if (prop is not null && !string.IsNullOrEmpty(prop.OwnerPlayerId))
                {
                    var rentText = prop.State is PropertyState.Mortgaged or PropertyState.Reserved
                        ? $"{RuleDictionary.Currency}0"
                        : space.PropertySet == PropertySet.Utility
                            ? $"{space.GetRent(prop.RentLevel) ?? 0}× dice"
                            : $"{RuleDictionary.Currency}{space.GetRent(prop.RentLevel) ?? 0}";
                    tipContent += $"\nRent level: {RentLevelName(prop.RentLevel)}\nRent: {rentText}";
                }
            }
            else if (space.IsTaxable)
            {
                tipTitle = space.Name;
                tipContent = $"Tax: {RuleDictionary.Currency}{space.Tax}";
            }
            var hasTip = tipContent is not null;

            var propClass = PropClass(space.PropertySet);
            var stateClass = ownable && prop is not null ? StateClass(prop.State) : null;

            <div class="board-space @SideClass(cell.Side) @(isCorner ? "is-corner" : null)"
                 style="grid-column: @cell.Column / span @cell.ColumnSpan; grid-row: @cell.Row / span @cell.RowSpan;"
                 data-board-index="@space.Index"
                 tabindex="@(hasTip ? "0" : null)"
                 role="@(hasTip ? "button" : null)"
                 data-bs-toggle="@(hasTip ? "popover" : null)"
                 data-bs-trigger="@(hasTip ? "focus" : null)"
                 data-bs-custom-class="@(hasTip ? "board-popover" : null)"
                 data-bs-title="@tipTitle"
                 data-bs-content="@tipContent">
                @if (ownable)
                {
                    <div class="space-banner @propClass"></div>
                    <div class="space-body @stateClass"></div>

                    @* Rent level — building squares for built levels (max 2 per row), else a
                       lettered badge. Sits under the player chips (lower z-index). *@
                    @if (prop is not null && prop.State == PropertyState.Owned)
                    {
                        var rentVisual = RentLevelVisual(prop.RentLevel);
                        <div class="space-buildings" aria-hidden="true">
                            @if (rentVisual.Badge is not null)
                            {
                                <span class="rent-badge">@rentVisual.Badge</span>
                            }
                            else
                            {
                                <div class="space-buildings-inner">
                                    @for (var b = 0; b < rentVisual.Houses; b++)
                                    {
                                        <span class="building building--house"></span>
                                    }
                                    @for (var b = 0; b < rentVisual.Hotels; b++)
                                    {
                                        <span class="building building--hotel"></span>
                                    }
                                </div>
                            }
                        </div>
                    }
                }
                else if (isCorner && space.Index == IndexHelper.JustVisitingSpace)
                {
                    // Bottom-left corner. "Just Visiting" runs along the outer edges; the
                    // diagonal "In Jail" triangle sits in the inner corner (top-right, facing
                    // the centre — beside Pentonville Road and Pall Mall). Jailed players
                    // (BoardIndex == JailSpace, 100) render inside the triangle.
                    playersByIndex.TryGetValue(IndexHelper.JailSpace, out var jailPlayers);
                    <div class="jail-tri" aria-hidden="true"></div>
                    <div class="space-label jv-visiting-label">@space.Name</div>
                    <div class="jail-zone">
                        <span class="jail-zone__label">Jail</span>
                        @if (jailPlayers is { Count: > 0 })
                        {
                            <div class="jail-zone__counters">
                                <partial name="Play/_PlayerCounter" model="(jailPlayers[0].Profile, jailPlayers[0].Model.Direction)" />
                            </div>
                            if (jailPlayers.Count > 1)
                            {
                                <span class="jail-zone__extra">@jailPlayers.Count</span>
                            }
                        }
                    </div>
                }
                else if (isCorner)
                {
                    <div class="space-label">@space.Name</div>
                }
                else if (space.Index.IsChance())
                {
                    <div class="space-icon" title="@space.Name"><i class="bi bi-question-lg"></i></div>
                }
                else if (space.Index.IsComChest())
                {
                    <div class="space-icon" title="@space.Name"><i class="bi bi-archive-fill"></i></div>
                }
                else if (space.Index.IsTax())
                {
                    <div class="space-icon" title="@space.Name"><i class="bi bi-bank2"></i></div>
                }
                else
                {
                    <div class="space-label">@space.Name</div>
                }

                @if (spacePlayers is { Count: > 0 })
                {
                    <div class="space-counters">
                        <partial name="Play/_PlayerCounter" model="(spacePlayers[0].Profile, spacePlayers[0].Model.Direction)" />
                    </div>
                    if (spacePlayers.Count > 1)
                    {
                        <span class="space-counter-extra @CounterEdgeClass(cell)">@(spacePlayers.Count)</span>
                    }
                }
            </div>
        }

        @* Centre — a state-colour key (top), the Free Parking pot, and a card for one
           property held in Free Parking (hidden when there are none). *@
        <div class="board-centre" style="grid-column: 3 / span 9; grid-row: 3 / span 9;">
            @* Key — what the rectangle tints mean (mirrors StateClass). *@
            <div class="board-key">
                <span class="board-key__item"><span class="board-key__dot bg-success"></span>Available</span>
                <span class="board-key__item"><span class="board-key__dot bg-danger"></span>Owned</span>
                <span class="board-key__item"><span class="board-key__dot bg-warning"></span>Mortgaged</span>
                <span class="board-key__item"><span class="board-key__dot bg-primary"></span>Reserved</span>
                <span class="board-key__item"><span class="board-key__dot bg-info"></span>Free Parking</span>
            </div>

            <div class="fp-centre">
                <div class="fp-label">Free Parking</div>
                <div class="fp-pot">@c@Model.FreeParkingAmount</div>

                @if (fpProp is not null)
                {
                    var fpSpace = Model.Board.GetBoardSpace(fpProp.BoardIndex);
                    <div class="fp-prop-card">
                        <div class="fp-prop-card__banner @PropClass(fpSpace.PropertySet)"></div>
                        <div class="fp-prop-card__name">@fpSpace.Name</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@functions {
    // Rent-level label for the popover (plain text — the visual badge/pips can't render
    // in a plain-text popover; the property tab shows those via the _RentLevel partial).
    static string RentLevelName(RentLevel level) => level switch
    {
        RentLevel.SINGLE => "Single",
        RentLevel.SET => "Set",
        RentLevel.DOUBLE => "Double",
        RentLevel.TRIPLE => "Triple",
        RentLevel.ONE_HOUSE => "1 house",
        RentLevel.TWO_HOUSES => "2 houses",
        RentLevel.THREE_HOUSES => "3 houses",
        RentLevel.FOUR_HOUSES => "4 houses",
        RentLevel.HOTEL => "Hotel",
        RentLevel.DOUBLE_HOTEL => "Double hotel",
        _ => level.ToString()
    };

    // The board-rectangle rent indicator: building squares for built levels (houses + hotels),
    // a single lettered badge for the rest. Houses/hotels render as squares (max 2 per row);
    // SINGLE/SET/DOUBLE/TRIPLE render as a secondary badge "1"/"S"/"D"/"T".
    static (string? Badge, int Houses, int Hotels) RentLevelVisual(RentLevel level) => level switch
    {
        RentLevel.SINGLE => ("1", 0, 0),
        RentLevel.SET => ("S", 0, 0),
        RentLevel.DOUBLE => ("D", 0, 0),
        RentLevel.TRIPLE => ("T", 0, 0),
        RentLevel.ONE_HOUSE => (null, 1, 0),
        RentLevel.TWO_HOUSES => (null, 2, 0),
        RentLevel.THREE_HOUSES => (null, 3, 0),
        RentLevel.FOUR_HOUSES => (null, 4, 0),
        RentLevel.HOTEL => (null, 0, 1),
        RentLevel.DOUBLE_HOTEL => (null, 0, 2),
        _ => (null, 0, 0)
    };

    static string SideClass(BoardSide side) => side switch
    {
        BoardSide.Top => "side-top",
        BoardSide.Bottom => "side-bottom",
        BoardSide.Left => "side-left",
        BoardSide.Right => "side-right",
        _ => "is-corner"
    };

    // The space's outer edge (facing away from the board centre) for the extra-
    // player count badge. Edge spaces map to their side; corners pin to the
    // outer corner derived from the cell's grid position.
    static string CounterEdgeClass(BoardCell cell) => cell.Side switch
    {
        BoardSide.Top => "cnt-top",
        BoardSide.Bottom => "cnt-bottom",
        BoardSide.Left => "cnt-left",
        BoardSide.Right => "cnt-right",
        _ => (cell.Row, cell.Column) switch
        {
            (1, 1) => "cnt-tl",
            (1, _) => "cnt-tr",
            (_, 1) => "cnt-bl",
            _ => "cnt-br"
        }
    };

    // Banner colour via the shared SCSS property palette (.bg-prop-{slug}) —
    // e.g. DarkBlue -> bg-prop-dark-blue, Station -> bg-prop-station. ToDisplayName
    // splits the PascalCase name ("Dark blue") and ToSlug kebabs it, matching the
    // keys in custom-bootstrap.scss ($prop-colours).
    static string? PropClass(PropertySet? set) =>
        set is null ? null : $"bg-prop-{set.Value.ToDisplayName().ToSlug()}";

    // Ownership-state tint via Bootstrap's contextual backgrounds. The hue
    // tracks the theme palette; the tint strength is set once on .space-body
    // via --bs-bg-opacity (these .bg-* classes compute their colour as
    // rgba(var(--bs-*-rgb), var(--bs-bg-opacity))), composited over the white
    // .board-space behind them for a light tint.
    static string StateClass(PropertyState state) => state switch
    {
        PropertyState.NotOwned => "bg-success",     // available — green
        PropertyState.Owned => "bg-danger",         // owned — red
        PropertyState.Mortgaged => "bg-warning",    // mortgaged — amber
        PropertyState.Reserved => "bg-primary",     // reserved — light blue
        PropertyState.FreeParking => "bg-info",     // free parking — periwinkle/purple
        _ => ""
    };
}

@* Click-popover init exposed as a global so it can re-run after the board is
   re-rendered live (this inline script does not execute on an innerHTML swap, but
   window.initBoardPopovers persists from first load — play-state.js calls it). *@
<script>
    window.initBoardPopovers = function () {
        if (typeof bootstrap === 'undefined') return;
        document.querySelectorAll('.board-view [data-bs-toggle="popover"]').forEach(function (el) {
            if (!bootstrap.Popover.getInstance(el)) new bootstrap.Popover(el);
        });
    };
    document.addEventListener('DOMContentLoaded', function () { window.initBoardPopovers(); });
</script>

<style>
    /* Square sized off the container's height; capped so a narrow column can't overflow. */
    .board-view {
        aspect-ratio: 1 / 1;
        height: 100%;
        max-width: 100%;
        margin-inline: auto;
    }

    .board-grid {
        display: grid;
        grid-template-columns: repeat(13, 1fr);
        grid-template-rows: repeat(13, 1fr);
        width: 100%;
        height: 100%;
        gap: 2px;                  /* gaps show the dark backing as grid lines */
        background: #2b2b2b;
        border: 2px solid #2b2b2b;
        border-radius: 4px;
    }

    .board-space {
        position: relative;
        display: flex;
        min-width: 0;
        min-height: 0;
        overflow: visible;          /* let player tokens sit over the cell edges */
        background: #f5f5f5;        /* white body for plain (non-property) spaces */
    }
    .board-space[data-bs-toggle] { cursor: pointer; }

    /* Banner on the inward edge. Markup order is banner-then-body, so the
       reversed directions put the banner against the centre of the board. */
    .side-top { flex-direction: column-reverse; }   /* banner bottom */
    .side-bottom { flex-direction: column; }         /* banner top */
    .side-left { flex-direction: row-reverse; }      /* banner right */
    .side-right { flex-direction: row; }             /* banner left */

    /* Body colour = ownership tint (.bg-success/-danger/…); banner = .bg-prop-*.
       --bs-bg-opacity softens the .bg-* classes to a light tint over the white
       space behind them (default is 1 — fully saturated, too dark). */
    .space-body { flex: 1 1 auto; background: #f5f5f5; --bs-bg-opacity: .45 !important; }
    .space-banner { flex: 0 0 22%; }

    /* Text labels — non-property spaces (Chance, Tax, …) and corners */
    .space-label {
        flex: 1 1 auto;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0.2rem;
        text-align: center;
        font-size: 0.62rem;
        line-height: 1.05;
        font-weight: 600;
        color: #222;
        overflow: hidden;
    }

    /* Icon glyphs replace text on non-corner Chance / Community Chest / Tax spaces */
    .space-icon {
        flex: 1 1 auto;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        line-height: 1;
        color: #333;
    }

    /* Player tokens — centred over the whole space (edge spaces span two cells).
       One counter per space; extras are tallied in a badge on the outer edge. */
    .space-counters {
        position: absolute;
        inset: 0;
        z-index: 2;
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: none;
    }
    .space-counter-extra {
        position: absolute;
        z-index: 3;
        min-width: 1.1rem;
        height: 1.1rem;
        padding: 0 0.22rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.6rem;
        font-weight: 700;
        line-height: 1;
        border-radius: 1rem;
        background: rgba(17, 17, 17, .85);
        color: #fff;
        pointer-events: none;
    }
    /* Outer edge (facing away from the board centre); corners pin to the corner. */
    .space-counter-extra.cnt-top    { top: 0;    left: 50%; transform: translateX(-50%); }
    .space-counter-extra.cnt-bottom { bottom: 0; left: 50%; transform: translateX(-50%); }
    .space-counter-extra.cnt-left   { left: 0;   top: 50%;  transform: translateY(-50%); }
    .space-counter-extra.cnt-right  { right: 0;  top: 50%;  transform: translateY(-50%); }
    .space-counter-extra.cnt-tl { top: 0; left: 0; }
    .space-counter-extra.cnt-tr { top: 0; right: 0; }
    .space-counter-extra.cnt-bl { bottom: 0; left: 0; }
    .space-counter-extra.cnt-br { bottom: 0; right: 0; }

    /* Rent-level indicator — centred in the rectangle, beneath the player chips (z-index 1
       vs the counters' 2). Built levels show building squares (max two per row); the rest
       show a single secondary badge. */
    .space-buildings {
        position: absolute;
        inset: 0;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: none;
    }
    .space-buildings-inner {
        display: flex;
        flex-wrap: wrap;
        align-content: center;
        justify-content: center;
        gap: 2px;
        width: 64%;                       /* fits exactly two squares per row */
    }
    /* Left/right edge spaces are landscape (~2:1) where top/bottom are portrait, so a
       width-based square is ~2× too big on them and overflows the short (height) axis.
       Halve the inner width on the wide sides: 32% of a 2:1 cell ≈ 64% of its short
       side, matching the square size on top/bottom. */
    .side-left .space-buildings-inner,
    .side-right .space-buildings-inner { width: 32%; }
    .building {
        width: calc(50% - 2px);
        aspect-ratio: 1 / 1;
        border-radius: 1px;
        border: 1px solid rgba(0, 0, 0, 0.35);
    }
    .building--house { background: #2e9e4f; }   /* houses — green */
    .building--hotel { background: #d63a3a; }   /* hotels — red */
    .rent-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 1rem;
        height: 1rem;
        padding: 0 0.2rem;
        border-radius: 1rem;
        background: var(--bs-secondary);
        color: #fff;
        font-size: 0.6rem;
        font-weight: 700;
        line-height: 1;
    }

    /* Corners + centre share the board base colour */
    .board-space.is-corner { background: #e9e4d6; }
    .board-space.is-corner .space-label {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.02em;
    }

    /* ── Just Visiting / In Jail (bottom-left corner) ──
       "Just Visiting" pins to the outer (bottom-left) part of the cell; the diagonal
       "In Jail" zone is a triangle in the inner corner (top-right, facing the centre,
       beside Pentonville Road / Pall Mall). Jailed players (BoardIndex == JailSpace)
       render inside the triangle. */
    .jail-tri {
        position: absolute;
        inset: 0;
        clip-path: polygon(0 0, 100% 0, 100% 100%);   /* inner top-right triangle */
        background: var(--bs-warning, #ffc107);
        opacity: 0.85;
        z-index: 1;
    }
    .board-space.is-corner .space-label.jv-visiting-label {
        position: absolute;
        left: 0;
        bottom: 0;
        width: 72%;
        flex: none;
        padding: 0.15rem;
        font-size: 0.56rem;
        line-height: 1.05;
        z-index: 2;
    }
    .jail-zone {
        position: absolute;
        top: 0;
        right: 0;
        width: 60%;
        height: 60%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.1rem;
        z-index: 3;
        pointer-events: none;
    }
    .jail-zone__label {
        font-size: 0.5rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.02em;
        line-height: 1;
        color: #5a3a00;
    }
    .jail-zone__counters { line-height: 0; }
    .jail-zone__extra {
        position: absolute;
        top: -0.1rem;
        right: -0.1rem;
        min-width: 0.95rem;
        height: 0.95rem;
        padding: 0 0.18rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.55rem;
        font-weight: 700;
        line-height: 1;
        border-radius: 1rem;
        background: rgba(17, 17, 17, .85);
        color: #fff;
    }
    .board-centre {
        background: #e9e4d6;
        color: #222;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;   /* key pinned top; .fp-centre fills + centres the rest */
        gap: 0.4rem;
        padding: 0.5rem;
        text-align: center;
    }
    .board-centre .fp-label { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; opacity: 0.7; }
    .board-centre .fp-pot { font-size: 1.5rem; font-weight: 700; }

    /* Key — legend for the board's ownership-state tints (matches StateClass). */
    .board-key {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.2rem 0.55rem;
        width: 100%;
    }
    .board-key__item {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        font-size: 0.58rem;
        font-weight: 600;
        line-height: 1;
        color: #333;
        white-space: nowrap;
    }
    .board-key__dot {
        width: 0.7rem;
        height: 0.7rem;
        border-radius: 50%;
        border: 1px solid rgba(0, 0, 0, 0.25);
        flex: 0 0 auto;
    }

    /* Free Parking block — pot + one optional held-property card, centred below the key. */
    .fp-centre {
        flex: 1 1 auto;
        min-height: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
    }
    .fp-prop-card {
        width: 78%;
        max-width: 15rem;
        background: #f5f5f5;
        border: 1px solid #2b2b2b;
        border-radius: 4px;
        overflow: hidden;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.25);
    }
    .fp-prop-card__banner { height: 2rem; }
    .fp-prop-card__name {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 3rem;
        padding: 1.1rem 1rem;
        font-size: 0.95rem;
        font-weight: 700;
        line-height: 1.25;
        text-align: center;
        color: #222;
    }

    /* Multi-line popover content (plain text + pre-line — no HTML, so a
       user-authored board-skin name can't inject markup). */
    .board-popover .popover-body { white-space: pre-line; }
</style>