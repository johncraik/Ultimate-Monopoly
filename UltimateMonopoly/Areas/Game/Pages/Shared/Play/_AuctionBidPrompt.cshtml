@using JC.Core.Extensions
@using MP.GameEngine.Helpers
@using MP.GameEngine.Helpers.RuleSet
@using MP.GameEngine.Models.Prompts.PromptTypes
@model AuctionBidPrompt
@{
    var set = PropertySetHelper.ResolveSet(Model.BoardIndex);
    var slug = set?.ToDisplayName().ToSlug();
    var headClass = slug is not null ? $"text-bg-prop-{slug}" : "text-bg-primary";
    var borderClass = slug is not null ? $"border-prop-{slug}" : "border-primary";
    const string cur = RuleDictionary.Currency;
}
@*
    AUCTION-BID PROMPT — server-rendered fragment. One raise button per AllowedIncrements,
    each submitting CurrentHighBid + increment as a Bid (disabled if it exceeds balance —
    game-rules.md Default rule 7), plus Pass. ingame-prompts.js: [data-prompt-submit] with
    data-bid-amount → Bid; [data-prompt-decline] → Pass. Coloured by the property's set.
*@
<div class="pp-prompt-card border border-2 @borderClass">
    <div class="pp-prompt-head @headClass">
        @(string.IsNullOrEmpty(Model.Title) ? "Property auction" : Model.Title)
    </div>
    <div class="pp-prompt-body">
        @if (!string.IsNullOrEmpty(Model.Body))
        {
            <p class="mb-2">@Model.Body</p>
        }
        <div class="d-flex justify-content-between small text-body-secondary mb-3">
            <span>Current bid: <span class="fw-semibold text-body">@cur@Model.CurrentHighBid</span></span>
            <span>Your balance: <span class="fw-semibold text-body">@cur@Model.PlayerBalance</span></span>
        </div>
        <div class="text-body-secondary small mb-1">Raise the bid by:</div>
        <div class="d-flex flex-wrap gap-2">
            @foreach (var inc in Model.AllowedIncrements)
            {
                var newBid = Model.CurrentHighBid + inc;
                <button type="button" class="btn btn-outline-primary flex-fill" data-prompt-submit data-bid-amount="@newBid"
                        disabled="@(newBid > Model.PlayerBalance)">
                    +@cur@inc
                </button>
            }
        </div>
    </div>
    <div class="pp-prompt-foot">
        <button type="button" class="btn btn-outline-danger w-100" data-prompt-decline>
            <i class="bi bi-x-circle me-1"></i> Pass (drop out)
        </button>
    </div>
</div>
