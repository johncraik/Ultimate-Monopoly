@using JC.Core.Extensions
@using MP.GameEngine.Enums
@using MP.GameEngine.Enums.Properties
@using MP.GameEngine.Helpers
@using MP.GameEngine.Helpers.RuleSet
@using MP.GameEngine.Models.Snapshot
@using UltimateMonopoly.Models.ViewModels.Games
@using UltimateMonopoly.Models.ViewModels.Social
@using UltimateMonopoly.Services.Cache
@model MP.GameEngine.Services.Framework.GameEngine
@inject PlayerCacheService PlayerCache
@inject UltimateMonopoly.Services.RuleCatalog RuleCatalog
@{
    // The live play body. Rendered on first load (from Play.cshtml) and re-rendered
    // on every SignalR StateChanged frame (PlayModel.OnGetStateAsync → swapped in by
    // play-state.js). All state reads straight off the engine cache, so the live and
    // first-load render paths are identical.
    var cache = Model.Cache;
    var turnStateProvider = Model.TurnStateProvider;

    var game = cache.Game;

    var current = game.CurrentPlayer();
    if (current == null) throw new InvalidOperationException("No current player.");

    var players = game.GetPlayers(excludePovPlayer: false);
    var playerCounters = new List<(UserProfileViewModel, PlayerModel)>();

    var bankruptPlayers = game.GetPlayers(true);

    var canEndTurn = turnStateProvider.CanEndTurn(current.PlayerId, cache.HostPlayerId);

    // Current player's profile (for the turn bar's profile circle) and the turn's dice. GetTurnDiceRoll
    // gives the EFFECTIVE roll (its RollType already reflects any card modification). ModifiedDiceRollType
    // is the up/down signal: Triple = a double upgraded to a triple (up), Double = a triple downgraded (down).
    var currentProfile = await PlayerCache.GetPlayerProfile(current.PlayerId);
    var turnDice = cache.GetTurnDiceRoll();
    var modifiedType = game.ModifiedDiceRollType;

    var availableCount = game.Properties.Count(p => string.IsNullOrEmpty(p.OwnerPlayerId));
    var fpProperties = game.Properties.Where(p => p.State == PropertyState.FreeParking).ToList();

    var c = RuleDictionary.Currency;

    // Rules cited this turn, resolved to player-facing text via the catalogue.
    // Newest first (reverse of the cited order); Distinct guards against repeats.
    var rules = await RuleCatalog.GetRules(cache.RuleCodes.Reverse().Distinct().ToList());

    // Global "until a double is rolled" events (rail strike, tax rise, etc.).
    // Each tuple is (icon, title, body). Each active flag contributes one item;
    // the banner only renders if at least one is active. See EventInfo.
    var events = new List<(string Icon, string Title, string Body)>();
    var ev = game.GlobalEventInfo;
    if (ev.StationEvent)
    {
        events.Add(ev.StationRentMultiplier == 0
            ? ("bi-train-front-fill", "Rail Strike!", "No rent on stations until a double is rolled.")
            : ("bi-train-front-fill", "Station Boom!", $"Station rent is ×{ev.StationRentMultiplier} until a double is rolled."));
    }
    if (ev.UtilityEvent)
    {
        events.Add(ev.UtilityRentMultiplier == 0
            ? ("bi-lightning-charge-fill", "Utility Outage!", "No rent on utilities until a double is rolled.")
            : ("bi-lightning-charge-fill", "Utility Surge!", $"Utility rent is ×{ev.UtilityRentMultiplier} until a double is rolled."));
    }
    if (ev.TaxEvent)
    {
        events.Add(ev.TaxMultiplier == 0
            ? ("bi-bank2", "Tax Holiday!", "No tax until a double is rolled.")
            : ("bi-bank2", "Tax Rises!", $"Tax is ×{ev.TaxMultiplier} until a double is rolled."));
    }
    if (ev.RealFreeParking)
    {
        events.Add(("bi-cone-striped", "Pay Machine Broken!", "Free Parking does nothing until a double is rolled."));
    }
    if (ev.JailFull)
    {
        events.Add(("bi-shield-exclamation", "Jail at Max Capacity!", "Players sent to jail must pay the fee until a double is rolled."));
    }
}

@* ───────────────────────── Event banner (full bleed) ─────────────────────────
   Card-driven "until a double is rolled" events surface here as a single-line
   scrolling news ticker that spans the whole viewport (the .news-banner
   full-bleed CSS overrides the row's gutter). Pure-CSS marquee; pauses on hover.
   The content is rendered twice for a seamless loop (-50% wraps to 0). *@
@if (events.Count > 0)
{
    @* col-12 is the row child (so col-3 + col-9 below wrap to a fresh line);
       the inner .news-banner-wrap does the full-bleed bleed-out. *@
    <div class="col-12 p-0">
        <div class="news-banner-wrap">
            <div class="news-banner">
                <div class="news-banner-track">
                    @for (var rep = 0; rep < 2; rep++)
                    {
                        <div class="news-banner-set" aria-hidden="@(rep == 1 ? "true" : null)">
                            @foreach (var (icon, title, body) in events)
                            {
                                <span class="news-banner-item">
                                    <i class="bi @icon me-2"></i>
                                    <strong>@title</strong>
                                    <span class="ms-2">@body</span>
                                </span>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@* ───────────────────────── Sidebar (col-3) ───────────────────────── *@
<div class="col-3">
    <div class="h-100 d-flex flex-column gap-3">

        @* "Open Profile on Prompt" — when on, a player's profile drawer auto-opens as a
           prompt fires for them. Persisted client-side (player-drawer.js); default on. *@
        <div class="card flex-shrink-0">
            <div class="card-body py-2">
                <div class="form-check form-switch d-flex justify-content-between align-items-center ps-0 m-0">
                    <label class="form-check-label fw-semibold" for="openOnPromptToggle">Open Profile on Prompt</label>
                    <input class="form-check-input ms-0 mt-0" type="checkbox" role="switch"
                           id="openOnPromptToggle" data-open-on-prompt checked>
                </div>
            </div>
        </div>

        @* Top: player list (40% of the sidebar) *@
        <div class="card play-pane play-pane--players">
            <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                <span>Players</span>
                <span class="badge text-bg-secondary">@players.Count</span>
            </div>
            <div class="card-body d-flex flex-column gap-2 overflow-auto">
                @foreach (var p in players)
                {
                    var profile = await PlayerCache.GetPlayerProfile(p.PlayerId);
                    playerCounters.Add((profile, p));

                    var isHost = p.PlayerId == cache.HostPlayerId;
                    var isCurrent = p.PlayerId == current.PlayerId;
                    <div class="card play-player-card @(isHost ? "play-player-card--host" : null) @(isCurrent ? "border-info" : null) @(p.IsBankrupt ? "opacity-50" : null)"
                         data-player-card data-user-id="@p.PlayerId" data-player-name="@profile.DisplayName"
                         data-view-player="@(p.IsBankrupt ? (string?)null : "")"
                         style="@(string.IsNullOrEmpty(profile.AvatarColour) ? null : $"--player-colour:{profile.AvatarColour}")">
                        <div class="card-body d-flex align-items-center gap-2 py-2">
                            <profile-circle user="profile" size="Md" />
                            <div class="flex-grow-1 min-w-0">
                                <div class="fw-semibold text-truncate">
                                    @profile.DisplayName
                                    @if (p.IsBankrupt)
                                    {
                                        <span class="badge text-bg-danger ms-1">Bankrupt</span>
                                    }
                                </div>
                                <div class="small text-body-secondary d-flex flex-wrap align-items-center gap-2">
                                    <span>Seat @(p.OrderId + 1)</span>
                                    <span>Dice <span class="badge text-bg-secondary">@p.Dice1 | @p.Dice2</span></span>
                                    <span class="fw-semibold text-body">@c@p.Money.ToString("N0")</span>
                                </div>
                            </div>
                        </div>
                        <span class="play-arrow" aria-hidden="true"></span>
                    </div>
                }

                @foreach (var p in bankruptPlayers)
                {
                    var profile = await PlayerCache.GetPlayerProfile(p.PlayerId);

                    var isHost = p.PlayerId == cache.HostPlayerId;
                    var isCurrent = p.PlayerId == current.PlayerId;
                    <div class="card play-player-card @(isHost ? "play-player-card--host" : null) @(isCurrent ? "border-info" : null) @(p.IsBankrupt ? "opacity-50" : null)"
                         data-player-card data-user-id="@p.PlayerId" data-player-name="@profile.DisplayName"
                         data-view-player="@(p.IsBankrupt ? (string?)null : "")"
                         style="@(string.IsNullOrEmpty(profile.AvatarColour) ? null : $"--player-colour:{profile.AvatarColour}")">
                        <div class="card-body d-flex align-items-center gap-2 py-2">
                            <profile-circle user="profile" size="Md" />
                            <div class="flex-grow-1 min-w-0">
                                <div class="fw-semibold text-truncate">
                                    @profile.DisplayName
                                    @if (p.IsBankrupt)
                                    {
                                        <span class="badge text-bg-danger ms-1">Bankrupt</span>
                                    }
                                </div>
                                <div class="small text-body-secondary d-flex flex-wrap align-items-center gap-2">
                                    <span>Seat @(p.OrderId + 1)</span>
                                    <span>Dice <span class="badge text-bg-secondary">@p.Dice1 | @p.Dice2</span></span>
                                    <span class="fw-semibold text-body">@c@p.Money.ToString("N0")</span>
                                </div>
                            </div>
                        </div>
                        <span class="play-arrow" aria-hidden="true"></span>
                    </div>
                }
            </div>
        </div>

        @* Bottom: Game Info — reservation rule (full-width badge), houses/hotels left, and the
           Free Parking / Available Properties accordion. Takes the larger (60%) share of the
           sidebar (play-pane--rules sizing); the body scrolls internally (play-pane--info) so its
           bottom stays in line with the board/game area. *@
        <div class="card play-pane play-pane--rules play-pane--info">
            <div class="card-header fw-semibold">Game Info</div>
            <div class="card-body overflow-auto d-flex flex-column gap-3">

                @* ── Reservation rule — full-width badge ─────── *@
                @if (game.ReserveRuleActive)
                {
                    <span class="badge text-bg-success w-100 py-2">Reservation Rule Active</span>
                }
                else
                {
                    <span class="badge text-bg-secondary w-100 py-2">Reservation Rule Inactive</span>
                }

                @* ── Houses / Hotels left block (split) ─────── *@
                @{
                    var (housesLeft, hotelsLeft) = game.GetHousesAndHotelsLeft();
                }
                <div class="gi-block gi-block--split d-flex text-center">
                    <div class="flex-fill">
                        <i class="bi bi-house-fill fs-2 d-block mb-2 opacity-75"></i>
                        <div class="fs-5 fw-semibold">@housesLeft</div>
                        <div class="small text-body-secondary">Houses left</div>
                    </div>
                    <div class="flex-fill">
                        <i class="bi bi-buildings-fill fs-2 d-block mb-2 opacity-75"></i>
                        <div class="fs-5 fw-semibold">@hotelsLeft</div>
                        <div class="small text-body-secondary">Hotels left</div>
                    </div>
                </div>

                @* ── Accordion: Free Parking + Available Properties ──
                   Each body is a flat badge list (one badge per property), coloured
                   by set via text-bg-prop-{slug} (contrast-aware) and ordered by the
                   PropertySet enum order, BoardIndex within a set. Names come from
                   cache.Board.Spaces (the live source of truth for skin names). *@
                @{
                    var boardSpaces = cache.Board.Spaces.ToDictionary(s => s.Index);

                    int SetOrder(PropertySet? s) => s.HasValue ? (int)s.Value : int.MaxValue;

                    // Group by set so each set renders on its own row in the body;
                    // properties within a set keep BoardIndex order. Null-set entries
                    // (shouldn't exist for Properties) tail-end under a Misc bucket.
                    var fpBySet = fpProperties
                        .GroupBy(p => PropertySetHelper.ResolveSet(p.BoardIndex))
                        .OrderBy(g => SetOrder(g.Key))
                        .Select(g => (Set: g.Key, Props: g.OrderBy(p => p.BoardIndex).ToList()))
                        .ToList();

                    var availableBySet = game.Properties
                        .Where(p => string.IsNullOrEmpty(p.OwnerPlayerId) && p.State == PropertyState.NotOwned)
                        .GroupBy(p => PropertySetHelper.ResolveSet(p.BoardIndex))
                        .OrderBy(g => SetOrder(g.Key))
                        .Select(g => (Set: g.Key, Props: g.OrderBy(p => p.BoardIndex).ToList()))
                        .ToList();

                    var availableCountFromGroups = availableBySet.Sum(g => g.Props.Count);
                }
                <div class="accordion gi-accordion" id="gameInfoAccordion">

                    @* Free Parking — pot in the header, FP-held properties in the body *@
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#gi-fp">
                                <span class="flex-grow-1">Free Parking</span>
                                <span class="badge text-bg-secondary me-2">@c@game.FreeParkingAmount.ToString("N0")</span>
                            </button>
                        </h2>
                        <div id="gi-fp" class="accordion-collapse collapse show" data-bs-parent="#gameInfoAccordion">
                            <div class="accordion-body d-flex flex-column gap-2">
                                @if (fpBySet.Count == 0)
                                {
                                    <div class="text-body-secondary small">No properties in Free Parking.</div>
                                }
                                else
                                {
                                    @foreach (var group in fpBySet)
                                    {
                                        <div class="d-flex flex-wrap gap-1">
                                            @foreach (var p in group.Props)
                                            {
                                                var name = boardSpaces.TryGetValue(p.BoardIndex, out var sp) ? sp.Name : p.Name;
                                                <span class="badge rounded-pill @(group.Set is null ? "text-bg-secondary" : $"text-bg-prop-{group.Set.Value.ToDisplayName().ToSlug()}")">@name</span>
                                            }
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>

                    @* Available Properties — every unowned (NotOwned) space *@
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#gi-avail">
                                <span class="flex-grow-1">Available Properties</span>
                                <span class="badge text-bg-secondary me-2">@availableCountFromGroups</span>
                            </button>
                        </h2>
                        <div id="gi-avail" class="accordion-collapse collapse" data-bs-parent="#gameInfoAccordion">
                            <div class="accordion-body d-flex flex-column gap-2">
                                @if (availableBySet.Count == 0)
                                {
                                    <div class="text-body-secondary small">No available properties.</div>
                                }
                                else
                                {
                                    @foreach (var group in availableBySet)
                                    {
                                        <div class="d-flex flex-wrap gap-1">
                                            @foreach (var p in group.Props)
                                            {
                                                var name = boardSpaces.TryGetValue(p.BoardIndex, out var sp) ? sp.Name : p.Name;
                                                <span class="badge rounded-pill @(group.Set is null ? "text-bg-secondary" : $"text-bg-prop-{group.Set.Value.ToDisplayName().ToSlug()}")">@name</span>
                                            }
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@* ───────────────────────── Game View (col-9) ───────────────────────── *@
<div class="col-9">
    <div class="h-100 d-flex flex-column gap-3">

        @* Current turn — info-headed card with the state-driven turn button *@
        <div class="card">
            <div class="card-header bg-info text-dark fw-semibold d-flex align-items-center justify-content-between gap-3">
                <div class="min-w-0 d-flex align-items-center gap-2">
                    <profile-circle user="currentProfile" size="Md" />
                    <span class="fs-5 fw-semibold text-truncate">@currentProfile.DisplayName</span>
                    <span class="badge rounded-pill p-2 text-bg-secondary flex-shrink-0">@cache.TurnState.ToDisplayName()</span>
                </div>

                <div class="d-flex align-items-center gap-3 flex-shrink-0">
                    @* The turn's dice (left of the turn button): the two dice and the third die, a roll-type
                       badge, and — when a card changed the roll type — an up (double→triple) / down
                       (triple→double) indicator. Only shown once a roll has happened this turn. *@
                    @if (turnDice != null)
                    {
                        var (rollLabel, rollColour) = turnDice.RollType switch
                        {
                            DiceRollType.Triple => ("Triple", "warning"),
                            DiceRollType.Double => ("Double", "primary"),
                            _ => ("Normal", "secondary")
                        };
                        <div class="d-flex align-items-center gap-2 bg-secondary rounded-pill ps-3 pe-2 py-2 shadow-sm">
                            <span class="d-flex align-items-center gap-1 fs-4 text-dark lh-1">
                                <i class="bi bi-dice-@turnDice.Die1"></i>
                                @if (turnDice.Die2 is { } d2)
                                {
                                    <i class="bi bi-dice-@d2"></i>
                                }
                            </span>
                            @if (turnDice.ThirdDie is { } d3)
                            {
                                <span class="text-body-secondary fw-light">|</span>
                                <i class="bi bi-dice-@d3 fs-4 text-dark lh-1"></i>
                            }
                            <span class="badge rounded-pill text-bg-@rollColour">@rollLabel</span>
                            @if (modifiedType == DiceRollType.Triple)
                            {
                                <span class="badge rounded-pill text-bg-success d-inline-flex align-items-center" title="Upgraded to a triple by a card">
                                    <i class="bi bi-arrow-up"></i>
                                </span>
                            }
                            else if (modifiedType == DiceRollType.Double)
                            {
                                <span class="badge rounded-pill text-bg-danger d-inline-flex align-items-center" title="Downgraded to a double by a card">
                                    <i class="bi bi-arrow-down"></i>
                                </span>
                            }
                        </div>
                    }

                    @* Turn button — driven by TurnState (commands in play-page.js,
                       gated server-side and enqueued on the executor):
                         • StartOfTurn → Roll Dice (StartTurn → EnqueueTurn)
                         • EndOfTurn   → End Turn   (EndTurn → EnqueueEndTurn)
                         • mid-turn    → End Turn, disabled (light)                  *@
                    @if (cache.TurnState == TurnState.StartOfTurn)
                    {
                        <button type="button" class="btn btn-hero-success" data-start-turn>
                            <i class="bi bi-dice-5 me-1"></i> Roll Dice
                        </button>
                    }
                    else if (cache.TurnState == TurnState.EndOfTurn)
                    {
                        <button type="button" class="btn btn-hero-danger" data-end-turn
                                disabled="@(!canEndTurn)">
                            <i class="bi bi-flag-fill me-1"></i> End Turn
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-hero-light" data-end-turn disabled>
                            <i class="bi bi-flag-fill me-1"></i> End Turn
                        </button>
                    }
                </div>
            </div>
        </div>

        @* Board (square — the partial aspect-ratio-locks itself to the column
           width) + Rules this turn. *@
        <div class="row g-3">
            <div class="col-8">
                <partial name="Play/_BoardView" model="new BoardViewModel(cache.Board, game.Properties, playerCounters, game.FreeParkingAmount)" />
            </div>

            <div class="col-4">
                @* Rules executed this turn — newest first. Each links to the rule on the
                   (separate) rules page, opening in a new tab. Fills the column height; the
                   body scrolls internally so its bottom stays in line with the board. *@
                <div class="card h-100 play-pane play-pane--info">
                    <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                        <span>Rules</span>
                        @if (rules.Count > 0)
                        {
                            <span class="badge text-bg-secondary">@rules.Count</span>
                        }
                    </div>
                    <div class="card-body overflow-auto p-0">
                        @if (rules.Count == 0)
                        {
                            <div class="text-center text-body-secondary small p-4">
                                <i class="bi bi-journal-text d-block fs-3 mb-2 opacity-50"></i>
                                No custom rules have been executed yet.
                            </div>
                        }
                        else
                        {
                            <div class="list-group list-group-flush">
                                @foreach (var rule in rules)
                                {
                                    <a class="list-group-item list-group-item-action"
                                       href="/Rules#@rule.RuleIdLink" target="_blank" rel="noopener">
                                        <div class="fw-semibold small">@rule.Title</div>
                                        <div class="small text-body-secondary">@rule.RuleDescription</div>
                                    </a>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>