@using UltimateMonopoly.Helpers.RuleSet
@using UltimateMonopoly.Services
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@inject ProfileService ProfileService
<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @RuleDictionary.GameName</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" />
    @{
        var afTokens = Antiforgery.GetAndStoreTokens(Context);
    }
    <meta name="csrf-header" content="@afTokens.HeaderName" />
    <meta name="csrf-token" content="@afTokens.RequestToken" />
</head>
<body>
    @{
        var currentUser = await ProfileService.GetCurrentUserProfileViewModelAsync();
    }
    <nav class="navbar navbar-glass mb-4" data-game-nav>
        <div class="container-lg d-flex align-items-center justify-content-between">
            <button type="button"
                    class="btn btn-primary rounded-circle d-inline-flex align-items-center justify-content-center p-0"
                    style="width: 2.75rem; height: 2.75rem;"
                    data-nav-back aria-label="Go back">
                <i class="bi bi-arrow-left fs-5"></i>
            </button>

            <partial name="_Branding" />

            <a href="/profile" class="d-inline-flex" aria-label="My profile">
                <profile-circle user="currentUser" size="Md" />
            </a>
        </div>
    </nav>

    <main class="container-lg pb-5">
        @RenderBody()
    </main>

    @* Leave-page confirmation — shown before any nav-bar navigation *@
    <div class="modal fade" id="navConfirmModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-body text-center py-4">
                    <p class="mb-0 fs-5">Are you sure you want to leave this page?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" data-nav-confirm-go>Leave</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/scripts/game-nav.js" asp-append-version="true"></script>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <script src="~/scripts/SignalR/signalr.min.js" asp-append-version="true"></script>
        <script src="~/scripts/SignalR/presence.js" asp-append-version="true"></script>
        <script src="~/scripts/notifications.js" asp-append-version="true"></script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>