@using JC.Identity.Authentication
@using Microsoft.AspNetCore.Identity
@using MP.GameEngine.Helpers.RuleSet
@using UltimateMonopoly.Data
@using UltimateMonopoly.Services
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@inject SignInManager<AppUser> SignInManager
<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @RuleDictionary.GameName</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" />
    @await RenderSectionAsync("Styles", required: false)
    @{
        var afTokens = Antiforgery.GetAndStoreTokens(Context);
    }
    <meta name="csrf-header" content="@afTokens.HeaderName" />
    <meta name="csrf-token" content="@afTokens.RequestToken" />
</head>
<body>
    <nav class="navbar navbar-glass mb-4" data-game-nav>
        <div class="container-xl d-flex align-items-center justify-content-between">
            <partial name="_Branding" />

            @if (SignInManager.IsSignedIn(User))
            {
                <div class="d-flex align-items-center gap-2 ms-auto justify-content-end">
                    <partial name="~/Pages/Shared/_ProfileDropdown.cshtml" />
                </div>

            }
        </div>
    </nav>

    <main class="container-xl pb-5">
        @RenderBody()
    </main>

    @* Leave-page confirmation — shown before any nav-bar navigation *@
    <div class="modal fade" id="navConfirmModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-body text-center py-4">
                    <p class="mb-0 fs-5">Are you sure you want to leave this page?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" data-nav-confirm-go>Leave</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/scripts/game-nav.js" asp-append-version="true"></script>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <script src="~/scripts/SignalR/signalr.min.js" asp-append-version="true"></script>
        <script src="~/scripts/SignalR/presence.js" asp-append-version="true"></script>
        <script src="~/scripts/notifications.js" asp-append-version="true"></script>
    }
    <partial name="~/Pages/Shared/_BugReporter.cshtml" />
    <partial name="~/Pages/Shared/_FeedbackModal.cshtml" />

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>