@page "{userId}"
@model UltimateMonopoly.Areas.Social.Pages.Friends.ProfileModel
@{
    ViewData["Title"] = Model.User.DisplayName;
}

<div class="mb-3">
    <a asp-page="./Index" class="btn btn-sm btn-outline-secondary">&larr; Back to Friends</a>
</div>

<div class="d-flex align-items-center flex-wrap gap-3 mb-4">
    <profile-circle user="Model.User" size="Lg" />
    <div class="flex-grow-1 min-w-0">
        <h1 class="mb-1 text-truncate">@Model.User.DisplayName</h1>
        <p class="text-body-secondary mb-0">@@@Model.User.Username</p>
    </div>
</div>

<partial name="_GameStatsCards" model="Model.User" />
