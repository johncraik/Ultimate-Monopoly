@model UltimateMonopoly.Areas.Admin.Models.ViewModels.ReportTableModel
@using JC.Core.Extensions
@using UltimateMonopoly.Areas.Admin.Enums
@{
    // Pagination links carry the current filter/search (no handler) so a no-JS click reloads the full
    // page; report-management.js upgrades the click to a ?handler=Table partial fetch.
    var hrefFormat = $"?Resolution={Model.Resolution}" +
                     $"&Search={Uri.EscapeDataString(Model.Search ?? "")}&pageNumber={{0}}";
}

<div class="d-flex align-items-center justify-content-between mb-2">
    <span class="small text-body-secondary">@Model.Reports.TotalCount.ToString("N0") report(s)</span>
</div>

<div class="table-responsive">
    <table class="table table-hover table-sm align-middle admin-users-table mb-0">
        <thead>
            <tr class="text-body-secondary small text-uppercase">
                <th class="admin-id-col">Report ID</th>
                <th class="admin-id-col">Reported User ID</th>
                <th>Reported User</th>
                <th>Reported</th>
                <th>Reason</th>
                <th>Message</th>
                <th>Resolution</th>
                <th class="admin-id-col">Reported By User ID</th>
                <th class="text-center">Open</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Reports.Count == 0)
            {
                <tr><td colspan="9" class="text-center text-body-secondary py-4">No reports match these filters.</td></tr>
            }
            else
            {
                foreach (var r in Model.Reports)
                {
                    <tr data-href="/Admin/Reports/Details?reportId=@r.ReportId">
                        <td class="admin-id-col">
                            <code class="user-id-copy" role="button" title="@r.ReportId"
                                  data-copy-id="@r.ReportId">@r.ReportId.Truncate(8, "…")</code>
                        </td>
                        <td class="admin-id-col">
                            @if (r.ReportedUserId != "-")
                            {
                                <code class="user-id-copy" role="button" title="@r.ReportedUserId"
                                      data-copy-id="@r.ReportedUserId">@r.ReportedUserId.Truncate(8, "…")</code>
                            }
                            else
                            {
                                <span class="text-body-secondary">—</span>
                            }
                        </td>
                        <td>
                            @if (r.ReportedUser != null)
                            {
                                <div class="d-flex align-items-center justify-content-between gap-2">
                                    <div class="min-w-0">
                                        <div class="fw-semibold text-truncate">@r.ReportedUser.Profile.Username</div>
                                        <div class="small text-body-secondary text-truncate">@r.ReportedUser.Profile.DisplayName</div>
                                    </div>
                                    <a href="/Admin/Users/Details?userId=@r.ReportedUser.Profile.UserId"
                                       class="btn btn-sm btn-outline-secondary text-nowrap" title="View user" aria-label="View user">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </div>
                            }
                            else
                            {
                                <span class="text-body-secondary fst-italic">Deleted user</span>
                            }
                        </td>
                        <td>@r.ReportedDate</td>
                        <td>@r.ReasonDisplay</td>
                        <td><span title="@r.Message">@r.Message.Truncate(50, "...")</span></td>
                        <td>@r.ResolutionDisplay</td>
                        <td class="admin-id-col">
                            @if (r.ReportedByUserId != "-")
                            {
                                <code class="user-id-copy" role="button" title="@r.ReportedByUserId"
                                      data-copy-id="@r.ReportedByUserId">@r.ReportedByUserId.Truncate(8, "…")</code>
                            }
                            else
                            {
                                <span class="text-body-secondary">—</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (r.Resolution == ReportResolution.Open)
                            {
                                <i class="bi bi-exclamation-circle-fill text-warning" title="Open"></i>
                            }
                            else
                            {
                                <i class="bi bi-dash-circle text-body-secondary" title="Closed"></i>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<div class="mt-3 d-flex justify-content-center">
    <pagination model="Model.Reports" href-format="@hrefFormat" />
</div>