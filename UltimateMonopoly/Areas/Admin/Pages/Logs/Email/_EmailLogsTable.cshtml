@using JC.Core.Extensions
@model UltimateMonopoly.Areas.Admin.Models.ViewModels.Logs.EmailLogTableModel
@{
    var hrefFormat = $"?Search={Uri.EscapeDataString(Model.Search ?? "")}&pageNumber={{0}}";

    string TypeBadge(JC.Communication.Logging.Models.Email.RecipientLogType t) => t switch
    {
        JC.Communication.Logging.Models.Email.RecipientLogType.To => "text-bg-primary",
        JC.Communication.Logging.Models.Email.RecipientLogType.Cc => "text-bg-info",
        JC.Communication.Logging.Models.Email.RecipientLogType.Bcc => "text-bg-secondary",
        _ => "text-bg-secondary"
    };
}

<div class="d-flex align-items-center justify-content-between mb-2">
    <span class="small text-body-secondary">@Model.Logs.TotalCount.ToString("N0") email(s)</span>
</div>

<div class="table-responsive">
    <table class="table table-hover table-sm align-middle admin-audit-table mb-0">
        <thead>
            <tr class="text-body-secondary small text-uppercase">
                <th class="admin-id-col">Email Log ID</th>
                <th>From</th>
                <th>Subject</th>
                <th>Created</th>
                <th>Created Date</th>
                <th>When</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Logs.Count == 0)
            {
                <tr><td colspan="6" class="text-center text-body-secondary py-4">No emails match.</td></tr>
            }
            else
            {
                foreach (var e in Model.Logs)
                {
                    var detailId = $"email-{e.LogId}";
                    @* Click the row to toggle its detail row (independent collapse). No data-href. *@
                    <tr class="audit-row" role="button" data-bs-toggle="collapse" data-bs-target="#@detailId" aria-expanded="false" aria-controls="@detailId">
                        <td class="admin-id-col">
                            <code class="user-id-copy" role="button" title="@e.LogId" data-copy="@e.LogId">@e.LogId.Truncate(8, "…")</code>
                        </td>
                        <td class="text-truncate">@e.FromAddress</td>
                        <td><span title="@e.Subject">@e.Subject.Truncate(40, "…")</span></td>
                        <td class="min-w-0">
                            <div class="fw-semibold text-truncate">@e.Username</div>
                            @if (e.CreatedById != "-")
                            {
                                <code class="user-id-copy small text-body-secondary" role="button" title="@e.CreatedById" data-copy="@e.CreatedById">@e.CreatedById.Truncate(12, "…")</code>
                            }
                            else
                            {
                                <span class="small text-body-secondary">—</span>
                            }
                        </td>
                        <td>@e.CreatedDate</td>
                        <td class="text-body-secondary">@e.RelativeDate</td>
                    </tr>
                    @* Detail row — recipients (left) and send attempts (right), 50/50. *@
                    <tr class="audit-detail">
                        <td colspan="6" class="p-0 border-0">
                            <div id="@detailId" class="collapse">
                                @* Background + padding on the wrapper, not the .row (a gutter row's negative
                                   top margin would bleed up into the clicked row). *@
                                <div class="bg-body-tertiary p-3">
                                    <div class="row g-3">
                                        @* Recipients *@
                                        <div class="col-12 col-lg-6">
                                            <div class="small text-body-secondary text-uppercase mb-2">Recipients (@e.Recipients.Count)</div>
                                            @if (e.Recipients.Count == 0)
                                            {
                                                <div class="text-body-secondary small">No recipients recorded.</div>
                                            }
                                            else
                                            {
                                                <div class="d-flex flex-column gap-2">
                                                    @foreach (var r in e.Recipients)
                                                    {
                                                        <div class="d-flex align-items-center gap-2 min-w-0">
                                                            <span class="badge @TypeBadge(r.Type) flex-shrink-0">@r.TypeDisplay</span>
                                                            <div class="min-w-0">
                                                                <div class="text-truncate">@r.Address</div>
                                                                @if (!string.IsNullOrWhiteSpace(r.DisplayName))
                                                                {
                                                                    <div class="small text-body-secondary text-truncate">@r.DisplayName</div>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>

                                        @* Send attempts *@
                                        <div class="col-12 col-lg-6">
                                            <div class="small text-body-secondary text-uppercase mb-2">Send attempts (@e.SentLogs.Count)</div>
                                            @if (e.SentLogs.Count == 0)
                                            {
                                                <div class="text-body-secondary small">No send attempts recorded.</div>
                                            }
                                            else
                                            {
                                                <div class="d-flex flex-column gap-2">
                                                    @foreach (var s in e.SentLogs)
                                                    {
                                                        <div class="border rounded p-2">
                                                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                                                @if (s.Succeeded)
                                                                {
                                                                    <span class="badge rounded-pill text-bg-success"><i class="bi bi-check-circle me-1"></i>Sent</span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="badge rounded-pill text-bg-danger"><i class="bi bi-x-circle me-1"></i>Failed</span>
                                                                }
                                                                <span class="badge text-bg-secondary">@s.ProviderDisplay</span>
                                                                <span class="small text-body-secondary">@s.SentAt</span>
                                                            </div>
                                                            @if (!string.IsNullOrWhiteSpace(s.ServerResponse))
                                                            {
                                                                <div class="small text-body-secondary mt-1"><i class="bi bi-hdd-network me-1"></i>@s.ServerResponse</div>
                                                            }
                                                            @if (!string.IsNullOrWhiteSpace(s.ErrorMessage))
                                                            {
                                                                <div class="small text-danger mt-1"><i class="bi bi-exclamation-triangle me-1"></i>@s.ErrorMessage</div>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@if (!Model.Preview)
{
    <div class="mt-3 d-flex justify-content-center">
        <pagination model="Model.Logs" href-format="@hrefFormat" />
    </div>
}
