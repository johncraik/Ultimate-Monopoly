@using JC.Core.Extensions
@model UltimateMonopoly.Areas.Admin.Models.ViewModels.Logs.ThreadActivityLogTableModel
@{
    var hrefFormat = $"?Search={Uri.EscapeDataString(Model.Search ?? "")}" +
                     $"&ActivityType={Model.ActivityType}&pageNumber={{0}}";

    string ActivityBadge(JC.Communication.Logging.Models.Messaging.ThreadActivityType t) => t switch
    {
        JC.Communication.Logging.Models.Messaging.ThreadActivityType.Message => "text-bg-primary",
        JC.Communication.Logging.Models.Messaging.ThreadActivityType.ParticipantAdded => "text-bg-success",
        JC.Communication.Logging.Models.Messaging.ThreadActivityType.ParticipantRemoved => "text-bg-warning",
        _ => "text-bg-secondary"
    };
}

<div class="d-flex align-items-center justify-content-between mb-2">
    <span class="small text-body-secondary">Showing @Model.Logs.Count.ToString("N0") of @Model.Logs.TotalCount.ToString("N0") event(s)</span>
</div>

<div class="table-responsive">
    <table class="table table-hover table-sm align-middle admin-audit-table mb-0">
        <thead>
            <tr class="text-body-secondary small text-uppercase">
                <th class="admin-id-col">Log ID</th>
                <th class="admin-id-col">Thread ID</th>
                <th>Activity</th>
                <th>Created</th>
                <th>Activity Date</th>
                <th>When</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Logs.Count == 0)
            {
                <tr><td colspan="6" class="text-center text-body-secondary py-4">No thread activity matches.</td></tr>
            }
            else
            {
                foreach (var l in Model.Logs)
                {
                    var detailId = $"tal-{l.LogId}";
                    @* Click the row to toggle its detail row (independent collapse). No data-href. *@
                    <tr class="audit-row" role="button" data-bs-toggle="collapse" data-bs-target="#@detailId" aria-expanded="false" aria-controls="@detailId">
                        <td class="admin-id-col">
                            <code class="user-id-copy" role="button" title="@l.LogId" data-copy="@l.LogId">@l.LogId.Truncate(8, "…")</code>
                        </td>
                        <td class="admin-id-col">
                            <code class="user-id-copy" role="button" title="@l.ThreadId" data-copy="@l.ThreadId">@l.ThreadId.Truncate(8, "…")</code>
                        </td>
                        <td><span class="badge rounded-pill @ActivityBadge(l.ActivityType)">@l.ActivityTypeDisplay</span></td>
                        <td class="min-w-0">
                            <div class="fw-semibold text-truncate">@l.Username</div>
                            @if (l.CreatedById != "-")
                            {
                                <code class="user-id-copy small text-body-secondary" role="button" title="@l.CreatedById" data-copy="@l.CreatedById">@l.CreatedById.Truncate(12, "…")</code>
                            }
                            else
                            {
                                <span class="small text-body-secondary">—</span>
                            }
                        </td>
                        <td>@l.ActivityDate</td>
                        <td class="text-body-secondary">@l.RelativeDate</td>
                    </tr>
                    @* Detail row — the full activity detail string. *@
                    <tr class="audit-detail">
                        <td colspan="6" class="p-0 border-0">
                            <div id="@detailId" class="collapse">
                                <div class="bg-body-tertiary p-3">
                                    <div class="small text-body-secondary text-uppercase mb-2">Details</div>
                                    <div class="admin-log-detail">@l.Details</div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@if (!Model.Preview)
{
    <div class="mt-3 d-flex justify-content-center">
        <pagination model="Model.Logs" href-format="@hrefFormat" />
    </div>
}
