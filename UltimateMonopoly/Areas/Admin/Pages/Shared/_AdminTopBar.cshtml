@using UltimateMonopoly.Services
@inject ProfileService ProfileService
@{
    var currentUser = await ProfileService.GetCurrentUserProfileViewModelAsync();
}
<header class="admin-topbar">
    <a class="btn btn-sm btn-nav" href="/" title="Return to the app">
        <i class="bi bi-arrow-left me-1"></i>Back to App
    </a>

    <span class="admin-topbar-title">
        <i class="bi bi-shield-lock-fill"></i>
        <span class="admin-title-text">Admin Centre</span>
    </span>

    <div class="d-flex align-items-center gap-2 ms-auto">
        <partial name="_NotificationBell" />

        <div class="dropdown">
            <button class="btn p-0 border-0 rounded-circle" type="button"
                    data-bs-toggle="dropdown" aria-expanded="false" aria-label="My Account">
                <profile-circle user="currentUser" size="Md" />
            </button>
            <ul class="dropdown-menu dropdown-menu-end" style="max-width: 95vw;">
                <li><a class="dropdown-item" href="/"><i class="bi bi-box-arrow-left me-1"></i>Back to App</a></li>
                <li><hr class="dropdown-divider" /></li>
                <li><a class="dropdown-item" href="/profile">Profile</a></li>
                <li><a class="dropdown-item" href="/account">Account</a></li>
                <li><hr class="dropdown-divider" /></li>
                <li>
                    <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="m-0">
                        <button type="submit" class="dropdown-item dropdown-item-danger">Logout</button>
                    </form>
                </li>
            </ul>
        </div>
    </div>
</header>
