@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Centre</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdn.syncfusion.com/ej2/33.2.6/bootstrap5-dark.css" />
    @{
        var afTokens = Antiforgery.GetAndStoreTokens(Context);
    }
    <meta name="csrf-header" content="@afTokens.HeaderName" />
    <meta name="csrf-token" content="@afTokens.RequestToken" />
</head>
<body>
    <div class="admin-shell">
        <partial name="_AdminTopBar" />

        <div class="admin-main">
            <partial name="_AdminSidebar" />
            <main class="admin-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/scripts/navbar.js" asp-append-version="true"></script>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <script src="~/scripts/SignalR/signalr.min.js" asp-append-version="true"></script>
        <script src="~/scripts/SignalR/presence.js" asp-append-version="true"></script>
        <script src="~/scripts/notifications.js" asp-append-version="true"></script>
    }
    <script src="https://cdn.syncfusion.com/ej2/33.2.6/dist/ej2.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <ejs-scripts></ejs-scripts>
</body>
</html>
