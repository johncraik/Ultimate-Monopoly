@model UltimateMonopoly.Areas.Admin.Models.ViewModels.Dashboard.MetricCard
@* Reusable KPI card — used on the hub tiles and every spoke. Whole card links when Href is set. *@
<div class="card h-100 position-relative">
    <div class="card-body d-flex align-items-start gap-3">
        @if (!string.IsNullOrEmpty(Model.Icon))
        {
            <span class="admin-page-ico bg-@(Model.Tone)-subtle text-@Model.Tone"><i class="bi @Model.Icon"></i></span>
        }
        <div class="min-w-0">
            <div class="small text-body-secondary text-uppercase">@Model.Label</div>
            <div class="fs-4 fw-semibold lh-1 my-1">@Model.Value</div>
            @if (Model.Delta != null)
            {
                <span class="badge text-bg-@Model.Delta.Tone"><i class="bi @Model.Delta.Icon me-1"></i>@Model.Delta.Value</span>
            }
            @if (!string.IsNullOrEmpty(Model.Sub))
            {
                <div class="small text-body-secondary">@Model.Sub</div>
            }
        </div>
    </div>
    @if (!string.IsNullOrEmpty(Model.Href))
    {
        <a href="@Model.Href" class="stretched-link" aria-label="@Model.Label"></a>
    }
</div>
