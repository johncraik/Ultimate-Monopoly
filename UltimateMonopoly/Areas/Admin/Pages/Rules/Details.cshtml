@page
@model UltimateMonopoly.Areas.Admin.Pages.Rules.DetailsModel
@using JC.Core.Extensions
@{
    ViewData["Title"] = "Edit Rule";
    var r = Model.RuleData;
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-area="Admin" asp-page="Index" class="btn btn-sm btn-outline-secondary" title="Back to rules">
        <i class="bi bi-arrow-left"></i>
    </a>
    <span class="admin-page-ico bg-secondary-subtle text-secondary"><i class="bi bi-pencil-square"></i></span>
    <div>
        <h1 class="h3 mb-1">Edit Rule</h1>
        <p class="text-body-secondary mb-0">@Model.SectionName &middot; Rule @Model.RuleId</p>
    </div>
</div>

<alert type="Success" message="@(TempData["Success"] as string)" />

<div class="row g-4">
    @* ---------- Editable fields ---------- *@
    <div class="col-12 col-xl-8">
        <div class="card">
            <div class="card-header"><i class="bi bi-pencil-square me-2"></i>Rule text</div>
            <div class="card-body">
                <form method="post" asp-route-section="@Model.Section" asp-route-rule="@Model.Rule" asp-route-point="@Model.Point">
                    <div class="mb-3">
                        <label class="form-label" asp-for="Title">Title</label>
                        <input class="form-control" asp-for="Title" autocomplete="off" />
                        <span class="text-danger small" asp-validation-for="Title"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="Description">Description</label>
                        <textarea class="form-control" asp-for="Description" rows="5"></textarea>
                        <span class="text-danger small" asp-validation-for="Description"></span>
                    </div>
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" role="switch" asp-for="IsHidden" id="rule-hidden" />
                        <label class="form-check-label" for="rule-hidden">Hidden from the public rulebook</label>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save</button>
                        <a asp-area="Admin" asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @* ---------- Read-only identity (engine cites against these — not editable) ---------- *@
    <div class="col-12 col-xl-4">
        <div class="card">
            <div class="card-header"><i class="bi bi-info-circle me-2"></i>Identity</div>
            <div class="card-body">
                <div class="admin-detail-group">
                    <div class="admin-detail-row">
                        <span class="admin-detail-label">Section</span>
                        <span class="admin-detail-value">@Model.Section &middot; @Model.SectionName</span>
                    </div>
                    <div class="admin-detail-row">
                        <span class="admin-detail-label">Rule</span>
                        <span class="admin-detail-value">@Model.RuleId</span>
                    </div>
                    <div class="admin-detail-row">
                        <span class="admin-detail-label">Rule Code</span>
                        <span class="admin-detail-value">@(r.RuleCode?.ToDisplayName() ?? "None")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>