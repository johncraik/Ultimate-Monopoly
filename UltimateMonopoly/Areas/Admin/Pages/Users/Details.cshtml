@page "{userId}"
@model UltimateMonopoly.Areas.Admin.Pages.Users.DetailsModel
@{
    ViewData["Title"] = "User Details";
    var u = Model.User;

    string RoleBadgeClass(string role) =>
        role == AppRoles.SystemAdmin ? "text-bg-danger" :
        role == AppRoles.Admin ? "text-bg-primary" :
        role == AppRoles.GithubManager ? "text-bg-info" :
        role == AppRoles.Restricted ? "text-bg-warning" :
        role == AppRoles.HiddenUser ? "text-bg-secondary" : "text-bg-info";

    string RoleLabel(string role) =>
        role == AppRoles.SystemAdmin ? "System Admin" :
        role == AppRoles.GithubManager ? "GitHub Manager" :
        role == AppRoles.HiddenUser ? "Hidden" : role;
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-area="Admin" asp-page="Index" class="btn btn-sm btn-outline-secondary" title="Back to users">
        <i class="bi bi-arrow-left"></i>
    </a>
    <span class="admin-page-ico bg-info-subtle text-info"><i class="bi bi-person-gear"></i></span>
    <div>
        <h1 class="h3 mb-1">User Details</h1>
        <p class="text-body-secondary mb-0">@u.Profile.Username</p>
    </div>
</div>

<alert type="Success" message="@(TempData["Success"] as string)" />
<alert type="Error" message="@(TempData["Error"] as string)" />

<div class="row g-4">
    @* ---------- LEFT: everything about this user ---------- *@
    <div class="col-12 col-xl-7">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <profile-circle user="u.Profile" size="Md" />
                    <div class="min-w-0">
                        <h2 class="h5 mb-0 text-truncate">@u.Profile.Username</h2>
                        <div class="text-body-secondary text-truncate">@(string.IsNullOrWhiteSpace(u.Profile.DisplayName) ? "No display name" : u.Profile.DisplayName)</div>
                        <div class="mt-1">
                            @if (u.Roles.Count == 0)
                            {
                                <span class="badge text-bg-light">No roles</span>
                            }
                            else
                            {
                                foreach (var role in u.Roles)
                                {
                                    <span class="badge @RoleBadgeClass(role) me-1">@RoleLabel(role)</span>
                                }
                            }
                        </div>
                    </div>
                </div>

                <div class="admin-detail-list">
                    @* Identity *@
                    <div class="admin-detail-group">
                        <div class="admin-detail-row">
                            <span class="admin-detail-label"><i class="bi bi-fingerprint"></i>User ID</span>
                            <code class="admin-detail-value user-id-copy" role="button" data-copy="@u.Profile.UserId" title="Click to copy">@u.Profile.UserId</code>
                        </div>
                        <div class="admin-detail-row">
                            <span class="admin-detail-label"><i class="bi bi-person"></i>Username</span>
                            <span class="admin-detail-value">@u.Profile.Username</span>
                        </div>
                        <div class="admin-detail-row">
                            <span class="admin-detail-label"><i class="bi bi-card-text"></i>Display Name</span>
                            <span class="admin-detail-value">@(string.IsNullOrWhiteSpace(u.Profile.DisplayName) ? "—" : u.Profile.DisplayName)</span>
                        </div>
                    </div>

                    @* Contact *@
                    <div class="admin-detail-group">
                        <div class="admin-detail-row">
                            <span class="admin-detail-label"><i class="bi bi-envelope"></i>Email</span>
                            <span class="admin-detail-value">
                                @u.Email
                                @if (u.EmailConfirmed)
                                {
                                    <span class="badge text-bg-success ms-1"><i class="bi bi-check-lg"></i> Confirmed</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-danger ms-1"><i class="bi bi-x-lg"></i> Unconfirmed</span>
                                }
                            </span>
                        </div>
                        <div class="admin-detail-row">
                            <span class="admin-detail-label"><i class="bi bi-telephone"></i>Phone</span>
                            <span class="admin-detail-value">@u.PhoneNumber</span>
                        </div>
                    </div>

                    @* Security *@
                    <div class="admin-detail-group">
                        <div class="admin-detail-row">
                            <span class="admin-detail-label"><i class="bi bi-shield-lock"></i>Two-Factor Auth</span>
                            <span class="admin-detail-value"><span class="badge @(u.TwoFactorEnabled ? "text-bg-success" : "text-bg-secondary")">@(u.TwoFactorEnabled ? "Enabled" : "Disabled")</span></span>
                        </div>
                        <div class="admin-detail-row">
                            <span class="admin-detail-label"><i class="bi bi-lock"></i>Lockout</span>
                            <span class="admin-detail-value">
                                <span class="me-1">@u.AccessFailedCount failed</span>
                                <span class="badge @(u.LockoutEnabled ? "text-bg-warning" : "text-bg-secondary")">@(u.LockoutEnabled ? "Enabled" : "Off")</span>
                                <div class="small text-body-secondary mt-1">Ends: @u.LockoutEnd</div>
                            </span>
                        </div>
                    </div>

                    @* Status *@
                    <div class="admin-detail-group">
                        <div class="admin-detail-row">
                            <span class="admin-detail-label"><i class="bi bi-power"></i>Account</span>
                            <span class="admin-detail-value"><span class="badge @(u.IsEnabled ? "text-bg-success" : "text-bg-danger")">@(u.IsEnabled ? "Enabled" : "Disabled")</span></span>
                        </div>
                        <div class="admin-detail-row">
                            <span class="admin-detail-label"><i class="bi bi-slash-circle"></i>Restricted</span>
                            <span class="admin-detail-value"><span class="badge @(Model.TargetIsRestricted ? "text-bg-warning" : "text-bg-secondary")">@(Model.TargetIsRestricted ? "Restricted" : "No")</span></span>
                        </div>
                        <div class="admin-detail-row">
                            <span class="admin-detail-label"><i class="bi bi-eye-slash"></i>Visibility</span>
                            <span class="admin-detail-value"><span class="badge @(Model.TargetIsHidden ? "text-bg-secondary" : "text-bg-success")">@(Model.TargetIsHidden ? "Hidden" : "Visible")</span></span>
                        </div>
                    </div>

                    @* Activity *@
                    <div class="admin-detail-group">
                        <div class="admin-detail-row">
                            <span class="admin-detail-label"><i class="bi bi-box-arrow-in-right"></i>Last Login</span>
                            <span class="admin-detail-value">@u.LastLogin</span>
                        </div>
                        <div class="admin-detail-row">
                            <span class="admin-detail-label"><i class="bi bi-activity"></i>Last Active</span>
                            <span class="admin-detail-value">@u.LastActive</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ---------- RIGHT: actions ---------- *@
    <div class="col-12 col-xl-5">
        @* Section 1 — user-editable *@
        <div class="card mb-4">
            <div class="card-header"><i class="bi bi-pencil-square me-2"></i>Profile</div>
            <div class="card-body">
                <div class="alert alert-info d-flex gap-2 small mb-3">
                    <i class="bi bi-info-circle mt-1"></i>
                    <div>The user can change these themselves from their own profile — you're editing them as an admin.</div>
                </div>

                <form method="post" asp-page-handler="DisplayName" asp-route-userId="@Model.UserId" class="mb-4">
                    <label class="form-label" asp-for="DisplayName">Display Name</label>
                    <div class="input-group">
                        <input class="form-control" asp-for="DisplayName" placeholder="No display name" autocomplete="off" />
                        <button class="btn btn-primary" type="submit">Save</button>
                    </div>
                    <span class="text-danger small" asp-validation-for="DisplayName"></span>
                </form>

                <div class="d-flex justify-content-between align-items-start gap-3">
                    <div>
                        <div class="fw-semibold">@(Model.TargetIsHidden ? "Profile is hidden" : "Profile is visible")</div>
                        <div class="small text-body-secondary">Hidden users don't show up publicly (search, leaderboards), but friends can still find and view them.</div>
                    </div>
                    <form method="post" asp-page-handler="ToggleHidden" asp-route-userId="@Model.UserId">
                        <button class="btn btn-outline-secondary text-nowrap" type="submit">
                            <i class="bi @(Model.TargetIsHidden ? "bi-eye" : "bi-eye-slash") me-1"></i>@(Model.TargetIsHidden ? "Show" : "Hide")
                        </button>
                    </form>
                </div>
            </div>
        </div>

        @* Section 2 — account actions *@
        <div class="card">
            <div class="card-header"><i class="bi bi-shield-exclamation me-2"></i>Account actions</div>
            <div class="card-body d-flex flex-column gap-3">
                @* Restrict *@
                <div class="d-flex justify-content-between align-items-start gap-3">
                    <div>
                        <div class="fw-semibold">@(Model.TargetIsRestricted ? "Restricted" : "Restrict")</div>
                        <div class="small text-body-secondary">@AppRoles.RestrictedDesc</div>
                        @if (!Model.CanModerateTarget) { <span class="text-warning small d-block mt-1">Only a System Admin can moderate a System Admin account.</span> }
                    </div>
                    <form method="post" asp-page-handler="ToggleRestricted" asp-route-userId="@Model.UserId">
                        <button class="btn @(Model.TargetIsRestricted ? "btn-outline-success" : "btn-outline-warning") text-nowrap" type="submit"
                                @(Model.CanModerateTarget ? "" : "disabled")
                                title="@(Model.CanModerateTarget ? null : "Only a System Admin can moderate a System Admin account.")">
                            @(Model.TargetIsRestricted ? "Un-restrict" : "Restrict")
                        </button>
                    </form>
                </div>

                @* Enable / Disable *@
                <div class="d-flex justify-content-between align-items-start gap-3 border-top pt-3">
                    <div>
                        <div class="fw-semibold">@(u.IsEnabled ? "Disable account" : "Enable account")</div>
                        <div class="small text-body-secondary">
                            Blocks all access to the app — the user can't do anything at all, though the account still exists (a soft delete).
                            @if (Model.IsSelf) { <span class="text-warning d-block mt-1">You can't disable your own account.</span> }
                            @if (!Model.CanModerateTarget) { <span class="text-warning d-block mt-1">Only a System Admin can moderate a System Admin account.</span> }
                        </div>
                    </div>
                    <form method="post" asp-page-handler="ToggleEnabled" asp-route-userId="@Model.UserId">
                        <button class="btn @(u.IsEnabled ? "btn-outline-danger" : "btn-outline-success") text-nowrap" type="submit"
                                @((Model.IsSelf && u.IsEnabled) || !Model.CanModerateTarget ? "disabled" : "")
                                title="@(Model.CanModerateTarget ? null : "Only a System Admin can moderate a System Admin account.")">
                            @(u.IsEnabled ? "Disable" : "Enable")
                        </button>
                    </form>
                </div>

                @if (Model.IsSystemAdmin)
                {
                    @* Make / remove GitHub Manager — above Admin, below the Restricted action. *@
                    <div class="d-flex justify-content-between align-items-start gap-3 border-top pt-3">
                        <div>
                            <div class="fw-semibold">@(Model.TargetIsGithubManager ? "Remove GitHub Manager" : "Make GitHub Manager")</div>
                            <div class="small text-body-secondary">@AppRoles.GithubManagerDesc</div>
                        </div>
                        <form method="post" asp-page-handler="ToggleRole" asp-route-userId="@Model.UserId" asp-route-role="@AppRoles.GithubManager">
                            <button class="btn @(Model.TargetIsGithubManager ? "btn-outline-secondary" : "btn-outline-info") text-nowrap" type="submit">
                                @(Model.TargetIsGithubManager ? "Remove" : "Grant")
                            </button>
                        </form>
                    </div>

                    @* Make / remove Admin *@
                    <div class="d-flex justify-content-between align-items-start gap-3 border-top pt-3">
                        <div>
                            <div class="fw-semibold">@(Model.TargetIsAdmin ? "Remove Admin" : "Make Admin")</div>
                            <div class="small text-body-secondary">Read-only admin access: the audit trail and logs, full report management, and restricting or disabling users.</div>
                        </div>
                        <form method="post" asp-page-handler="ToggleRole" asp-route-userId="@Model.UserId" asp-route-role="@AppRoles.Admin">
                            <button class="btn @(Model.TargetIsAdmin ? "btn-outline-secondary" : "btn-outline-primary") text-nowrap" type="submit">
                                @(Model.TargetIsAdmin ? "Remove" : "Grant")
                            </button>
                        </form>
                    </div>

                    @* Make / remove System Admin *@
                    <div class="d-flex justify-content-between align-items-start gap-3 border-top pt-3">
                        <div>
                            <div class="fw-semibold">@(Model.TargetIsSystemAdmin ? "Remove System Admin" : "Make System Admin")</div>
                            <div class="small text-body-secondary">Full control — everything an Admin can do, plus rules, game management, retention settings, granting roles, and deleting users.</div>
                        </div>
                        <form method="post" asp-page-handler="ToggleRole" asp-route-userId="@Model.UserId" asp-route-role="@AppRoles.SystemAdmin">
                            <button class="btn @(Model.TargetIsSystemAdmin ? "btn-outline-secondary" : "btn-outline-danger") text-nowrap" type="submit">
                                @(Model.TargetIsSystemAdmin ? "Remove" : "Grant")
                            </button>
                        </form>
                    </div>

                    @* Delete *@
                    <div class="d-flex justify-content-between align-items-start gap-3 border-top pt-3">
                        <div>
                            <div class="fw-semibold text-danger">Delete account</div>
                            <div class="small text-body-secondary">Permanently deletes this account. A System Admin must have their role removed first, and you can't delete your own account.</div>
                        </div>
                        @if (Model.CanDelete)
                        {
                            <button class="btn btn-danger text-nowrap" type="button" data-bs-toggle="modal" data-bs-target="#deleteModal">Delete</button>
                        }
                        else
                        {
                            <button class="btn btn-danger text-nowrap" type="button" disabled
                                    title="@(Model.IsSelf ? "You can't delete your own account." : "Remove the System Admin role first.")">Delete</button>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@if (Model.CanDelete)
{
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="deleteModalLabel">Delete @u.Profile.Username?</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-2">This <strong>permanently deletes</strong> this account. This cannot be undone.</p>
                    <p class="small text-body-secondary mb-0">Their games, stats, and history stay (attributed to a now-missing id) until the cleanup job runs.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <form method="post" asp-page-handler="Delete" asp-route-userId="@Model.UserId" class="m-0">
                        <button type="submit" class="btn btn-danger">Delete permanently</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script src="~/scripts/admin/copy.js" asp-append-version="true"></script>
}
