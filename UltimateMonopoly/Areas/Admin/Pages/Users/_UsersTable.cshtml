@model UltimateMonopoly.Areas.Admin.Models.ViewModels.Users.UserTableModel
@using System
@using JC.Core.Extensions
@using Microsoft.AspNetCore.Html
@using Syncfusion.EJ2.DropDowns
@{
    // Solid green tick (true) / red cross (false).
    Func<bool, IHtmlContent> flag = on => new HtmlString(on
        ? "<i class=\"bi bi-check-circle-fill text-success\" title=\"Yes\"></i>"
        : "<i class=\"bi bi-x-circle-fill text-danger\" title=\"No\"></i>");

    // Restricted: solid amber '!' (restricted) / solid grey minus (not restricted).
    Func<bool, IHtmlContent> restrictedFlag = on => new HtmlString(on
        ? "<i class=\"bi bi-exclamation-circle-fill text-warning\" title=\"Restricted\"></i>"
        : "<i class=\"bi bi-dash-circle-fill text-secondary\" title=\"Not restricted\"></i>");

    // Pagination links carry the current filter/search (no handler) so a no-JS click reloads the full
    // page; user-management.js upgrades the click to a ?handler=Table partial fetch.
    var hrefFormat = $"?RestrictedFilter={Model.RestrictedFilter}&DisabledFilter={Model.DisabledFilter}" +
                     $"&Search={Uri.EscapeDataString(Model.Search ?? "")}&pageNumber={{0}}";
}

<div class="d-flex align-items-center justify-content-between mb-2">
    <span class="small text-body-secondary">Showing @Model.Users.Count.ToString("N0") of @Model.Users.TotalCount.ToString("N0") user(s)</span>
</div>

<div class="table-responsive">
    <table class="table table-hover table-sm align-middle admin-users-table mb-0">
        <thead>
            <tr class="text-body-secondary small text-uppercase">
                <th>User ID</th>
                <th>User</th>
                <th>Email</th>
                @if (Model.FullTable)
                {
                    <th>Phone</th>
                    <th class="text-center">2FA</th>
                    <th>Lockout</th>
                    <th>Last Login</th>
                    <th>Last Active</th>
                    <th class="text-center">Enabled</th>
                    <th class="text-center">Restricted</th>
                }
                <th class="text-end"></th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Users.Count == 0)
            {
                <tr><td colspan="@(Model.FullTable ? 11 : 4)" class="text-center text-body-secondary py-4">No users match these filters.</td></tr>
            }
            else
            {
                foreach (var u in Model.Users)
                {
                    // Non-full (picker) destination: the configured RowLinkBase, else the default User Trail.
                    var trailHref = $"/Admin/Audit/Users/Trail/{u.Profile.UserId}";
                    var pickerHref = Model.RowLinkBase != null ? $"{Model.RowLinkBase}/{u.Profile.UserId}" : trailHref;
                    <tr data-href="@(Model.FullTable ? $"/Admin/Users/Details/{u.Profile.UserId}" : pickerHref)">
                        <td>
                            <code class="user-id-copy" role="button" title="@u.Profile.UserId"
                                  data-copy-id="@u.Profile.UserId">@u.Profile.UserId.Truncate(8, "…")</code>
                        </td>
                        <td>
                            <div class="fw-semibold text-truncate">@u.Profile.Username</div>
                            <div class="small text-body-secondary text-truncate">@u.Profile.DisplayName</div>
                        </td>
                        <td>
                            <span class="me-1">@u.Email</span> @flag(u.EmailConfirmed)
                        </td>
                        @if (Model.FullTable)
                        {
                            <td>@u.PhoneNumber</td>
                            <td class="text-center">@flag(u.TwoFactorEnabled)</td>
                            <td>
                                <span class="me-1">@u.AccessFailedCount</span> @flag(u.LockoutEnabled)
                                <div class="small text-body-secondary">@u.LockoutEnd</div>
                            </td>
                            <td>@u.LastLogin</td>
                            <td>@u.LastActive</td>
                            <td class="text-center">@flag(u.IsEnabled)</td>
                            <td class="text-center">@restrictedFlag(u.IsRestricted ?? false)</td>
                        }
                        
                        <td class="text-end">
                            <div class="btn-group btn-group-sm" role="group">
                                @if (Model.FullTable)
                                {
                                    <a href="/Admin/Users/Details/@u.Profile.UserId"
                                       class="btn btn-outline-secondary" title="View details" aria-label="View details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                }
                                @if (!Model.FullTable && Model.RowLinkBase != null)
                                {
                                    <a href="@pickerHref" class="btn btn-outline-secondary" title="View" aria-label="View">
                                        <i class="bi bi-bell"></i>
                                    </a>
                                }
                                else
                                {
                                    <a href="@trailHref" class="btn btn-outline-secondary" title="Audit trail" aria-label="Audit trail">
                                        <i class="bi bi-clipboard-data"></i>
                                    </a>
                                }
                                
                                @if (Model.FullTable)
                                {
                                    <div class="btn-group btn-group-sm" role="group">
                                        <button type="button" class="btn btn-outline-secondary dropdown-toggle"
                                                data-bs-toggle="dropdown" aria-expanded="false" title="Logs" aria-label="Logs">
                                            <i class="bi bi-journal-text"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            <li><a class="dropdown-item" href="/Admin/Logs/Notifications/User/@u.Profile.UserId"><i class="bi bi-bell me-2"></i>Notifications</a></li>
                                            <li><a class="dropdown-item" href="/Admin/Logs/Emails?search=@u.Profile.UserId"><i class="bi bi-envelope me-2"></i>Emails</a></li>
                                            <li><a class="dropdown-item" href="/Admin/Logs/Messages?search=@u.Profile.UserId"><i class="bi bi-chat-dots me-2"></i>Messages</a></li>
                                        </ul>
                                    </div>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<div class="mt-3 d-flex justify-content-center">
    <pagination model="Model.Users" href-format="@hrefFormat" />
</div>
