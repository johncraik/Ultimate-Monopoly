@using MP.GameEngine.Models.Snapshot
@using UltimateMonopoly.Models.ViewModels.Games
@using UltimateMonopoly.Models.ViewModels.Social
@using UltimateMonopoly.Services.Cache
@model UltimateMonopoly.Areas.Admin.Models.ViewModels.GameStateViewModel
@inject PlayerCacheService PlayerCache
@{
    // Admin read-only game state for one turn: the selected player's profile, the game-info panel, and the
    // board — all reused from the live game (admin → game), rendered off the rehydrated engine. No game-play
    // hub is registered, so the view is inert. Reloaded by game-details.js on turn / player change.
    var engine = Model.Engine;
    var cache = engine.Cache;
    var game = cache.Game;

    // The board needs per-player counters (non-bankrupt) — same construction as _PlayView.
    var playerCounters = new List<(UserProfileViewModel, PlayerModel)>();
    foreach (var p in game.GetPlayers(excludePovPlayer: false))
    {
        playerCounters.Add((await PlayerCache.GetPlayerProfile(p.PlayerId), p));
    }
}

@* Selected player's profile (read-only) *@
<partial name="~/Areas/Game/Pages/Shared/Play/_PlayerProfileView.cshtml"
         model="new PlayerProfilePlayViewModel(engine, Model.PlayerId, Model.ViewerUserId, IsAdminView: true)" />

@* Game info panel *@
<div class="mt-3">
    <partial name="~/Areas/Game/Pages/Shared/Play/_GameInfoPanel.cshtml" model="engine" />
</div>

@* Board *@
<div class="mt-3">
    <partial name="~/Areas/Game/Pages/Shared/Play/_BoardView.cshtml"
             model="new BoardViewModel(cache.Board, game.Properties, playerCounters, game.FreeParkingAmount)" />
</div>