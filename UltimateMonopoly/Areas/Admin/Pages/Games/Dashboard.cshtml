@page
@model UltimateMonopoly.Areas.Admin.Pages.Games.DashboardModel
@{
    ViewData["Title"] = "Games Dashboard";
    var d = Model.Data;
    const string baseDir = "~/Areas/Admin/Pages/Shared/Dashboard/";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <span class="admin-page-ico bg-success-subtle text-success"><i class="bi bi-controller"></i></span>
    <div>
        <h1 class="h3 mb-1">Games</h1>
        <p class="text-body-secondary mb-0">Lifecycle, players, length, boards, storage, and activity.</p>
    </div>
    <a asp-area="Admin" asp-page="/Games/Index" class="btn btn-sm btn-outline-secondary ms-auto">
        <i class="bi bi-list-ul me-1"></i>Game list
    </a>
</div>

<partial name="@(baseDir)_AlertStrip.cshtml" model="d.Alerts" />

@* KPI strip *@
<div class="row g-3 mb-4">
    @foreach (var k in d.Kpis)
    {
        <div class="col-6 col-md-4 col-xl"><partial name="@(baseDir)_MetricCard.cshtml" model="k" /></div>
    }
</div>

@* Lifecycle & configuration *@
<h2 class="h5 mb-3"><i class="bi bi-diagram-3 me-2 text-primary"></i>Lifecycle &amp; configuration</h2>
<div class="row g-3 mb-3">
    <div class="col-6 col-xl-3"><partial name="@(baseDir)_Gauge.cshtml" model="d.CompletionRate" /></div>
    <div class="col-6 col-xl-3"><partial name="@(baseDir)_Gauge.cshtml" model="d.CancellationRate" /></div>
    <div class="col-12 col-xl-6"><partial name="@(baseDir)_Breakdown.cshtml" model="d.GamesByState" /></div>
</div>
<div class="row g-3 mb-4">
    <div class="col-12 col-xl-6"><partial name="@(baseDir)_Breakdown.cshtml" model="d.OutcomeSplit" /></div>
    <div class="col-12 col-xl-6"><partial name="@(baseDir)_Histogram.cshtml" model="d.RoundingRules" /></div>
</div>

@* Players & length *@
<h2 class="h5 mb-3"><i class="bi bi-people me-2 text-info"></i>Players &amp; length</h2>
<div class="row g-3 mb-3">
    <div class="col-6 col-xl-3"><partial name="@(baseDir)_MetricCard.cshtml" model="d.AvgPlayers" /></div>
    <div class="col-6 col-xl-3"><partial name="@(baseDir)_MetricCard.cshtml" model="d.AvgTurns" /></div>
    <div class="col-12 col-xl-6"><partial name="@(baseDir)_TopList.cshtml" model="d.LongestGames" /></div>
</div>
<div class="row g-3 mb-4">
    <div class="col-12 col-xl-6"><partial name="@(baseDir)_Histogram.cshtml" model="d.PlayersPerGame" /></div>
    <div class="col-12 col-xl-6"><partial name="@(baseDir)_Histogram.cshtml" model="d.GameLength" /></div>
</div>

@* Boards & storage *@
<h2 class="h5 mb-3"><i class="bi bi-hdd me-2 text-secondary"></i>Boards &amp; storage</h2>
<div class="row g-3 mb-3">
    <div class="col-12 col-xl-4"><partial name="@(baseDir)_Breakdown.cshtml" model="d.BoardUsage" /></div>
    <div class="col-12 col-xl-4"><partial name="@(baseDir)_TopList.cshtml" model="d.TopBoards" /></div>
    <div class="col-12 col-xl-4"><partial name="@(baseDir)_MetricCard.cshtml" model="d.TotalStorage" /></div>
</div>
<div class="row g-3 mb-4">
    <div class="col-12"><partial name="@(baseDir)_TopList.cshtml" model="d.TopGamesBySize" /></div>
</div>

@* Trends *@
<h2 class="h5 mb-3"><i class="bi bi-graph-up me-2 text-primary"></i>Trends</h2>
<div class="row g-3">
    <div class="col-12 col-xl-6"><partial name="@(baseDir)_Series.cshtml" model="d.GamesCreated" /></div>
    <div class="col-12 col-xl-6"><partial name="@(baseDir)_Series.cshtml" model="d.GamesConcluded" /></div>
    <div class="col-12"><partial name="@(baseDir)_Series.cshtml" model="d.TurnThroughput" /></div>
</div>
