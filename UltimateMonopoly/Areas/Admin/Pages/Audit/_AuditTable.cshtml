@using JC.Core.Enums
@using JC.Core.Extensions
@using Microsoft.AspNetCore.Html
@model UltimateMonopoly.Areas.Admin.Models.ViewModels.Audits.AuditTableModel
@{
    // Pagination links carry the current search/action (no handler) so a no-JS click reloads the full
    // page; audit-trail.js upgrades the click to a ?handler=Table partial fetch.
    var hrefFormat = $"?Search={Uri.EscapeDataString(Model.Search ?? "")}&Action={Model.Action}&pageNumber={{0}}";

    // Rounded badge per action — Create:success, Update:info, SoftDelete:warning, Delete:danger, Restore:secondary.
    string ActionBadge(AuditAction a) => a switch
    {
        AuditAction.Create => "text-bg-success",
        AuditAction.Update => "text-bg-info",
        AuditAction.SoftDelete => "text-bg-warning",
        AuditAction.Delete => "text-bg-danger",
        AuditAction.Restore => "text-bg-secondary",
        _ => "text-bg-secondary"
    };

    // Present → green tick; absent → AMBER warning (not red): a missing key/data blob is an expected,
    // low-severity audit gap, not an error.
    Func<bool, IHtmlContent> flag = present => new HtmlString(present
        ? "<i class=\"bi bi-check-circle-fill text-success\" title=\"Present\"></i>"
        : "<i class=\"bi bi-exclamation-circle-fill text-warning\" title=\"None\"></i>");
}

<div class="d-flex align-items-center justify-content-between mb-2">
    <span class="small text-body-secondary">@Model.Entries.TotalCount.ToString("N0") entr@(Model.Entries.TotalCount == 1 ? "y" : "ies")</span>
</div>

<div class="table-responsive">
    <table class="table table-hover table-sm align-middle admin-audit-table mb-0">
        <thead>
            <tr class="text-body-secondary small text-uppercase">
                <th class="admin-id-col">Audit ID</th>
                @* Variable column: user trail fixes the user → show Table; data trail fixes the table → show User. *@
                @if (Model.IsUserTrail)
                {
                    <th>Table</th>
                }
                else
                {
                    <th>User</th>
                }
                <th>Date</th>
                <th>When</th>
                <th>Action</th>
                <th class="audit-col-flag text-center">Keys</th>
                <th class="audit-col-flag text-center">Data</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Entries.Count == 0)
            {
                <tr><td colspan="7" class="text-center text-body-secondary py-4">No audit entries match.</td></tr>
            }
            else
            {
                foreach (var e in Model.Entries)
                {
                    var detailId = $"ae-{e.AuditId}";
                    @* The data row — clicking it toggles the detail row below (independent collapse, many can
                       be open). No data-href, so clickable-rows.js leaves it alone. *@
                    <tr class="audit-row" role="button" data-bs-toggle="collapse" data-bs-target="#@detailId" aria-expanded="false" aria-controls="@detailId">
                        <td class="admin-id-col">
                            <code class="user-id-copy" role="button" title="@e.AuditId" data-copy="@e.AuditId">@e.AuditId.Truncate(8, "…")</code>
                        </td>
                        @if (Model.IsUserTrail)
                        {
                            <td class="fw-semibold text-truncate">@e.TableName</td>
                        }
                        else
                        {
                            <td class="min-w-0">
                                <div class="fw-semibold text-truncate">@e.UserName</div>
                                <code class="user-id-copy small text-body-secondary" role="button" title="@e.UserId" data-copy="@e.UserId">@e.UserId.Truncate(12, "…")</code>
                            </td>
                        }
                        <td>@e.AuditDate</td>
                        <td class="text-body-secondary">@e.RelativeDate</td>
                        <td><span class="badge rounded-pill @ActionBadge(e.Action)">@e.ActionDisplay</span></td>
                        <td class="audit-col-flag text-center">@flag(e.TableKeys.Count > 0)</td>
                        <td class="audit-col-flag text-center">@flag(e.ActionData != null)</td>
                    </tr>
                    @* The detail row — keys (left, each copyable) + the pretty-printed action data (right). *@
                    <tr class="audit-detail">
                        <td colspan="7" class="p-0 border-0">
                            <div id="@detailId" class="collapse">
                                @* Background + padding live on this wrapper, NOT the .row: a .row with a
                                   gutter (g-3) has a negative top margin, which would bleed its background up
                                   into the clicked row above. *@
                                <div class="bg-body-tertiary p-3">
                                    <div class="row g-3">
                                    <div class="col-12 col-lg-5">
                                        <div class="small text-body-secondary text-uppercase mb-2">Entity keys</div>
                                        @if (e.TableKeys.Count == 0)
                                        {
                                            <div class="text-body-secondary small"><i class="bi bi-exclamation-circle text-warning me-1"></i>No entity key recorded.</div>
                                        }
                                        else
                                        {
                                            <div class="d-flex flex-column gap-2">
                                                @foreach (var (key, value) in e.TableKeys)
                                                {
                                                    var val = value?.ToString() ?? "";
                                                    <div class="d-flex align-items-center gap-2 min-w-0">
                                                        <span class="badge text-bg-secondary flex-shrink-0">@key</span>
                                                        <code class="flex-grow-1 text-truncate user-id-copy" role="button" data-copy="@val" title="Click to copy">@val</code>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                    <div class="col-12 col-lg-7">
                                        <div class="small text-body-secondary text-uppercase mb-2">Action data</div>
                                        @if (e.ActionData is null)
                                        {
                                            <div class="text-body-secondary small"><i class="bi bi-exclamation-circle text-warning me-1"></i>No change data recorded.</div>
                                        }
                                        else
                                        {
                                            <pre class="admin-audit-json mb-0"><code>@e.ActionData</code></pre>
                                        }
                                    </div>
                                </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<div class="mt-3 d-flex justify-content-center">
    <pagination model="Model.Entries" href-format="@hrefFormat" />
</div>