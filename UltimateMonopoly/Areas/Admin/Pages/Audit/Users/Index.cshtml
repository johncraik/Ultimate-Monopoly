@page
@model UltimateMonopoly.Areas.Admin.Pages.Audit.Users.IndexModel
@{
    ViewData["Title"] = "User Trail";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <span class="admin-page-ico bg-warning-subtle text-warning"><i class="bi bi-clipboard-data"></i></span>
    <div>
        <h1 class="h3 mb-1">User Trail</h1>
        <p class="text-body-secondary mb-0">Pick a user to see every action they've taken across the app.</p>
    </div>
    @* No userId + system=true → the System / background-actor trail on the same Trail page. *@
    <a asp-area="Admin" asp-page="/Audit/Users/Trail" asp-route-system="true"
       class="btn btn-outline-warning ms-auto align-self-center text-nowrap">
        <i class="bi bi-robot me-1"></i>View System Trail
    </a>
</div>

@* Search only (no filters). A plain GET form is the no-JS fallback; user-management.js intercepts it and
   re-fetches just the table partial (?handler=Table). Reuses the audit-mode (FullTable=false) _UsersTable. *@
<form id="user-filters" method="get" class="card mb-3">
    <div class="card-body">
        <label class="form-label small text-body-secondary mb-1" for="user-search">Search</label>
        <div class="input-group">
            <input type="search" class="form-control" id="user-search" name="Search" value="@Model.Search"
                   placeholder="Username, name, email, phone…" autocomplete="off" />
            <button class="btn btn-primary" type="submit" aria-label="Search"><i class="bi bi-search"></i></button>
        </div>
    </div>
</form>

<div id="users-table">
    <partial name="~/Areas/Admin/Pages/Users/_UsersTable.cshtml" model="Model.TableModel" />
</div>

@section Scripts {
    <script src="~/scripts/admin/user-management.js" asp-append-version="true"></script>
}